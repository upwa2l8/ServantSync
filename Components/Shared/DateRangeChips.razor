@* Shared date-range chip strip. Emits (fromUtc, toUtc) on user change.
   Parent owns the (FromUtc, ToUtc) state; this component manages the chip
   selection and the custom date inputs visually.

   Migration note: the preset chips use <MudButtonGroup> + <MudButton>,
   but the custom date inputs are kept as raw <input type="date">
   elements. MudBlazor's date picker (MudDatePicker) requires a
   MudPopoverProvider + full MudBlazor theme setup that's heavier than
   this lightweight component warrants; the native <input type="date">
   is well-supported across modern browsers and matches the original
   UX. *@

<MudStack Row="true" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
    <MudText Typo="Typo.caption" Class="mud-text-secondary me-1">Range:</MudText>
    <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
        @foreach (var p in Presets)
        {
            <MudButton Color="@(_mode == p.mode ? Color.Primary : Color.Default)"
                       Variant="@(_mode == p.mode ? Variant.Filled : Variant.Outlined)"
                       OnClick="() => SetModeAsync(p.mode)">
                @p.label
            </MudButton>
        }
    </MudButtonGroup>
    @if (_mode == RangeMode.Custom)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="ms-2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-0">From</MudText>
            <input type="date" class="form-control form-control-sm" style="width:160px"
                   value="@_customFrom.ToString("yyyy-MM-dd")"
                   @onchange="OnCustomFromChanged" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-0">to</MudText>
            <input type="date" class="form-control form-control-sm" style="width:160px"
                   value="@_customTo.ToString("yyyy-MM-dd")"
                   @onchange="OnCustomToChanged" />
        </MudStack>
    }
</MudStack>
@code {
    public enum RangeMode
    {
        Today = 0,
        Next7 = 1,
        Next14 = 2,
        Next30 = 3,
        Next90 = 4,
        All = 5,
        Custom = 6,
    }

    [Parameter, EditorRequired] public DateTime FromUtc { get; set; }
    [Parameter, EditorRequired] public DateTime ToUtc { get; set; }
    [Parameter] public EventCallback<(DateTime From, DateTime To)> OnRangeChanged { get; set; }
    [Parameter] public RangeMode InitialMode { get; set; } = RangeMode.Next14;

    private RangeMode _mode;
    private DateTime _customFrom = DateTime.UtcNow.Date;
    private DateTime _customTo = DateTime.UtcNow.Date.AddDays(14);

    private record PresetItem(RangeMode mode, string label);

    private static readonly List<PresetItem> Presets = new()
    {
        new(RangeMode.Today,  "Today"),
        new(RangeMode.Next7,  "7 days"),
        new(RangeMode.Next14, "14 days"),
        new(RangeMode.Next30, "30 days"),
        new(RangeMode.Next90, "90 days"),
        new(RangeMode.All,    "All"),
        new(RangeMode.Custom, "Custom…"),
    };

    protected override void OnInitialized()
    {
        _mode = InitialMode;
    }

    private async Task SetModeAsync(RangeMode mode)
    {
        _mode = mode;
        var (from, to) = DateRangeCalculator.Resolve(mode, _customFrom, _customTo, DateTime.UtcNow);
        FromUtc = from;
        ToUtc = to;
        await OnRangeChanged.InvokeAsync((from, to));
    }

    private async Task OnCustomFromChanged(ChangeEventArgs e)
    {
        if (!DateTime.TryParse(e.Value?.ToString(), out var d)) return;
        _customFrom = d;
        if (_customTo < _customFrom) _customTo = _customFrom;
        if (_mode == RangeMode.Custom)
            await SetModeAsync(RangeMode.Custom);
    }

    private async Task OnCustomToChanged(ChangeEventArgs e)
    {
        if (!DateTime.TryParse(e.Value?.ToString(), out var d)) return;
        _customTo = d;
        if (_customTo < _customFrom) _customFrom = _customTo;
        if (_mode == RangeMode.Custom)
            await SetModeAsync(RangeMode.Custom);
    }
}
