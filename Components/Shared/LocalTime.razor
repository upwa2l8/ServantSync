@implements IDisposable

@* Renders a UTC value as the user's browser-detected local time.

    The browser timezone is set once per Blazor circuit by
    `Components.TimeZoneInitializer` (via the scoped
    `Services.UserTimeZoneProvider`). During the brief prerender window
    before that JS round-trip completes, this falls back to the
    server's `TimeZoneInfo.Local` so the page is never blank. The
    initializer fires `Provider.RaiseChanged()` after assigning
    `TimeZoneId` — this component subscribes and re-renders so the
    fallback swaps out for the user's actual zone on the next tick.

    The `<time datetime="…">` markup is semantic and machine-readable:
    screen readers and calendar apps pick up the original UTC instant,
    humans see it shifted to their local zone.

    Default format is "MMM d, h:mm tt" → e.g. "Jan 12, 9:00 AM".
    Common alternatives:
      • Format="HH:mm"               → "14:00"
      • Format="h:mm tt"             → "2:00 PM"
      • Format="ddd, MMM d h:mm tt"  → "Sun, Jan 12 2:00 PM"
      • Format="MMM d"               → "Jan 12"

    Pass `Class` to add a Bootstrap class on the `<time>` element — used
    by the calendar pill to preserve the original `calendar-pill-time`
    spacing/styling.

    Pass `FallbackTimeZoneId` (round-AV) to provide an org-level IANA
    timezone id used when the browser-detected zone isn't available.
    Resolution precedence: provider (browser) → FallbackTimeZoneId (org)
    → server local. Typical caller is a page that resolves the parent
    org and passes its `Organization.TimeZoneId` here. An invalid IANA
    id on the fallback tier falls through silently — it must not break
    a page render if an admin typed a typo into the database.
*@

<time datetime="@Utc.ToString("o")" class="@Class">@DisplayLocal</time>

@code {
    [Parameter, EditorRequired] public DateTime Utc { get; set; }
    [Parameter] public string Format { get; set; } = "MMM d, h:mm tt";
    [Parameter] public string? Class { get; set; }

    /// <summary>
    /// Optional fallback IANA timezone id used when the browser-detected
    /// provider zone is missing. Round-AV: callers resolve the parent org
    /// of the rendered event (or the user's picked override for /Open,
    /// which lists shifts across multiple orgs) and pipe the org's
    /// <c>Organization.TimeZoneId</c> here. Resolution precedence
    /// (implemented by the private <c>ResolveZone</c> helper just below):
    ///   1. <c>TzProvider.TimeZoneId</c> (browser-detected) —
    ///      strict; reflects what the JS layer reported.
    ///   2. This <c>FallbackTimeZoneId</c> (org-TZ from the database) —
    ///      defensive; a typo'd IANA id silently falls through.
    ///   3. <c>TimeZoneInfo.Local</c> (server-Local during the prerender
    ///      window before either of the above is known).
    /// </summary>
    [Parameter] public string? FallbackTimeZoneId { get; set; }

    // Optional — tests or contexts that don't register UserTimeZoneProvider
    // fall through to the next tier below (org-TZ fallback, then server
    // local).
    [Inject] private UserTimeZoneProvider? TzProvider { get; set; }

    private string DisplayLocal => Convert(Utc).ToString(Format);

    private DateTime Convert(DateTime utc)
    {
        // Many assignment rows are seeded without an explicit UTC marker
        // even though we always store UTC. Force Unspecified->Utc rather
        // than letting .ToUniversalTime() shift "Unspecified" values as if
        // they were server-local (the bug IcsCalendarGenerator already
        // guards against for the same reason).
        utc = DateTime.SpecifyKind(utc, DateTimeKind.Utc);
        return TimeZoneInfo.ConvertTimeFromUtc(utc, ResolveZone());
    }

    /// <summary>
    /// Walk the 3-tier resolution chain. The returned
    /// <see cref="TimeZoneInfo"/> is always non-null.
    ///
    /// Tier 1 is strict: <see cref="TzProvider"/>.TimeZoneId comes from
    /// <c>Intl.DateTimeFormat().resolvedOptions().timeZone</c> via the
    /// browser, which always returns a valid IANA id on a supported
    /// runtime. Throwing here surfaces a real JS-layer bug.
    ///
    /// Tier 2 is defensive: <see cref="FallbackTimeZoneId"/> comes from
    /// the database; an admin's hand-typed or migrated typo can't break
    /// a page render — we step down to tier 3 instead.
    /// </summary>
    private TimeZoneInfo ResolveZone()
    {
        // Tier 1 — strict: provider id comes from the browser JS layer,
        // which always returns a valid IANA id on a supported runtime.
        // A throw here surfaces a real JS-layer / DI bug rather than silent
        // mislocalization.
        var providerId = TzProvider?.TimeZoneId;
        if (!string.IsNullOrEmpty(providerId))
            return TimeZoneInfo.FindSystemTimeZoneById(providerId);

        // Tier 2 — defensive: the fallback id comes from the database, so
        // a hand-typed or migrated typo'd IANA id must not break a page
        // render. We catch broadly (TimeZoneNotFoundException +
        // InvalidTimeZoneException together) so any failure mode in the
        // lookup chain steps down to tier 3 instead of crashing.
        var fallbackId = FallbackTimeZoneId;
        if (!string.IsNullOrEmpty(fallbackId))
        {
            try
            {
                return TimeZoneInfo.FindSystemTimeZoneById(fallbackId);
            }
            catch (Exception)
            {
                // Fall through to tier 3 (server local).
            }
        }

        // Tier 3 — last-resort: server local during the prerender window
        // before either tier above is known.
        return TimeZoneInfo.Local;
    }

    protected override void OnInitialized()
    {
        if (TzProvider is not null)
            TzProvider.TimeZoneChanged += OnTzChanged;
    }

    private void OnTzChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        if (TzProvider is not null)
            TzProvider.TimeZoneChanged -= OnTzChanged;
    }
}
