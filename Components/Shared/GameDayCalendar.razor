@* GameDayCalendar — day-grouped list overlay of games and volunteer
   shifts. Used on /Leagues/{id}/Schedule so a coordinator can see at
   a glance which games are happening and who's working each one. *@

<MudCard>
    <MudCardHeader>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudText Typo="Typo.subtitle1"><strong>@_title</strong></MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@_filtered.Count event@(_filtered.Count == 1 ? "" : "s") in view</MudText>
                @if (Arenas.Any())
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Filter by arena</MudText>
                    <MudSelect T="string" @bind-Value="_arenaFilter" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="width: auto">
                        <MudSelectItem T="string" Value="@("all")">All arenas</MudSelectItem>
                        @foreach (var a in Arenas)
                        {
                            <MudSelectItem T="string" Value="@a.Id.ToString()">@a.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudStack>
        </MudStack>
    </MudCardHeader>
    <MudCardContent>
        @if (!_filtered.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mb-0">No events in this window.</MudAlert>
        }
        else
        {
            // Group by the user's local calendar day so a Sunday-evening
            // service scheduled as "2025-01-12 03:00Z" lands under Jan 11
            // (the day the user is on), not Jan 12.
            @foreach (var day in _filtered.GroupBy(e => TzProvider.ToLocal(e.StartUtc).Date).OrderBy(g => g.Key))
            {
                <div class="mb-3">
                    <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">@day.Key.ToString("ddd, MMM d, yyyy")</MudText>
                    <MudList T="CalendarEvent">
                        @foreach (var ev in day.OrderBy(e => e.StartUtc))
                        {
                            <MudListItem>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <div>
                                        <MudChip T="string" Size="Size.Small" Class="me-2"><LocalTime Utc="@ev.StartUtc" Format="HH:mm" />–<LocalTime Utc="@ev.EndUtc" Format="HH:mm" /></MudChip>
                                        <a href="@ev.Href" class="text-decoration-none">@ev.Title</a>
                                        @if (!string.IsNullOrEmpty(ev.Subtitle))
                                        {
                                            <MudText Typo="Typo.caption" Inline="true" Class="mud-text-secondary ms-2">· @ev.Subtitle</MudText>
                                        }
                                        @if (!string.IsNullOrEmpty(ev.Location))
                                        {
                                            <MudText Typo="Typo.caption" Inline="true" Class="mud-text-secondary ms-2">@ev.Location</MudText>
                                        }
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@ev.Status</MudChip>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </div>
            }
        }
    </MudCardContent>
</MudCard>

@implements IDisposable
@inject UserTimeZoneProvider TzProvider
@code {
    [Parameter, EditorRequired] public List<CalendarEvent> Events { get; set; } = new();
    [Parameter] public DateTime FromUtc { get; set; } = DateTime.UtcNow.Date;
    [Parameter] public DateTime ToUtc { get; set; } = DateTime.UtcNow.AddDays(14);
    [Parameter] public List<Arena> Arenas { get; set; } = new();
    [Parameter] public string? Title { get; set; }

    private string _arenaFilter = "all";

    private string _title => Title
        ?? $"From {FromUtc:MMM d} to {ToUtc.AddDays(-1):MMM d, yyyy}";

    private List<CalendarEvent> _filtered => Events
        .Where(e => e.StartUtc >= FromUtc && e.StartUtc < ToUtc)
        .Where(e => _arenaFilter == "all"
            || (e.ArenaId.HasValue && e.ArenaId.Value.ToString() == _arenaFilter))
        .ToList();

    protected override void OnInitialized() =>
        TzProvider.TimeZoneChanged += OnTimeZoneChanged;

    public void Dispose() =>
        TzProvider.TimeZoneChanged -= OnTimeZoneChanged;

    private void OnTimeZoneChanged() =>
        InvokeAsync(StateHasChanged);
}
