@implements IDisposable
@inject UserTimeZoneProvider TzProvider

@* Month + week calendar. Renders a 6×7 grid (Sun-first) in Month mode
   and an hour-row × 7-day-column grid in Week mode. Day cells in Month
   mode cap visible pills at 3 and surface a "+N more" affordance that
   expands inline on click.

   Day grouping and hour bucketing happen in the *user's local* timezone
   (via UserTimeZoneProvider) so an evening service scheduled as
   "2025-01-12 03:00Z" lands under Jan 11 for an EST viewer, not Jan 12.
   Falls back to server TimeZoneInfo.Local during the brief prerender
   window before the JS roundtrip populates the provider.

   Migration note: the custom CSS grid (`.calendar-grid`, `.calendar-cell`,
   `.calendar-out`, `.calendar-today`, `.calendar-daynum`, `.calendar-pill`,
   `.calendar-pill-time`, `.week-grid`, `.week-corner`, `.week-day-header`,
   `.week-hour-label`, `.week-cell`) is preserved because MudGrid is a
   12-column flexbox grid that can't represent the 6×7 month layout or
   the hour-row × 7-day-column week layout. Only the header controls
   (card, btn-group, buttons) were migrated to MudBlazor primitives.
   The event pills stay as raw `<a class="badge bg-*">` elements because
   the custom `.calendar-pill` CSS handles overflow/ellipsis/line-height
   that MudChip would break. The "+N more" expand buttons also stay as
   raw `<button class="btn btn-link">` because they're inline-text
   affordances inside the calendar cell, not standalone buttons. *@

<MudCard>
    <MudCardHeader>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                <MudButton OnClick="Prev" aria-label="Previous">‹</MudButton>
                <MudButton OnClick="GoToday">Today</MudButton>
                <MudButton OnClick="Next" aria-label="Next">›</MudButton>
            </MudButtonGroup>
            <MudText Typo="Typo.subtitle1"><strong>@_title</strong></MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@Events.Count event@(Events.Count == 1 ? "" : "s") in view</MudText>
                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                    <MudButton Color="@(_viewMode == CalendarViewMode.Month ? Color.Primary : Color.Default)"
                               Variant="@(_viewMode == CalendarViewMode.Month ? Variant.Filled : Variant.Outlined)"
                               OnClick="() => SetViewMode(CalendarViewMode.Month)">Month</MudButton>
                    <MudButton Color="@(_viewMode == CalendarViewMode.Week ? Color.Primary : Color.Default)"
                               Variant="@(_viewMode == CalendarViewMode.Week ? Variant.Filled : Variant.Outlined)"
                               OnClick="() => SetViewMode(CalendarViewMode.Week)">Week</MudButton>
                </MudButtonGroup>
            </MudStack>
        </MudStack>
    </MudCardHeader>
    <MudCardContent Class="pa-0">
    @if (_viewMode == CalendarViewMode.Month)
    {
        <div class="calendar-grid">
            @foreach (var dn in DayNames)
            {
                <div class="calendar-head">@dn</div>
            }
            @foreach (var cell in _monthCells)
            {
                <div class="calendar-cell @(cell.IsCurrentMonth ? "" : "calendar-out") @(cell.IsToday ? "calendar-today" : "")">
                    <div class="calendar-daynum">@cell.Date.Day</div>
                    @foreach (var ev in cell.Events)
                    {
                        <a href="@ev.Href" class="calendar-pill badge bg-@ev.StatusColor text-decoration-none"
                           title="@ev.Tooltip">
                            <LocalTime Utc="@ev.StartUtc" Format="HH:mm" Class="calendar-pill-time" />@ev.Title
                            @* Round-FR-2.3b: training-event badge so a
                               training session doesn't visually compete
                               with regular assignments on the same day.
                               Renders as a small inline pill after the
                               title; the link itself is unchanged.
                               Round-FR-2.3 polish-3 follow-up (ii):
                               MySchedule.razor now projects in-person
                               training sessions into the same
                               CalendarEvent list with IsTraining=true,
                               so this branch is reachable for the
                               volunteer's own scheduled sessions.
                               Other call sites (Open.razor, Dashboard.razor)
                               still default to IsTraining=false and can
                               opt in by setting it true on their
                               CalendarEvent projection. *@
                            @if (ev.IsTraining)
                            {
                                <span class="badge bg-info ms-1" style="font-size: 0.6rem;">training</span>
                            }
                        </a>
                    }
                    @if (cell.MoreCount > 0)
                    {
                        var key = cell.Date.ToString("yyyy-MM-dd");
                        if (_expandedDays.Contains(key))
                        {
                            @foreach (var ev in cell.AllEvents.Skip(3))
                            {
                                <a href="@ev.Href" class="calendar-pill badge bg-@ev.StatusColor text-decoration-none"
                                   title="@ev.Tooltip">
                                    <LocalTime Utc="@ev.StartUtc" Format="HH:mm" Class="calendar-pill-time" />@ev.Title
                                </a>
                            }
                            <button type="button" class="btn btn-link btn-sm text-muted text-decoration-none px-1 py-0 text-start"
                                    aria-expanded="true" aria-label="Collapse this day"
                                    @onclick="() => ToggleDayExpansion(cell.Date)">
                                Show less
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-link btn-sm text-muted text-decoration-none px-1 py-0 text-start"
                                    aria-expanded="false" aria-label="Show @cell.MoreCount more events"
                                    @onclick="() => ToggleDayExpansion(cell.Date)">
                                +@cell.MoreCount more
                            </button>
                        }
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="week-grid">
            <div class="week-corner"></div>
            @foreach (var d in _weekDays)
            {
                <div class="week-day-header @(d.Date == _today ? "calendar-today" : "")">
                    <div>@d.Date.ToString("ddd")</div>
                    <div class="small text-muted">@d.Date.Day</div>
                </div>
            }
            @for (int h = StartHour; h < EndHour; h++)
            {
                <div class="week-hour-label">@FormatHour(h)</div>
                @foreach (var d in _weekDays)
                {
                    // Bucketing is local: the cell date is in the user's
                    // local TZ, the event's local date/hour must match.
                    var hourEvents = Events
                        .Select(e => new { Ev = e, Local = TzProvider.ToLocal(e.StartUtc) })
                        .Where(x => x.Local.Date == d.Date && x.Local.Hour == h)
                        .OrderBy(x => x.Ev.StartUtc)
                        .Select(x => x.Ev)
                        .ToList();
                    <div class="week-cell">
                    @foreach (var ev in hourEvents)
                    {
                        <a href="@ev.Href" class="calendar-pill badge bg-@ev.StatusColor text-decoration-none"
                           title="@ev.Tooltip">
                            <LocalTime Utc="@ev.StartUtc" Format="HH:mm" />@(ev.EndUtc.Hour > ev.StartUtc.Hour ? "→" : "")<LocalTime Utc="@ev.EndUtc" Format="HH:mm" />@ev.Title
                            @* Round-FR-2.3b: training-event badge so
                               a training session doesn't visually
                               compete with regular assignments in the
                               week-grid. Mirrors the month-view pill
                               above.                               Round-FR-2.3 polish-3 follow-up (ii):
                               wired up for MySchedule.razor — same
                               opt-in shape as the month view; other
                               call sites default to IsTraining=false
                               and can opt in by setting it true on
                               their CalendarEvent projection. *@
                            @if (ev.IsTraining)
                            {
                                <span class="badge bg-info ms-1" style="font-size: 0.6rem;">training</span>
                            }
                        </a>
                    }
                    </div>
                }
            }
        </div>
    }
    </MudCardContent>
</MudCard>
@code {
    public enum CalendarViewMode { Month, Week }

    private const int StartHour = 6;   // 6 AM
    private const int EndHour   = 22;  // 10 PM (exclusive)

    [Parameter, EditorRequired] public List<CalendarEvent> Events { get; set; } = new();
    [Parameter] public DateTime AnchorDate { get; set; } = DateTime.UtcNow;
    [Parameter] public EventCallback<DateTime> AnchorDateChanged { get; set; }
    /// <summary>One-way: the parent can set the initial view mode; the
    /// calendar owns subsequent toggles via the inline Month/Week buttons.</summary>
    [Parameter] public CalendarViewMode ViewMode { get; set; } = CalendarViewMode.Month;

    private CalendarViewMode _viewMode = CalendarViewMode.Month;
    private DateTime _anchor = new(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateTime _today = DateTime.UtcNow.Date;
    private List<MonthCell> _monthCells = new();
    private List<DateTime> _weekDays = new();
    private string _title = "";
    private HashSet<string> _expandedDays = new();

    private static readonly string[] DayNames = { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };

    protected override void OnInitialized()
    {
        TzProvider.TimeZoneChanged += OnTimeZoneChanged;
    }

    public void Dispose()
    {
        TzProvider.TimeZoneChanged -= OnTimeZoneChanged;
    }

    private void OnTimeZoneChanged()
    {
        // TzProvider is now populated for real; rebuild everything that
        // depends on a user-local frame and trigger a re-render. The
        // razor markup re-evaluates the inline .Where filters on render,
        // so a plain StateHasChanged is enough to redraw with the new TZ.
        _today = TzProvider.ToLocal(DateTime.UtcNow).Date;
        if (_viewMode == CalendarViewMode.Month) BuildMonthCells();
        else BuildWeekDays();
        InvokeAsync(StateHasChanged);
    }

    protected override void OnParametersSet()
    {
        _viewMode = ViewMode;
        _today = TzProvider.ToLocal(DateTime.UtcNow).Date;
        if (_viewMode == CalendarViewMode.Month)
        {
            // AnchorDate is a *local-frame* month marker; callers compute it
            // from TzProvider.ToLocal(DateTime.UtcNow). Reading Year/Month
            // directly (no extra ToLocal here) avoids the previous bug
            // where the UTC instant and the local calendar day landed in
            // different months for negative-offset users.
            _anchor = new DateTime(AnchorDate.Year, AnchorDate.Month, 1);
            _title = _anchor.ToString("MMMM yyyy");
            BuildMonthCells();
        }
        else
        {
            _anchor = StartOfWeek(AnchorDate.Date);
            _title = $"{_anchor:MMM d} \u2013 {_anchor.AddDays(6):MMM d, yyyy}";
            BuildWeekDays();
        }
    }

    private void BuildMonthCells()
    {
        var firstOfMonth = _anchor;
        var startGrid = firstOfMonth.AddDays(-(int)firstOfMonth.DayOfWeek);
        _monthCells = new List<MonthCell>(42);
        for (int i = 0; i < 42; i++)
        {
            var d = startGrid.AddDays(i);
            // Day bucketing is local: each event's local Date must match
            // the cell's user-local date.
            var dayEvents = Events
                .Select(e => new { Ev = e, Local = TzProvider.ToLocal(e.StartUtc) })
                .Where(x => x.Local.Date == d)
                .OrderBy(x => x.Ev.StartUtc)
                .Select(x => x.Ev)
                .ToList();
            _monthCells.Add(new MonthCell
            {
                Date = d,
                IsCurrentMonth = d.Month == _anchor.Month,
                IsToday = d.Date == _today,
                Events = dayEvents.Take(3).ToList(),
                AllEvents = dayEvents,
                MoreCount = Math.Max(0, dayEvents.Count - 3),
            });
        }
    }

    private void BuildWeekDays()
    {
        _weekDays = Enumerable.Range(0, 7).Select(i => _anchor.AddDays(i)).ToList();
    }

    private async Task Prev()
    {
        _anchor = _viewMode == CalendarViewMode.Month
            ? _anchor.AddMonths(-1)
            : _anchor.AddDays(-7);
        await AnchorDateChanged.InvokeAsync(_anchor);
    }

    private async Task Next()
    {
        _anchor = _viewMode == CalendarViewMode.Month
            ? _anchor.AddMonths(1)
            : _anchor.AddDays(7);
        await AnchorDateChanged.InvokeAsync(_anchor);
    }

    private async Task GoToday()
    {
        var now = _today;
        _anchor = _viewMode == CalendarViewMode.Month
            ? new DateTime(now.Year, now.Month, 1)
            : StartOfWeek(now);
        await AnchorDateChanged.InvokeAsync(_anchor);
    }

    private async Task SetViewMode(CalendarViewMode mode)
    {
        if (_viewMode == mode) return;
        _viewMode = mode;
        _expandedDays.Clear();
        // Snap the anchor to a sensible value for the new view.
        _anchor = mode == CalendarViewMode.Month
            ? new DateTime(_anchor.Year, _anchor.Month, 1)
            : StartOfWeek(_anchor);
    }

    private void ToggleDayExpansion(DateTime date)
    {
        var key = date.ToString("yyyy-MM-dd");
        if (!_expandedDays.Add(key)) _expandedDays.Remove(key);
    }

    private static DateTime StartOfWeek(DateTime d) =>
        d.Date.AddDays(-(int)d.DayOfWeek);

    private static string FormatHour(int h) =>
        h == 0 ? "12 AM" :
        h < 12 ? $"{h} AM" :
        h == 12 ? "12 PM" :
        $"{h - 12} PM";

    private class MonthCell
    {
        public DateTime Date { get; set; }
        public bool IsCurrentMonth { get; set; }
        public bool IsToday { get; set; }
        public List<CalendarEvent> Events { get; set; } = new();
        public List<CalendarEvent> AllEvents { get; set; } = new();
        public int MoreCount { get; set; }
    }
}
