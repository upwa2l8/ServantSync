@* Generic confirmation modal (MudBlazor overlay).
   Phase 5 — Bootstrap removal: the original Bootstrap modal shell
   (class="modal fade show d-block" + modal-dialog + modal-content +
   modal-header + modal-body + modal-footer) is replaced with a
   MudOverlay + MudPaper pattern. The Visible-bound @if preserves the
   public API contract — every caller wires up the component the same
   way as before (Visible="@(someCondition)" + OnConfirm + OnCancel +
   ChildContent), so no caller refactor is needed. The ConfirmButtonClass
   string parameter is still accepted (e.g. "btn-danger") for caller
   stability, and is mapped to the MudBlazor Color enum internally
   via the _confirmColor computed property.

   Keyboard / aria / backdrop parity with the prior Bootstrap version:
     - Esc dismisses (MudOverlay AutoClose + OnClick -> HandleBackdrop)
     - Clicking the backdrop dismisses (MudOverlay AutoClose=true)
     - Title has aria-labelledby
     - Cancel button gets focus on open (autofocus HTML attribute) *@

@if (Visible)
{
    <MudOverlay Visible="true"
                DarkBackground="true"
                AutoClose="true"
                OnClick="HandleCancel"
                ZIndex="9999">
        <MudPaper Elevation="8"
                  Class="pa-4"
                  Style="width: 500px; max-width: 90vw;"
                  @onclick:stopPropagation="true">
            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Class="mb-3">
                <MudText Typo="Typo.h6" id="@($"{InstanceId}-title")">@Title</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="HandleCancel"
                               Disabled="@Busy"
                               aria-label="Close" />
            </MudStack>

            <div class="mb-4">
                @ChildContent
            </div>

            <MudStack Row="true"
                      Justify="Justify.FlexEnd"
                      Spacing="2">
                <MudButton OnClick="HandleCancel"
                           Disabled="@Busy"
                           autofocus>@CancelText</MudButton>
                <MudButton Color="@_confirmColor"
                           Variant="Variant.Filled"
                           OnClick="HandleConfirm"
                           Disabled="@Busy">
                    @if (Busy)
                    {
                        <MudProgressCircular Size="Size.Small"
                                             Indeterminate="true"
                                             Class="me-2" />
                    }
                    @ConfirmText
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudOverlay>
}

@code {
    /// <summary>Whether the dialog is visible. Bound by the parent.</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>Title shown at the top of the dialog.</summary>
    [Parameter, EditorRequired] public string Title { get; set; } = "";

    /// <summary>Body content (rendered between title and buttons).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Text for the confirm (primary) button.</summary>
    [Parameter] public string ConfirmText { get; set; } = "OK";

    /// <summary>Text for the cancel (secondary) button.</summary>
    [Parameter] public string CancelText { get; set; } = "Cancel";

    /// <summary>
    /// Caller-supplied Bootstrap-style button class for the confirm action —
    /// usually <c>btn-danger</c> or <c>btn-warning</c>. Preserved for caller
    /// stability across the Phase-5 Bootstrap removal; mapped to the
    /// MudBlazor <see cref="Color"/> enum internally via
    /// <see cref="_confirmColor"/>.
    /// </summary>
    [Parameter] public string ConfirmButtonClass { get; set; } = "btn-primary";

    /// <summary>When true, both buttons are disabled and the confirm button shows a spinner.</summary>
    [Parameter] public bool Busy { get; set; }

    /// <summary>Fired when the user clicks the confirm button.</summary>
    [Parameter] public EventCallback OnConfirm { get; set; }

    /// <summary>Fired when the user clicks the cancel button, the close icon, the backdrop, or presses Esc.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    /// <summary>
    /// Stable per-instance id used for aria-labelledby. Generated once
    /// per component instance so multiple ConfirmDialogs on the same
    /// page (e.g. one for slot delete + one for arena delete) don't
    /// collide on the title's id attribute.
    /// </summary>
    private string InstanceId { get; } = $"confirm-{Guid.NewGuid():N}";

    // Map the legacy Bootstrap ConfirmButtonClass string (e.g. "btn-danger")
    // to the MudBlazor Color enum. Literal-pattern matches (not the
    // `var c when c.Contains("...")` style) so the intent reads at a
    // glance and a future contributor adding a new caller-passed class
    // string gets the obvious "add a case here" prompt. Unknown /
    // empty values fall through to Color.Primary (the safe default).
    private Color _confirmColor => ConfirmButtonClass switch
    {
        "btn-danger" => Color.Error,
        "btn-warning" => Color.Warning,
        "btn-success" => Color.Success,
        "btn-info" => Color.Info,
        "btn-secondary" => Color.Default,
        _ => Color.Primary,
    };

    private async Task HandleConfirm()
    {
        if (Busy) return;
        await OnConfirm.InvokeAsync();
    }

    private async Task HandleCancel()
    {
        if (Busy) return;
        await OnCancel.InvokeAsync();
    }
}
