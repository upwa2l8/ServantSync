@*
    MudBlazor-flavored skeleton placeholder. Use in place of a "0" or
    empty value while async data is loading so the page doesn't flash
    zeros before the real data arrives.

    Defaults to a Medium (~1em) shimmer spanning 6 of 12 grid columns.
    Pass `Size` to size up (matches `display-6` etc.) or down, and
    `Columns` (`col-1`…`col-12`) to control the visual width within
    its container.

    `aria-hidden="true"` on the <MudSkeleton> because it's purely
    visual chrome — the surrounding label conveys what's loading for
    screen readers.

    `MudSkeleton SkeletonType="Rectangle"` with `Style="min-height: 4rem"`
    matches the height of `display-6` text (~4rem) so the layout
    doesn't shift visibly when data arrives.
*@

<MudSkeleton SkeletonType="@_mudType" Class="@ColClass" Style="@StyleAttr" aria-hidden="true" />

@code {
    [Parameter] public SkeletonSize Size { get; set; } = SkeletonSize.Medium;
    [Parameter] public int Columns { get; set; } = 6;

    public enum SkeletonSize { Small, Medium, Large, Display }

    private SkeletonType _mudType => Size switch
    {
        SkeletonSize.Small   => SkeletonType.Text,
        SkeletonSize.Medium  => SkeletonType.Text,
        SkeletonSize.Large   => SkeletonType.Rectangle,
        SkeletonSize.Display => SkeletonType.Rectangle,
        _ => SkeletonType.Text,
    };
    private string ColClass => $"col-{Math.Clamp(Columns, 1, 12)}";

    // Display-6 is 4rem; placeholder-lg (2.5em) is too small. Other sizes
    // inherit their natural placeholder default which we don't override.
    private string StyleAttr => Size == SkeletonSize.Display ? "min-height: 4rem;" : "";
}
