@page "/Account/ResetPassword"
@layout AccountLayout
@rendermode InteractiveServer

<PageTitle>Reset password · ServantSync</PageTitle>

<h1 class="h3 mb-3">Set a new password</h1>
<StatusMessage Message="@_message" IsError="@_isError" />

@if (string.IsNullOrEmpty(Email))
{
    <p class="text-muted">
        Finish resetting your password: enter the email tied to your account and a new password.
        If the token in the URL is valid, your password will be updated.
    </p>
    <EditForm Model="_model" OnValidSubmit="HandleReset" FormName="reset-no-email">
        <div class="form-floating mb-3">
            <InputText id="email" class="form-control" @bind-Value="_model.Email" autocomplete="username" />
            <label for="email">Email</label>
        </div>
        <div class="form-floating mb-3">
            <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" autocomplete="new-password" />
            <label for="password">New password (8+ chars)</label>
        </div>
        <div class="form-floating mb-3">
            <InputText id="confirm" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" autocomplete="new-password" />
            <label for="confirm">Confirm password</label>
        </div>
        <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
            @(_busy ? "Saving…" : "Update password")
        </button>
    </EditForm>
}
else
{
    <EditForm Model="_model" OnValidSubmit="HandleReset" FormName="reset">
        <div class="form-floating mb-3">
            <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" autocomplete="new-password" />
            <label for="password">New password (8+ chars)</label>
        </div>
        <div class="form-floating mb-3">
            <InputText id="confirm" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" autocomplete="new-password" />
            <label for="confirm">Confirm password</label>
        </div>
        <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
            @(_busy ? "Saving…" : "Update password")
        </button>
    </EditForm>
}

@inject UserManager<IdentityUser> UserManager
@inject NavigationManager Nav
@code {
    [SupplyParameterFromQuery] public string? Code { get; set; }
    [SupplyParameterFromQuery] public string? Email { get; set; }

    [SupplyParameterFromForm] private ResetModel _model { get; set; } = new();
    private string? _message;
    private bool _isError;
    private bool _busy;

    protected override void OnInitialized()
    {
        _model.Email = Email ?? "";
    }

    private async Task HandleReset()
    {
        if (string.IsNullOrEmpty(Code) || string.IsNullOrEmpty(_model.Email))
        {
            _isError = true;
            _message = "This reset link is missing information. Request a new one.";
            return;
        }

        if (_model.Password != _model.ConfirmPassword)
        {
            _isError = true;
            _message = "Passwords do not match.";
            return;
        }

        _busy = true;
        try
        {
            var user = await UserManager.FindByEmailAsync(_model.Email.Trim());
            if (user is null)
            {
                _isError = true;
                _message = "Reset link is invalid or has expired.";
                return;
            }

            // Validate the token first to give a clear "invalid token" path
            // before ResetPasswordAsync consumes it.
            var tokenOk = await UserManager.VerifyUserTokenAsync(
                user, TokenOptions.DefaultProvider, "ResetPassword", Code);
            if (!tokenOk)
            {
                _isError = true;
                _message = "Reset link is invalid or has expired. Request a new one.";
                return;
            }

            var result = await UserManager.ResetPasswordAsync(user, Code, _model.Password);
            if (!result.Succeeded)
            {
                _isError = true;
                _message = string.Join("; ", result.Errors.Select(e => e.Description));
                return;
            }

            Nav.NavigateTo("Account/Login?reset=success", forceLoad: true);
        }
        finally
        {
            _busy = false;
        }
    }

    private class ResetModel
    {
        public string Email { get; set; } = "";
        [Required, MinLength(8)] public string Password { get; set; } = "";
        [Required, MinLength(8)] public string ConfirmPassword { get; set; } = "";
    }
}
