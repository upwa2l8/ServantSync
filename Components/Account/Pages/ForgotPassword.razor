@page "/Account/ForgotPassword"
@layout AccountLayout
@rendermode InteractiveServer

<PageTitle>Forgot password · ServantSync</PageTitle>

<h1 class="h3 mb-3">Forgot your password?</h1>
<StatusMessage Message="@_message" IsError="@_isError" />

<p>Enter your account email and we'll send you a link to set a new password.</p>

<EditForm Model="_model" OnValidSubmit="HandleForgot" FormName="forgot">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-floating mb-3">
        <InputText id="email" class="form-control" @bind-Value="_model.Email" autocomplete="username" />
        <label for="email">Email</label>
    </div>

    <button type="submit" class="btn btn-primary w-100">
        @(_busy ? "Sending…" : "Send reset link")
    </button>
</EditForm>

<p class="mt-3 mb-0">
    Remembered it? <a href="Account/Login">Sign in</a>
</p>

@inject UserManager<IdentityUser> UserManager
@inject IEmailSender<IdentityUser> EmailSender
@inject IHttpContextAccessor Http
@inject NavigationManager Nav
@code {
    [SupplyParameterFromForm] private ForgotModel _model { get; set; } = new();
    private string? _message;
    private bool _isError;
    private bool _busy;

    private async Task HandleForgot()
    {
        _busy = true;
        try
        {
            var email = _model.Email.Trim();
            var user = await UserManager.FindByEmailAsync(email);

            // Don't reveal whether the email exists — always show the same message.
            const string generic = "If an account exists for that email, a reset link has been sent.";
            if (user is null)
            {
                _isError = false;
                _message = generic;
                return;
            }

            var token = await UserManager.GeneratePasswordResetTokenAsync(user);
            var callback = BuildCallback(token);
            await EmailSender.SendPasswordResetLinkAsync(user, email, callback);

            _isError = false;
            _message = generic;
        }
        finally
        {
            _busy = false;
        }
    }

    private string BuildCallback(string token)
    {
        // Prefer the true scheme/host from the HTTP context (works correctly
        // behind reverse proxies when ForwardedHeaders is configured). Fall
        // back to NavigationManager.BaseUri for prerender/disconnected cases.
        var ctx = Http.HttpContext;
        if (ctx is not null)
        {
            var scheme = ctx.Request.Scheme;
            var host = ctx.Request.Host.Value;
            return $"{scheme}://{host}/Account/ResetPassword?code={Uri.EscapeDataString(token)}";
        }

        var baseUri = Nav.BaseUri.TrimEnd('/');
        return $"{baseUri}/Account/ResetPassword?code={Uri.EscapeDataString(token)}";
    }

    private class ForgotModel
    {
        [Required, EmailAddress] public string Email { get; set; } = "";
    }
}
