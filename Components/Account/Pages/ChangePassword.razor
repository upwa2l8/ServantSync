@page "/Account/ChangePassword"
@layout AccountLayout
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Change password · ServantSync</PageTitle>

<h1 class="h3 mb-3">Change your password</h1>
<StatusMessage Message="@_message" IsError="@_isError" />

<EditForm Model="_model" OnValidSubmit="HandleChange" FormName="change-password">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-floating mb-3">
        <InputText id="old" type="password" class="form-control" @bind-Value="_model.OldPassword" autocomplete="current-password" />
        <label for="old">Current password</label>
    </div>
    <div class="form-floating mb-3">
        <InputText id="new" type="password" class="form-control" @bind-Value="_model.NewPassword" autocomplete="new-password" />
        <label for="new">New password (8+ chars)</label>
    </div>
    <div class="form-floating mb-3">
        <InputText id="confirm" type="password" class="form-control" @bind-Value="_model.ConfirmPassword" autocomplete="new-password" />
        <label for="confirm">Confirm new password</label>
    </div>

    <button type="submit" class="btn btn-primary w-100" disabled="@_busy">
        @(_busy ? "Saving…" : "Change password")
    </button>
</EditForm>

@inject UserManager<IdentityUser> UserManager
@inject AuthenticationStateProvider Auth
@code {
    [SupplyParameterFromForm] private ChangeModel _model { get; set; } = new();
    private string? _message;
    private bool _isError;
    private bool _busy;

    private async Task HandleChange()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _isError = true;
            _message = "Passwords do not match.";
            return;
        }

        _busy = true;
        try
        {
            var state = await Auth.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(state.User);
            if (user is null)
            {
                _isError = true;
                _message = "Could not load your account.";
                return;
            }

            var result = await UserManager.ChangePasswordAsync(user, _model.OldPassword, _model.NewPassword);
            if (!result.Succeeded)
            {
                _isError = true;
                _message = string.Join("; ", result.Errors.Select(e => e.Description));
                return;
            }

            _isError = false;
            _message = "Password updated.";
            _model = new();
        }
        finally
        {
            _busy = false;
        }
    }

    private class ChangeModel
    {
        [Required] public string OldPassword { get; set; } = "";
        [Required, MinLength(8)] public string NewPassword { get; set; } = "";
        [Required, MinLength(8)] public string ConfirmPassword { get; set; } = "";
    }
}
