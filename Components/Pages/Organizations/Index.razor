@page "/Organizations"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Organizations</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.h4" Class="gradient-text">Organizations</MudText>
    @* Round-AZ: the "+ New organization" affordance widens to either
       OrgAdmin (existing) OR SystemAdmin. The OR matches the actual
       capability of OrganizationService.CreateOrgAsync — the service
       gate widens to either branch, so hiding the button here on the
       basis of the narrower OrgAdmin-only check would 403-on-submit a
       SystemAdmin (who's only Admin via the identity role, not via
       OrganizationMembership). SystemAdmin who IS NOT Admin of any
       existing org keeps the bootstrap-tenant creation capability. *@
    @if (_isAnyAdmin || _isSystemAdmin)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Href="Organizations/New" StartIcon="@Icons.Material.Outlined.Add">
            New organization
        </MudButton>
    }
</MudStack>

@if (_orgs is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_orgs.Any())
{
    @* Round-AZ: a SystemAdmin sees the "no orgs yet" bootstrap copy
       because they ARE the authoritative bootstrap-Admin identity role
       and can use the +New affordance to spin up the first tenant. A
       non-SysAdmin signed-in user keeps the "ask an admin" copy. *@
    <MudPaper Outlined="true" Class="glass-card pa-4">
        <MudStack Spacing="2">
            @if (_isSystemAdmin)
            {
                <MudText>No organizations yet — create the first one.</MudText>
            }
            else
            {
                <MudText>
                    You are not yet a member of any organization. Ask an admin for an invite,
                    or use the <MudLink Href="Account/Register">Register</MudLink> link from
                    your organization to join.
                </MudText>
            }
        </MudStack>
    </MudPaper>
}
else
{
    <MudPaper Outlined="true" Class="glass-card">
        <MudTable Items="_orgs" Hover="true" Striped="true" Dense="false" Elevation="0">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Ministries</MudTh>
                <MudTh>Members</MudTh>
                <MudTh Style="text-align:right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudLink Href="@LinkBuilder.OrganizationHref(context.Id)">@context.Name</MudLink>
                </MudTd>
                <MudTd DataLabel="Ministries">@context.MinistryCount</MudTd>
                <MudTd DataLabel="Members">@context.MemberCount</MudTd>
                <MudTd DataLabel="Actions" Style="text-align:right">
                    @* Per-row Edit button: Admin-only. *@
                    @if (context.CanEdit)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   Href="@LinkBuilder.OrganizationEditHref(context.Id)">
                            Edit
                        </MudButton>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject NavigationManager Nav
@code {
    private List<OrgRow>? _orgs;
    private string _userId = "";
    private bool _isAnyAdmin;
    private bool _isSystemAdmin;
    // Per-page breadcrumb trail. Same shape as the rest of the migrated
    // pages — `MudBreadcrumbs` is the MudBlazor equivalent of the old
    // <ol class="breadcrumb"> block.
    private List<BreadcrumbItem> _crumbs = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("Organizations", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _isAnyAdmin = await OrgAuth.IsAnyOrgAdminAsync(_userId);
        _isSystemAdmin = await OrgAuth.IsSystemAdminAsync(_userId);

        await using var db = await DbFactory.CreateDbContextAsync();

        var myOrgIds = _isSystemAdmin
            ? new List<int>()
            : await db.OrganizationMemberships
                .Where(m => m.PersonUserId == _userId)
                .Select(m => m.OrganizationId)
                .ToListAsync();

        var adminOrgIds = (await db.OrganizationMemberships
            .Where(m => m.PersonUserId == _userId
                && m.Role == OrganizationRole.Admin)
            .Select(m => m.OrganizationId)
            .ToListAsync())
            .ToHashSet();

        if (!_isSystemAdmin && myOrgIds.Count == 1 && !adminOrgIds.Contains(myOrgIds[0]))
        {
            Nav.NavigateTo($"Organizations/{myOrgIds[0]}");
            return;
        }

        _orgs = await db.Organizations
            .Where(o => _isSystemAdmin || myOrgIds.Contains(o.Id))
            .OrderBy(o => o.Name)
            .Select(o => new OrgRow
            {
                Id = o.Id,
                Name = o.Name,
                MinistryCount = o.Ministries.Count,
                MemberCount = o.Memberships.Count,
                CanEdit = adminOrgIds.Contains(o.Id),
            })
            .ToListAsync();
    }

    private class OrgRow
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int MinistryCount { get; set; }
        public int MemberCount { get; set; }
        public bool CanEdit { get; set; }
    }
}
