@page "/Organizations/{OrgId:int}/Training/Sessions/New"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>New training session</PageTitle>

@* Bootstrap breadcrumb (matches the Sessions/Index + Sessions/Detail
   pattern but adds a "New session" tier for the create affordance.
   Renders unconditionally on the page so a user who failed the
   permission gate can still navigate back via the breadcrumb rather
   than browser-back. _orgName is fetched at the top of
   OnInitializedAsync so it's populated even on early returns. *@
<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="">Home</a></li>
        <li class="breadcrumb-item"><a href="Organizations">Organizations</a></li>
        <li class="breadcrumb-item"><a href="@($"Organizations/{OrgId}")">@_orgName</a></li>
        <li class="breadcrumb-item"><a href="@($"Organizations/{OrgId}/Training/Sessions")">In-person training sessions</a></li>
        <li class="breadcrumb-item active" aria-current="page">New session</li>
    </ol>
</nav>

<h1>New training session</h1>
<StatusMessage Message="@_message" IsError="@_isError" />

@if (!_authChecked)
{
    <p class="text-muted">Loading permissions…</p>
}

<EditForm Model="_model" OnValidSubmit="Save" FormName="training-session-new">
    @* Same form-mount discipline as Training/Edit.razor (round-AF):
       FormName restored, EditForm is always-mounted, internal
       <fieldset disabled> gates on _canSubmit. The @if (!_authChecked)
       sentinel above shows the loading state until the
       OnInitializedAsync terminal; once _authChecked flips, the
       fieldset enables (or stays disabled) in a single re-render. *@
    <DataAnnotationsValidator />
    <ValidationSummary />
    <fieldset disabled="@(!_authChecked || !_canSubmit)">

        <div class="row g-2 mb-3">
            <div class="col-md-8">
                <div class="form-floating">
                    <InputText id="title" class="form-control" @bind-Value="_model.Title" />
                    <label for="title">Title</label>
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <div class="form-control-plaintext">
                    <span class="badge bg-primary">Scheduled</span>
                    <span class="text-muted small ms-2">(created as Scheduled)</span>
                </div>
            </div>
        </div>

        <div class="form-floating mb-3">
            <InputTextArea id="desc" class="form-control" style="height: 5rem" @bind-Value="_model.Description" />
            <label for="desc">Description (optional)</label>
        </div>

        <div class="form-floating mb-3">
            <InputText id="location" class="form-control" @bind-Value="_model.Location" />
            <label for="location">Location</label>
        </div>

        <div class="row g-2 mb-3">
            <div class="col-md-4">
                <label class="form-label">Start (your local time)</label>
                @* Manual value + onchange avoids Blazor's @bind DateTime conversion
                   on datetime-local inputs (fails silently in InteractiveServer).
                   Same string-based pattern as Games/Edit.razor time inputs. *@
                <input type="datetime-local" class="form-control"
                       value="@_model.StartLocal"
                       @onchange="OnStartChanged" />
            </div>
            <div class="col-md-4">
                <label class="form-label">End (your local time)</label>
                <input type="datetime-local" class="form-control"
                       value="@_model.EndLocal"
                       @onchange="OnEndChanged" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Max attendees (optional)</label>
                <input type="number" min="1" class="form-control" @bind="_model.MaxAttendees" />
                <div class="form-text">Leave blank for no capacity limit.</div>
            </div>
        </div>

        <div class="form-floating mb-3">
            <select class="form-select" @bind="_model.TrainingContentId">
                <option value="">— General orientation (no specific training) —</option>
                @foreach (var c in _orgTraining)
                {
                    <option value="@c.Id">@c.Title</option>
                }
            </select>
            <label>Linked training content (optional)</label>
            <div class="form-text">If set, marking attendance also writes a TrainingCompletion for the linked content.</div>
        </div>

        <div class="mt-3">
            <button class="btn btn-primary" type="submit">Create session</button>
            <a class="btn btn-outline-secondary ms-2" href="@($"Organizations/{OrgId}/Training/Sessions")">Cancel</a>
        </div>
    </fieldset>
</EditForm>

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITrainingSessionService SessionService
@inject ITrainingService TrainingService
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject NavigationManager Nav
@code {
    [Parameter] public int OrgId { get; set; }
    [SupplyParameterFromForm] private SessionModel _model { get; set; } = new();
    // Org-name cache for the breadcrumb. Fetched at the top of
    // OnInitializedAsync independent of auth outcome so the breadcrumb
    // renders a real label even when the user is redirected or denied.
    // The same fallback as Sessions/Detail.razor (Org #{OrgId}).
    private string _orgName = "";
    private string? _message;
    private bool _isError;
    private bool _canSubmit;
    private bool _authChecked;
    private List<ContentOption> _orgTraining = new();
    private string _userId = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        // Fetch the org name FIRST so the breadcrumb shows a real
        // label even for the auth-denied branches below. The fetch
        // is one indexed lookup on Organizations.Id so it's cheap
        // and runs before the auth/permission gates. Same fallback
        // ("Org #{OrgId}") as Sessions/Detail.razor's breadcrumb.
        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            _orgName = await db.Organizations
                .Where(o => o.Id == OrgId)
                .Select(o => o.Name)
                .FirstOrDefaultAsync() ?? $"Org #{OrgId}";
        }
        if (string.IsNullOrEmpty(_userId))
        {
            _isError = true;
            _message = "Sign in to create a training session.";
            _authChecked = true;
            return;
        }
        // Coord/Admin of THIS org. Same gate TrainingSessionService
        // .CreateAsync re-applies server-side.
        _canSubmit = await OrgAuth.IsOrgAdminAsync(_userId, OrgId) || await OrgAuth.IsMinistryDirectorAsync(_userId, OrgId);
        if (!_canSubmit)
        {
            _isError = true;
            _message = "Only admins or Ministry Directors of this organization can create training sessions.";
            _authChecked = true;
            return;
        }
        // Linked-content dropdown: only show the org's own catalog.
        // ITrainingService.ListOrgTrainingAsync enforces the per-org
        // scope server-side; we get a flat list to render in the
        // <select> without N+1.
        _orgTraining = (await TrainingService.ListOrgTrainingAsync(OrgId))
            .Select(c => new ContentOption { Id = c.Id, Title = c.Title })
            .ToList();
        _authChecked = true;
    }

    private void OnStartChanged(ChangeEventArgs e) =>
        _model.StartLocal = e.Value?.ToString() ?? "";
    private void OnEndChanged(ChangeEventArgs e) =>
        _model.EndLocal = e.Value?.ToString() ?? "";

    private async Task Save()
    {
        if (!_canSubmit)
        {
            _isError = true;
            _message = "You don't have permission to do that.";
            return;
        }
        // Parse the datetime-local strings (yyyy-MM-ddTHH:mm) to DateTime
        // with Kind=Local, then convert to UTC. Same heuristic every other
        // create form on this app uses: the user typed wall-clock time that
        // matches the server's local timezone.
        if (!DateTime.TryParse(_model.StartLocal, out var startLocal))
        {
            _isError = true;
            _message = "Start date/time is invalid.";
            return;
        }
        if (!DateTime.TryParse(_model.EndLocal, out var endLocal))
        {
            _isError = true;
            _message = "End date/time is invalid.";
            return;
        }
        var startUtc = startLocal.ToUniversalTime();
        var endUtc = endLocal.ToUniversalTime();
        int? contentId = string.IsNullOrEmpty(_model.TrainingContentId) ? null : int.Parse(_model.TrainingContentId);

        var result = await SessionService.CreateAsync(
            organizationId: OrgId,
            title: _model.Title,
            description: string.IsNullOrWhiteSpace(_model.Description) ? null : _model.Description,
            location: _model.Location,
            startUtc: startUtc,
            endUtc: endUtc,
            maxAttendees: _model.MaxAttendees,
            trainingContentId: contentId,
            callerUserId: _userId);

        switch (result)
        {
            case TrainingSessionMutationResult.Succeeded:
                // Reload to get the assigned id; in practice the service
                // already persisted it but the method signature doesn't
                // return the new id. The simplest round-trip: re-list the
                // upcoming sessions and pick the most recently-created
                // one. Acceptable for the rare case where two admins
                // race-create (they'd land on their own new row anyway).
                var upcoming = await SessionService.ListUpcomingAsync(OrgId);
                var newest = upcoming.OrderByDescending(s => s.Id).FirstOrDefault();
                if (newest is not null)
                {
                    Nav.NavigateTo($"Organizations/{OrgId}/Training/Sessions/{newest.Id}");
                }
                else
                {
                    Nav.NavigateTo($"Organizations/{OrgId}/Training/Sessions");
                }
                break;
            case TrainingSessionMutationResult.ValidationFailed:
                _isError = true;
                _message = "Please check the inputs: title and location are required, end must be after start, max attendees must be positive.";
                break;
            case TrainingSessionMutationResult.PermissionDenied:
                _isError = true;
                _message = "You don't have permission to do that.";
                break;
            case TrainingSessionMutationResult.NotFound:
                // Cross-org linked training content: the dropdown only
                // lists THIS org's content, so this branch is effectively
                // unreachable in normal use, but a stale token or a
                // concurrent deletion would land here. Surface a
                // generic failure rather than failing silently.
                _isError = true;
                _message = "The linked training content was not found. Please refresh and try again.";
                break;
        }
    }

    private class ContentOption
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
    }

    private class SessionModel
    {
        [Required, StringLength(200)] public string Title { get; set; } = "";
        [StringLength(2000)] public string? Description { get; set; }
        [Required, StringLength(200)] public string Location { get; set; } = "";
        // String properties for datetime-local inputs — avoids Blazor
        // InteractiveServer binding issues with DateTime + @bind:format
        // (the format string only affects display, not parsing; browser
        // values fail BindConverter.TryConvertTo<DateTime> silently).
        public string StartLocal { get; set; } = DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm");
        public string EndLocal { get; set; } = DateTime.Now.AddDays(7).AddHours(1).ToString("yyyy-MM-ddTHH:mm");
        public int? MaxAttendees { get; set; }
        public string? TrainingContentId { get; set; }
    }
}
