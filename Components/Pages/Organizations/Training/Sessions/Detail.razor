@page "/Organizations/{OrgId:int}/Training/Sessions/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_session?.Title ?? "Training session")</PageTitle>

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else
{
    @* Bootstrap breadcrumb. 5-tier scope drill-in: Home >
       Organizations > (this org) > In-person training sessions >
       (this session title). The active item carries the session
       title as its label so a coord deep-linking from a CSV or
       Slack message lands on a page whose breadcrumb shows them
       exactly where they are in the org tree. The breadcrumb
       uses the page-state _orgName rather than _session's
       Organization nav so it renders even when _session is null
       (the Not Found path). *@
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="">Home</a></li>
            <li class="breadcrumb-item"><a href="Organizations">Organizations</a></li>
            <li class="breadcrumb-item"><a href="@($"Organizations/{OrgId}")">@_orgName</a></li>
            <li class="breadcrumb-item"><a href="@($"Organizations/{OrgId}/Training/Sessions")">In-person training sessions</a></li>
            <li class="breadcrumb-item active" aria-current="page">@(_session?.Title ?? $"Session #{Id}")</li>
        </ol>
    </nav>
}
@if (_loading)
{
    <p><em>Loading…</em></p>
}
else if (_session is null)
{
    <div class="alert alert-warning mt-3">
        <h4>Session not found</h4>
        <p>No training session matches id <code>@Id</code>.</p>
        <a href="@($"Organizations/{OrgId}/Training/Sessions")">Back to sessions</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-0">@_session.Title</h1>
            @if (!string.IsNullOrEmpty(_session.Description))
            {
                <div class="text-muted">@_session.Description</div>
            }
            <div class="text-muted small mt-1">
                <span class="bi bi-geo-alt" aria-hidden="true"></span> @_session.Location
            </div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge @StatusClass(_session.Status) fs-6">@_session.Status</span>
            @if (_canManage && _session.Status == TrainingSessionStatus.Scheduled)
            {
                <a class="btn btn-outline-secondary" href="@($"Organizations/{OrgId}/Training/Sessions/{Id}/Edit")">Edit</a>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="text-muted small">Start</div>
                    <div><LocalTime Utc="@_session.StartUtc" /></div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted small">End</div>
                    <div><LocalTime Utc="@_session.EndUtc" /></div>
                </div>
            </div>
            @if (_session.MaxAttendees.HasValue)
            {
                <div class="mt-2">
                    <span class="text-muted small">Capacity:</span>
                    <span class="ms-1">@_session.Attendees.Count / @_session.MaxAttendees</span>
                </div>
            }
            @if (_session.TrainingContent is not null)
            {
                <div class="mt-2">
                    <span class="text-muted small">Linked training:</span>
                    <a class="ms-1" href="@($"Training/{_session.TrainingContent.Id}")">@_session.TrainingContent.Title</a>
                </div>
            }
        </div>
    </div>

    @* Self-service sign-up/cancel for any org member (volunteer + coord/admin).
       The SignUpAsync service applies the org-membership gate; we just
       surface a friendly button + a status text. The button copy flips
       between "Sign up" and "Cancel my sign-up" depending on whether
       the current user is already on the roster. *@
    @if (_session.Status == TrainingSessionStatus.Scheduled)
    {
        <div class="card mb-3">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    @if (_isSignedUp)
                    {
                        <span class="text-success"><span class="bi bi-check-circle-fill me-1"></span>You're signed up for this session.</span>
                    }
                    else if (_signUpDeniedReason is not null)
                    {
                        <span class="text-muted small">@_signUpDeniedReason</span>
                    }
                    else
                    {
                        <span class="text-muted">Sign up to attend this training session.</span>
                    }
                </div>
                <div>
                    @if (_isSignedUp)
                    {
                        <button class="btn btn-outline-danger" @onclick="CancelMySignUp" disabled="@_busySignUp">
                            @(_busySignUp ? "Cancelling…" : "Cancel my sign-up")
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="SignUp" disabled="@(_busySignUp || _signUpDeniedReason is not null)">
                            @(_busySignUp ? "Signing up…" : "Sign up")
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @* Coord/Admin mark UI. The roster carries per-row Attended selects
       + a SESSION-SHARED notes textarea at the top. The shared notes
       are the marker-shared audit-trail reason across all per-row
       single marks (per-row single marks now go through the new
       ITrainingSessionService.SetAttendedAsync, which writes the
       marker's actual notes — replacing the round-1 synthetic
       "Per-row mark from session detail page" placeholder). The
       bulk-mark path still uses its own textarea + the bulk
       MarkAttendeesCompleteAsync service method. The marker chooses
       one path or the other per save. *@
    <h5>Roster (@_session.Attendees.Count attendee@(_session.Attendees.Count == 1 ? "" : "s"))</h5>
    @if (!_session.Attendees.Any())
    {
        <div class="alert alert-info">No one has signed up yet.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Volunteer</th>
                        <th>Signed up</th>
                        @if (_canManage)
                        {
                            <th>Attended</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _session.Attendees)
                    {
                        <tr>
                            <td><a href="@($"People/{a.PersonUserId}")">@PersonName(a.PersonUserId)</a></td>
                            <td><LocalTime Utc="@a.SignedUpUtc" Format="yyyy-MM-dd HH:mm" /></td>
                            @if (_canManage)
                            {
                                <td>
                                    @* Tri-state select: null = "not marked yet",
                                       true = attended, false = no-show. The
                                       SetAttendedAsync service upserts the
                                       Attended flag in place; the on-blur
                                       handler saves immediately so a no-show
                                       recorded on a phone doesn't get lost
                                       on refresh. The shared _sharedNotes
                                       (above) is the marker-shared audit
                                       reason — required when attended=true
                                       AND the session has linked training
                                       content. *@
                                    <select class="form-select form-select-sm" style="width: auto"
                                            @bind="_attendedMap[a.PersonUserId]"
                                            @bind:after="() => PersistAttended(a.PersonUserId)">
                                        <option value="">— not marked —</option>
                                        <option value="true">Attended</option>
                                        <option value="false">No-show</option>
                                    </select>
                                </td>
                            }
                            else
                            {
                                <td>
                                    @if (a.Attended == true)
                                    {
                                        <span class="badge bg-success">Attended</span>
                                    }
                                    else if (a.Attended == false)
                                    {
                                        <span class="badge bg-secondary">No-show</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_markError is not null)
    {
        // Inline alert for per-row single-mark failures (e.g. the
        // marker picked Attended but left the shared notes blank
        // when the session has linked training content). The
        // risk the FR-2.3 designer flagged: the per-row select
        // fires on @bind:after with no explicit "save" button, so
        // a silent discard is the worst outcome. The alert makes
        // the validation visible without forcing the marker to
        // re-issue the mark.
        <div class="alert alert-warning py-2 small mb-3">@_markError</div>
    }

    @* Coord/Admin bulk mark. The notes textarea is REQUIRED (decision Q5
       in PLAN.md) — the per-row single-mark path through SetAttendedAsync
       also enforces it via the shared notes field above. The button is
       only enabled when there's at least one attendee with a non-empty
       Attended mark (the service refuses empty rosters with NoAttendees). *@
    @if (_canManage)
    {
        <div class="card mt-3">
            <div class="card-header"><h5 class="mb-0">Per-row single mark</h5></div>
            <div class="card-body">
                <p class="text-muted small mb-2">
                    Type a shared note once (e.g. <em>"Walked through the safety checklist at the door."</em>),
                    then change the per-row <em>Attended</em> dropdown above. Each change saves immediately and
                    the note is captured verbatim in the audit trail. Notes are required when the session
                    has linked training content and you mark someone as Attended — otherwise the per-row
                    change is refused so the audit trail stays consistent.
                </p>
                <div class="form-floating mb-2">
                    <InputTextArea id="shared-notes" class="form-control" style="height: 5rem" @bind-Value="_sharedNotes"
                                    aria-describedby="per-row-shared-notes-hint" />
                    <label for="shared-notes">Shared marker notes (required for Attended+linked training)</label>
                </div>
                <div class="d-flex align-items-start gap-3 flex-wrap mb-2">
                    <p id="per-row-shared-notes-hint" class="text-info small mb-0 flex-grow-1">
                        The shared note is reused for every per-row mark you make — use the button to clear the note before starting a new audit-trail reason.
                    </p>
                    <button type="button" class="btn btn-outline-secondary btn-sm flex-shrink-0"
                            @onclick="() => _sharedNotes = string.Empty"
                            disabled="@string.IsNullOrEmpty(_sharedNotes)">
                        Clear notes
                    </button>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header"><h5 class="mb-0">Bulk mark</h5></div>
            <div class="card-body">
                <p class="text-muted small mb-2">
                    Alternative to per-row: set the per-row <em>Attended</em> dropdown above, then add a
                    separate note for the bulk mark. Bulk mark flips the session status to Completed and
                    writes completion rows for every marked-Attended volunteer in one call.
                </p>
                <div class="form-floating mb-2">
                    <InputTextArea id="bulk-notes" class="form-control" style="height: 5rem" @bind-Value="_bulkNotes" />
                    <label for="bulk-notes">Bulk marker notes (required)</label>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <button class="btn btn-primary" @onclick="BulkMark" disabled="@(!CanBulkMark)">
                        @(_busyBulk ? "Saving…" : "Mark all attended and save")
                    </button>
                    @if (!CanBulkMark)
                    {
                        <span class="text-muted small">@BulkMarkDisabledReason</span>
                    }
                </div>
                @if (_bulkResult is not null)
                {
                    var r = _bulkResult.Value;
                    <div class="alert @(r.success ? "alert-success" : "alert-danger") py-2 small mt-2 mb-0">
                        @r.message
                    </div>
                }
            </div>
        </div>

        @* Walk-in add. Routes through SetAttendedAsync now (per the
           round-FR-2.3 polish) — the new service method auto-adds
           the volunteer to the roster in the same call, so the
           marker doesn't have to do a two-step "add then mark"
           flow. The walk-in note is required (matches the bulk
           path's notes-required policy). *@
        <div class="card mt-3">
            <div class="card-header"><h5 class="mb-0">Add walk-in attendee</h5></div>
            <div class="card-body">
                <p class="text-muted small mb-2">
                    For volunteers who showed up after the original roster was finalized.
                    Pick a member of this organization who isn't on the roster above.
                </p>
                <div class="d-flex gap-2 align-items-end">
                    <div class="flex-grow-1">
                        <select class="form-select" @bind="_walkInUserId">
                            <option value="">— pick an org member —</option>
                            @foreach (var m in _nonAttendeeOrgMembers)
                            {
                                <option value="@m.UserId">@m.DisplayName</option>
                            }
                        </select>
                    </div>
                    <div class="form-floating flex-grow-1">
                        <InputText class="form-control" @bind-Value="_walkInNote" placeholder="Walk-in note" />
                        <label>Note (required)</label>
                    </div>
                    <button class="btn btn-outline-primary" @onclick="AddWalkIn" disabled="@(!CanAddWalkIn)">
                        @(_busyWalkIn ? "Adding…" : "Add as attended")
                    </button>
                </div>
            </div>
        </div>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITrainingSessionService SessionService
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject NavigationManager Nav
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int Id { get; set; }
    private TrainingSession? _session;
    // Org-name cache for the breadcrumb. The breadcrumb renders
    // before _session is loaded (the loading + NotFound branches
    // both need it), so we fetch it first in OnInitializedAsync
    // independent of the session fetch. Fallback to "Org #{OrgId}"
    // when the org is missing so the breadcrumb still renders an
    // informative label rather than going blank.
    private string _orgName = "";
    private bool _loading = true;
    private bool _canManage;
    private bool _isSignedUp;
    private string? _signUpDeniedReason;
    private bool _busySignUp;
    private bool _busyBulk;
    private bool _busyWalkIn;
    // Shared notes field at the top of the roster — drives the
    // per-row SetAttendedAsync call. Required when the marker picks
    // Attended AND the session has linked training content (decision
    // Q5 carries over from the bulk path; the per-row single mark
    // service enforces it). When the session has no linked content,
    // notes are not consulted.
    private string _sharedNotes = "";
    private string _bulkNotes = "";
    private string _walkInUserId = "";
    private string _walkInNote = "";
    private string _userId = "";
    // Per-attendee attended tri-state map. Keyed by PersonUserId so
    // the bulk-mark loop + the per-row single PersistAttended both
    // pull from the same in-memory state.
    private Dictionary<string, string> _attendedMap = new();
    // Org members not on the attendee roster — candidates for the
    // walk-in add picker.
    private List<Person> _nonAttendeeOrgMembers = new();
    // Last bulk-mark outcome, surfaced in the inline alert.
    private (bool success, string message)? _bulkResult;
    // Last per-row single-mark error (e.g. notes required when
    // session has linked training). Cleared on the next successful
    // per-row mark OR on Reload.
    private string? _markError;

    private bool CanBulkMark =>
        !_busyBulk
        && !string.IsNullOrWhiteSpace(_bulkNotes)
        && _session?.Attendees.Any() == true
        && _attendedMap.Values.Any(v => v == "true" || v == "false");

    private string BulkMarkDisabledReason
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_bulkNotes)) return "Notes are required.";
            if (_session?.Attendees.Any() != true) return "No attendees yet.";
            if (!_attendedMap.Values.Any(v => v == "true" || v == "false")) return "Mark at least one row as attended or no-show.";
            return "";
        }
    }

    private bool CanAddWalkIn =>
        !_busyWalkIn
        && !string.IsNullOrEmpty(_walkInUserId)
        && !string.IsNullOrWhiteSpace(_walkInNote);

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        // Fetch the org name FIRST so the breadcrumb always has a
        // sensible label regardless of auth outcome. Independent of
        // _canManage and _session — the loading + permission-denied
        // + not-found branches all need the org-name for navigation.
        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            _orgName = await db.Organizations
                .Where(o => o.Id == OrgId)
                .Select(o => o.Name)
                .FirstOrDefaultAsync() ?? $"Org #{OrgId}";
        }
        if (string.IsNullOrEmpty(_userId))
        {
            _loading = false;
            return;
        }
        _canManage = await OrgAuth.IsOrgAdminAsync(_userId, OrgId) || await OrgAuth.IsMinistryDirectorAsync(_userId, OrgId);
        await Reload();
        _loading = false;
    }

    private async Task Reload()
    {
        _session = await SessionService.GetAsync(Id);
        if (_session is null || _session.OrganizationId != OrgId) return;
        _isSignedUp = _session.Attendees.Any(a => a.PersonUserId == _userId);
        // Re-seed the tri-state map. Values:
        //   "" = null Attended, "true" = attended, "false" = no-show.
        _attendedMap = _session.Attendees.ToDictionary(
            a => a.PersonUserId,
            a => a.Attended switch
            {
                true => "true",
                false => "false",
                _ => "",
            });
        _markError = null;
        await ReloadNonAttendeePicker();
    }

    private async Task ReloadNonAttendeePicker()
    {
        if (_session is null) return;
        await using var db = await DbFactory.CreateDbContextAsync();
        // Org members EXCLUDING the current attendees — the walk-in
        // picker only shows people who AREN'T on the roster yet.
        var attendeeIds = _session.Attendees.Select(a => a.PersonUserId).ToHashSet();
        _nonAttendeeOrgMembers = await db.OrganizationMemberships
            .Where(m => m.OrganizationId == OrgId && !attendeeIds.Contains(m.PersonUserId))
            .Select(m => m.Person)
            .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
            .AsNoTracking()
            .ToListAsync();
    }

    // Roster name lookup. Round-FR-2.3 polish-3 follow-up (iii):
    // GetAsync now eager-loads Person on Attendees
    // (.ThenInclude(a => a.Person)), so this is a pure in-memory
    // dictionary lookup — no DB hit, no per-page cache, no sync
    // CreateDbContext. The pre-polish N+1 (one People query per
    // distinct attendee across the page lifetime) is gone.
    private string PersonName(string userId)
    {
        if (_session is null) return userId;
        var attendee = _session.Attendees.FirstOrDefault(a => a.PersonUserId == userId);
        return attendee?.Person?.DisplayName ?? userId;
    }

    private async Task SignUp()
    {
        if (_session is null) return;
        _busySignUp = true;
        try
        {
            var result = await SessionService.SignUpAsync(Id, _userId, _userId);
            switch (result)
            {
                case TrainingSessionSignupResult.SignedUp:
                    _isSignedUp = true;
                    await Reload();
                    break;
                case TrainingSessionSignupResult.SessionFull:
                    _signUpDeniedReason = "This session is at capacity.";
                    break;
                case TrainingSessionSignupResult.SessionCancelled:
                    _signUpDeniedReason = "This session was cancelled.";
                    break;
                case TrainingSessionSignupResult.AlreadySignedUp:
                    _isSignedUp = true;
                    break;
                case TrainingSessionSignupResult.NotFound:
                    _signUpDeniedReason = "Sign-ups aren't open to your account for this session.";
                    break;
            }
        }
        finally
        {
            _busySignUp = false;
        }
    }

    private async Task CancelMySignUp()
    {
        if (_session is null) return;
        _busySignUp = true;
        try
        {
            var result = await SessionService.CancelSignUpAsync(Id, _userId, _userId);
            switch (result)
            {
                case TrainingSessionSignupResult.Cancelled:
                    _isSignedUp = false;
                    await Reload();
                    break;
                case TrainingSessionSignupResult.AlreadyMarkedAttended:
                    // Spec: the marker owns the audit trail; volunteer
                    // can't self-cancel once attendance is recorded.
                    // The page would need a follow-up flow (admin
                    // mediates) — round 2.
                    break;
            }
        }
        finally
        {
            _busySignUp = false;
        }
    }

    // Per-row attended flag change. Round-FR-2.3 polish-3 follow-up
    // (i): routes through the new SetAttendedAsync service method
    // (no synthetic notes) with the marker's actual notes from
    // the shared _sharedNotes field. Saves immediately so a
    // no-show recorded on a phone survives a refresh.
    // ValidationFailed (e.g. attended=true with no notes when the
    // session has linked training) surfaces in the inline _markError
    // alert instead of silently discarding.
    private async Task PersistAttended(string personUserId)
    {
        if (_session is null) return;
        if (!_attendedMap.TryGetValue(personUserId, out var raw)) return;
        if (string.IsNullOrEmpty(raw)) return; // null = "not marked" — no-op
        var attended = raw == "true";
        var result = await SessionService.SetAttendedAsync(
            Id, _userId, personUserId, attended, _sharedNotes);
        switch (result)
        {
            case TrainingSessionMutationResult.Succeeded:
                _markError = null;
                await Reload();
                break;
            case TrainingSessionMutationResult.ValidationFailed:
                // The shared notes are blank AND the session has linked
                // training content AND the marker picked Attended=true.
                // SetAttendedAsync refuses the write; surface the hint
                // so the marker can fill in the notes and retry.
                _markError = "Marker notes are required when marking Attended on a session with linked training content.";
                break;
            case TrainingSessionMutationResult.PermissionDenied:
                _markError = "You don't have permission to mark attendance.";
                break;
            case TrainingSessionMutationResult.AlreadyCancelled:
                _markError = "This session was cancelled.";
                break;
            case TrainingSessionMutationResult.AlreadyCompleted:
                _markError = "This session is already completed.";
                break;
            case TrainingSessionMutationResult.NotFound:
                _markError = "Session or volunteer not found.";
                break;
        }
    }

    // Bulk mark. Routes through MarkAttendeesCompleteAsync (unchanged
    // from FR-2.2) — flips the session status to Completed and
    // writes completion rows for every marked-Attended volunteer in
    // one call. Per-row single marks use SetAttendedAsync; bulk
    // marks use this. Two distinct paths so the audit-trail shape
    // matches the call site (CoordinatorManual for bulk,
    // CoordinatorManualSingle for per-row).
    private async Task BulkMark()
    {
        if (_session is null) return;
        if (!CanBulkMark) return;
        _busyBulk = true;
        _bulkResult = null;
        try
        {
            var marks = _attendedMap
                .Where(kv => kv.Value == "true" || kv.Value == "false")
                .Select(kv => new AttendeeMark
                {
                    PersonUserId = kv.Key,
                    Attended = kv.Value == "true",
                })
                .ToList();
            var result = await SessionService.MarkAttendeesCompleteAsync(Id, _userId, marks, _bulkNotes);
            switch (result)
            {
                case TrainingSessionMutationResult.Succeeded:
                    _bulkResult = (true, $"Marked {marks.Count} attendee{(marks.Count == 1 ? "" : "s")}.");
                    _bulkNotes = "";
                    await Reload();
                    break;
                case TrainingSessionMutationResult.NoAttendees:
                    _bulkResult = (false, "Mark at least one row before saving.");
                    break;
                case TrainingSessionMutationResult.ValidationFailed:
                    _bulkResult = (false, "Notes are required (or the roster contains non-members).");
                    break;
                case TrainingSessionMutationResult.PermissionDenied:
                    _bulkResult = (false, "You don't have permission to mark attendance.");
                    break;
            }
        }
        finally
        {
            _busyBulk = false;
        }
    }

    // Walk-in add. Round-FR-2.3 polish-3: routes through the new
    // SetAttendedAsync service method, which auto-adds the volunteer
    // to the roster in the same call. The walk-in note is required
    // (mirrors the bulk path's notes-required policy).
    private async Task AddWalkIn()
    {
        if (_session is null || !CanAddWalkIn) return;
        _busyWalkIn = true;
        try
        {
            var result = await SessionService.SetAttendedAsync(
                Id, _userId, _walkInUserId, attended: true, notes: _walkInNote);
            if (result == TrainingSessionMutationResult.Succeeded)
            {
                _walkInUserId = "";
                _walkInNote = "";
                await Reload();
            }
        }
        finally
        {
            _busyWalkIn = false;
        }
    }

    private static string StatusClass(TrainingSessionStatus status) => status switch
    {
        TrainingSessionStatus.Scheduled => "bg-primary",
        TrainingSessionStatus.Completed => "bg-success",
        TrainingSessionStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary",
    };
}
