@* OrgTrainingEditor — manages TrainingRequirement rows scoped to one organization. *@
@attribute [Authorize]

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Warning" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
        </MudAlert>
    }
    @if (!_content.Any())
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No training content available yet — add some under <MudLink Href="Training">Training</MudLink> first.</MudText>
    }
    else
    {
        @* No FormName="…" Context="…" on purpose: this EditForm is
           mounted conditionally inside an @if(_content.Any()) branch
           of the parent page. Blazor's enhanced-form handling treats
           any <EditForm FormName="X"> as static-form-SSR-capable;
           mounting it mid-render into an already-interactive circuit
           triggers the SignalR-drop regression captured in
           STATUS.md → Known quirks. The conditional branch above
           (the "no content" message) is the alternative when the
           dropdown has nothing to show. Keep this comment if you
           ever add a FormName back. *@
        <EditForm Model="_addModel" OnValidSubmit="AddRequirement">
            <MudGrid Spacing="2" Class="align-items-center mb-2">
                <MudItem xs="12" sm="4">
                    <MudSelect T="int"
                               @bind-Value="_addModel.TrainingContentId"
                               @bind-Value:after="ClearError"
                               Label="Training"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem T="int" Value="0">— pick training —</MudSelectItem>
                        @foreach (var c in _content)
                        {
                            <MudSelectItem T="int" Value="@c.Id">@c.Title (@c.Format v@c.Version)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="TrainingCadence"
                               @bind-Value="_addModel.Cadence"
                               Label="Cadence"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        <MudSelectItem T="TrainingCadence" Value="TrainingCadence.Yearly">Yearly</MudSelectItem>
                        <MudSelectItem T="TrainingCadence" Value="TrainingCadence.OneTime">One-time</MudSelectItem>
                        <MudSelectItem T="TrainingCadence" Value="TrainingCadence.EveryMonths">Every N months…</MudSelectItem>
                    </MudSelect>
                </MudItem>
                @if (_addModel.Cadence == TrainingCadence.EveryMonths)
                {
                    <MudItem xs="6" sm="2">
                        <MudNumericField T="int"
                                         @bind-Value="_addModel.CadenceMonths"
                                         Label="Months"
                                         Min="1"
                                         Max="60"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense" />
                    </MudItem>
                }
                <MudItem xs="12" sm="3" Class="d-flex align-end">
                    <MudButton ButtonType="ButtonType.Submit"
                               Color="Color.Primary"
                               Variant="Variant.Filled">Required</MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    }

    <MudText Typo="Typo.h6" Class="mt-4">Currently required</MudText>
    @if (!_requirements.Any())
    {
        <MudAlert Severity="Severity.Normal" Dense="true">No org-wide training required yet.</MudAlert>
    }
    else
    {
        <MudList T="ReqRow" Dense="true">
            @foreach (var r in _requirements)
            {
                <MudListItem T="ReqRow">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudLink Href="@LinkBuilder.TrainingEditHref(r.TrainingContentId)">@r.Title</MudLink>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ms-2">@r.Cadence</MudChip>
                        </div>
                        <MudButton Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small"
                                   OnClick="@(() => Remove(r.Id))">Remove</MudButton>
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITrainingService TrainingService
@code {
    [Parameter, EditorRequired] public int OrganizationId { get; set; }

    private bool _loading = true;
    private List<TrainingContent> _content = new();
    private List<ReqRow> _requirements = new();
    // Per-org guard UX: if a stale dropdown id submits a content row that
    // no longer belongs to this org (deleted / reassigned since the
    // dropdown was loaded), surface a friendly message instead of
    // silently bailing. Auto-cleared on the next dropdown change or on a
    // successful save; can also be dismissed manually.
    private string? _errorMessage;

    private void ClearError() => _errorMessage = null;
    // [SupplyParameterFromForm] — see Organizations/Edit.razor for rationale.
    [SupplyParameterFromForm] private AddModel _addModel { get; set; } = new();

    protected override async Task OnParametersSetAsync()
    {
        await Reload();
        _loading = false;
    }

    private async Task Reload()
    {
        // Per-org scoping (round N): the content dropdown only shows training
        // owned by THIS organization. Without this filter, an Admin of org A
        // could attach a requirement pointing at training belonging to org B,
        // silently cross-pollinating the catalogs.
        _content = await TrainingService.ListOrgTrainingAsync(OrganizationId);

        await using var db = await DbFactory.CreateDbContextAsync();
        _requirements = await db.TrainingRequirements
            .Include(r => r.TrainingContent)
            .Where(r => r.OrganizationId == OrganizationId)
            .Select(r => new ReqRow
            {
                Id = r.Id,
                TrainingContentId = r.TrainingContentId,
                Title = r.TrainingContent.Title,
                Cadence = r.Cadence,
            })
            .ToListAsync();
    }

    private async Task AddRequirement()
    {
        if (_addModel.TrainingContentId == 0) return;
        await using var db = await DbFactory.CreateDbContextAsync();

        // Per-org scoping guard (round N): the dropdown only shows
        // training owned by THIS org (via ListOrgTrainingAsync), but a
        // stale id (someone deleted/reassigned the content between load
        // and submit) or a hostile POST body could still submit a
        // foreign TrainingContentId. Re-verify the org membership before
        // the insert so a requirement never lands pointing at a
        // different org's training. Defensive; echoes the same gate the
        // service applies on RecordCompletion.
        var contentOrgId = await db.TrainingContents
            .Where(c => c.Id == _addModel.TrainingContentId)
            .Select(c => (int?)c.OrganizationId)
            .FirstOrDefaultAsync();
        if (contentOrgId != OrganizationId)
        {
            // Content was deleted or now belongs to another org. Tell
            // the user and refresh the dropdown so the corrected list
            // is visible — silent bail would be confusing.
            _errorMessage = "That training isn't part of this organization anymore. Please pick from the refreshed list.";
            _addModel = new();
            await Reload();
            return;
        }

        db.TrainingRequirements.Add(new TrainingRequirement
        {
            OrganizationId = OrganizationId,
            TrainingContentId = _addModel.TrainingContentId,
            Cadence = _addModel.Cadence,
            CadenceMonths = _addModel.Cadence == TrainingCadence.EveryMonths ? _addModel.CadenceMonths : null,
        });
        await db.SaveChangesAsync();
        _addModel = new();
        _errorMessage = null;
        await Reload();
    }

    private async Task Remove(int id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var req = await db.TrainingRequirements.FindAsync(id);
        if (req is not null)
        {
            db.TrainingRequirements.Remove(req);
            await db.SaveChangesAsync();
        }
        await Reload();
    }

    private class AddModel
    {
        public int TrainingContentId { get; set; }
        public TrainingCadence Cadence { get; set; } = TrainingCadence.Yearly;
        public int CadenceMonths { get; set; } = 12;
    }

    private class ReqRow
    {
        public int Id { get; set; }
        public int TrainingContentId { get; set; }
        public string Title { get; set; } = "";
        public TrainingCadence Cadence { get; set; }
    }
}
