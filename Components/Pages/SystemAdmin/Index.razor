@page "/SystemAdmin"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>System administrators</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (_loading)
{
    <MudText><em>Loading…</em></MudText>
}
else if (!_canView)
{
    <MudAlert Severity="Severity.Error">
        <strong>Access denied.</strong> Only SystemAdmins can view this page.
    </MudAlert>
}
else
{
    <MudText Typo="Typo.h4">System administrators</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary">Round-BC: grant or revoke the SystemAdmin role. Every attempt is logged on the audit log below.</MudText>

    <StatusMessage Message="@_message" IsError="@_isError" />

    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" md="6">
            <MudCard Outlined="true" Class="shadow-sm">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Current SystemAdmins (@_admins.Count)</MudText>
                </MudCardHeader>
                <MudList T="SystemAdminRow" Dense="true">
                    @if (_admins.Count == 0)
                    {
                        <MudListItem>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">Nobody holds the SystemAdmin role.</MudText>
                        </MudListItem>
                    }
                    else
                    {
                        @foreach (var a in _admins)
                        {
                            <MudListItem>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <div>
                                        <strong>@a.DisplayName</strong>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@a.Email · granted @FormatTimestamp(a.GrantedUtc)</MudText>
                                    </div>
                                    @* Cannot revoke self — disabled button when this row IS the caller. The
                                       page-markup guard mirrors the service's SelfRevokeRefused result so the
                                       click never even leaves the page in the self-revoke attempt. *@
                                    @if (a.UserId == _userId)
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small" Disabled="true"
                                                   title="You can't revoke yourself — ask another SystemAdmin to revoke you.">Revoke (self)</MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" OnClick="() => RevokeAsync(a.UserId)" Disabled="@_busy">Revoke</MudButton>
                                    }
                                </MudStack>
                            </MudListItem>
                        }
                    }
                </MudList>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudCard Outlined="true" Class="shadow-sm">
                <MudCardHeader>
                    <MudText Typo="Typo.h6">Grant SystemAdmin to a user</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">Enter the user's email — we'll look up their Identity row and grant the role.</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                        <MudTextField T="string" @bind-Value="_grantEmail" Placeholder="user@example.com" Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GrantByEmailAsync" Disabled="@(_busy || string.IsNullOrWhiteSpace(_grantEmail))">Grant</MudButton>
                    </MudStack>
                    @if (_grantTarget is not null)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-2">Resolved: <strong>@_grantTarget.DisplayName</strong> (@_grantTarget.UserId)</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h5">Recent audit log</MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary">Last @_audits.Count grant/revoke attempts across all SystemAdmin actors. Newest first.</MudText>
    <MudSimpleTable Hover="true" Dense="true" Bordered="false">
        <thead>
            <tr>
                <th>When (UTC)</th>
                <th>Actor</th>
                <th>Action</th>
                <th>Target</th>
                <th>Result</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in _audits)
            {
                <tr class="@((a.Success ? "" : "mud-table-row-warning"))">
                    <td><LocalTime Utc="@a.TimestampUtc" Format="yyyy-MM-dd HH:mm:ss" /></td>
                    <td>@a.ActorDisplayName</td>
                    <td>@(a.Action == SystemAdminAuditAction.Grant ? "Grant" : "Revoke")</td>
                    <td>@a.TargetDisplayName</td>
                    <td>@(a.Success ? "OK" : "Refused")</td>
                    <td>@a.Reason</td>
                </tr>
            }
            @if (_audits.Count == 0)
            {
                <tr>
                    <td colspan="6">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary text-center">No audit rows yet — make a grant / revoke to populate this list.</MudText>
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject ISystemAdminManagementService SysAdmin
@inject UserManager<IdentityUser> UserManager
@code {
    private bool _loading = true;
    private bool _canView;
    private bool _busy;
    private string? _message;
    private bool _isError;
    private string _userId = "";
    private List<SystemAdminRow> _admins = new();
    private List<SystemAdminAuditRow> _audits = new();
    private string _grantEmail = "";
    private SystemAdminRow? _grantTarget;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled).
    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem("Home", href: LinkBuilder.HomeHref()),
        new BreadcrumbItem("System admin", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        // Page-level gate mirror: IsSystemAdminAsync is the same check
        // the service uses; we render a friendly 403 panel if it fails.
        // The page is still @attribute [Authorize] so an anonymous user
        // is blocked by Blazor's authorize filter before this code runs.
        _canView = !string.IsNullOrEmpty(_userId) && await OrgAuth.IsSystemAdminAsync(_userId);
        if (!_canView)
        {
            _loading = false;
            return;
        }
        await ReloadAsync();
        _loading = false;
    }

    private async Task ReloadAsync()
    {
        _admins = (await SysAdmin.ListAsync()).ToList();
        _audits = (await SysAdmin.ListRecentAuditsAsync()).ToList();
    }

    private async Task ResolveGrantTargetAsync()
    {
        if (string.IsNullOrWhiteSpace(_grantEmail))
        {
            _grantTarget = null;
            return;
        }
        var user = await UserManager.FindByEmailAsync(_grantEmail);
        if (user is null)
        {
            _grantTarget = null;
            return;
        }
        // Display-name resolution matches SysAdmin.ListAsync style for consistency.
        await using var db = await DbFactory.CreateDbContextAsync();
        var person = await db.People.FirstOrDefaultAsync(p => p.UserId == user.Id);
        _grantTarget = new SystemAdminRow
        {
            UserId = user.Id,
            Email = user.Email ?? _grantEmail,
            DisplayName = person is null
                ? (user.Email ?? user.Id)
                : $"{person.FirstName} {person.LastName}".Trim(),
        };
    }

    private async Task GrantByEmailAsync()
    {
        if (string.IsNullOrWhiteSpace(_grantEmail)) return;
        _busy = true;
        _message = null;
        try
        {
            await ResolveGrantTargetAsync();
            if (_grantTarget is null)
            {
                _isError = true;
                _message = $"No Identity user with email '{_grantEmail}'.";
                return;
            }
            var result = await SysAdmin.GrantAsync(_userId, _grantTarget.UserId);
            switch (result)
            {
                case SystemAdminGrantResult.Success:
                    _isError = false;
                    _message = $"Granted SystemAdmin to {_grantTarget.DisplayName}.";
                    _grantEmail = "";
                    _grantTarget = null;
                    break;
                case SystemAdminGrantResult.AlreadyHasRole:
                    _isError = true;
                    _message = $"{_grantTarget.DisplayName} already has SystemAdmin.";
                    break;
                case SystemAdminGrantResult.TargetUserNotFound:
                    _isError = true;
                    _message = $"No Identity user found for '{_grantEmail}'.";
                    break;
                case SystemAdminGrantResult.PermissionDenied:
                default:
                    _isError = true;
                    _message = "Permission denied.";
                    break;
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RevokeAsync(string targetUserId)
    {
        _busy = true;
        _message = null;
        try
        {
            var result = await SysAdmin.RevokeAsync(_userId, targetUserId);
            switch (result)
            {
                case SystemAdminRevokeResult.Success:
                    _isError = false;
                    _message = "SystemAdmin revoked.";
                    break;
                case SystemAdminRevokeResult.DoesNotHaveRole:
                    _isError = true;
                    _message = "That user didn't have SystemAdmin.";
                    break;
                case SystemAdminRevokeResult.SelfRevokeRefused:
                    _isError = true;
                    _message = "You can't revoke your own SystemAdmin role.";
                    break;
                case SystemAdminRevokeResult.TargetUserNotFound:
                    _isError = true;
                    _message = "User not found.";
                    break;
                case SystemAdminRevokeResult.PermissionDenied:
                default:
                    _isError = true;
                    _message = "Permission denied.";
                    break;
            }
            await ReloadAsync();
        }
        finally
        {
            _busy = false;
        }
    }

    private static string FormatTimestamp(DateTime utc)
    {
        if (utc == DateTime.MinValue) return "—";
        return utc.ToString("yyyy-MM-dd HH:mm") + " UTC";
    }
}
