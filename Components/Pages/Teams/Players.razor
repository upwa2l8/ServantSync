@page "/Teams/{TeamId:int}/Players/{PlayerId:int}/Edit"
@page "/Teams/{TeamId:int}/Players/New"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New player" : "Edit player")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-2 gradient-text">@(_isNew ? "New player" : "Edit player")</MudText>
<StatusMessage Message="@_message" IsError="@_isError" />

@if (_team is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
        On <MudLink Href="@LinkBuilder.TeamHref(TeamId)">@_team.Name</MudLink> · <MudLink Href="@LinkBuilder.LeagueHref(_team.MinistryId)">@_team.Ministry?.Name</MudLink>
    </MudText>

    <EditForm Model="_model" OnValidSubmit="Save" FormName="player">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <MudGrid Spacing="2" Class="mb-2">
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="First name"
                              @bind-Value="_model.FirstName"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              RequiredError="First name is required" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudTextField T="string"
                              Label="Last name"
                              @bind-Value="_model.LastName"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Required="true"
                              RequiredError="Last name is required" />
            </MudItem>
            <MudItem xs="6" md="2">
                <MudNumericField T="int?"
                                 Label="Jersey #"
                                 @bind-Value="_model.JerseyNumber"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" md="2">
                <MudTextField T="string"
                              Label="Position"
                              @bind-Value="_model.Position"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <MudDatePicker Label="Date of birth"
                       @bind-Date="_model.DateOfBirth"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Class="mb-3" />

        <MudText Typo="Typo.h6" Class="mt-2">Primary contact (parent/guardian)</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
            Coaches use this to call a parent if a player gets hurt. Link to a Person in the system if one exists, or just type the contact info.
        </MudText>

        <MudSelect T="string"
                   @bind-Value="_model.PrimaryContactPersonUserId"
                   Label="Linked Person (login user)"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Class="mb-3">
            <MudSelectItem T="string" Value="@("")">— none —</MudSelectItem>
            @foreach (var p in _allPeople)
            {
                <MudSelectItem T="string" Value="@p.UserId">@p.DisplayName</MudSelectItem>
            }
        </MudSelect>

        <MudGrid Spacing="2" Class="mb-2">
            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Phone"
                              @bind-Value="_model.PrimaryContactPhone"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField T="string"
                              Label="Email"
                              InputType="InputType.Email"
                              @bind-Value="_model.PrimaryContactEmail"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <MudTextField T="string"
                      Label="Notes"
                      @bind-Value="_model.Notes"
                      Lines="3"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="mb-3" />

        <MudStack Row="true" Spacing="2">
            <MudButton ButtonType="ButtonType.Submit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@(!_canSubmit)">Save</MudButton>
            <MudButton Href="@LinkBuilder.TeamHref(TeamId)"
                       Color="Color.Default"
                       Variant="Variant.Outlined">Cancel</MudButton>
        </MudStack>
    </EditForm>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITeamService TeamService
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject NavigationManager Nav
@code {
    [Parameter] public int TeamId { get; set; }
    [Parameter] public int? PlayerId { get; set; }
    private bool _isNew => PlayerId is null;
    private Team? _team;
    private List<Person> _allPeople = new();
    // EditForm requires the bound model to be a PROPERTY marked with
    // [SupplyParameterFromForm] — without it the form data is submitted
    // but never deserialized into the model, so Save gets an empty _model
    // and DataAnnotationsValidator flags FirstName/LastName as required.
    // A private field is silently ignored by the form-binding pipeline.
    // (See Components/Account/Pages/Login.razor for the same comment.)
    [SupplyParameterFromForm] private PlayerModel _model { get; set; } = new();
    private string? _message;
    private bool _isError;
    private bool _canSubmit;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the loaded team + isNew flag
    // so it stays in sync whether the user is creating or editing a player.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Leagues", href: "Leagues"),
                new BreadcrumbItem(_team?.Name ?? $"Team #{TeamId}", href: LinkBuilder.TeamHref(TeamId)),
                new BreadcrumbItem(_isNew ? "New player" : "Edit player", href: null, disabled: true),
            };
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _canSubmit = !string.IsNullOrEmpty(userId) && await OrgAuth.CanManageTeamAsync(userId, TeamId);
        if (!_canSubmit)
        {
            _isError = true;
            _message = "You don't have permission to manage this team's roster.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        _team = await db.Teams.Include(t => t.Ministry).AsNoTracking().FirstOrDefaultAsync(t => t.Id == TeamId);
        _allPeople = await db.People.OrderBy(p => p.LastName).ToListAsync();

        if (!_isNew)
        {
            var p = await db.Players.FindAsync(PlayerId!.Value);
            if (p is null)
            {
                _isError = true;
                _message = "Player not found.";
                return;
            }
            _model = new PlayerModel
            {
                FirstName = p.FirstName,
                LastName = p.LastName,
                DateOfBirth = p.DateOfBirth,
                JerseyNumber = p.JerseyNumber,
                Position = p.Position,
                PrimaryContactPersonUserId = p.PrimaryContactPersonUserId,
                PrimaryContactPhone = p.PrimaryContactPhone,
                PrimaryContactEmail = p.PrimaryContactEmail,
                Notes = p.Notes,
            };
        }
    }

    private async Task Save()
    {
        if (!_canSubmit) return;
        try
        {
            if (_isNew)
            {
                await TeamService.AddPlayerAsync(
                    TeamId, _model.FirstName, _model.LastName,
                    _model.DateOfBirth, _model.JerseyNumber, _model.Position,
                    string.IsNullOrEmpty(_model.PrimaryContactPersonUserId) ? null : _model.PrimaryContactPersonUserId,
                    _model.PrimaryContactPhone, _model.PrimaryContactEmail, _model.Notes);
            }
            else
            {
                await TeamService.UpdatePlayerAsync(
                    PlayerId!.Value, _model.FirstName, _model.LastName,
                    _model.DateOfBirth, _model.JerseyNumber, _model.Position,
                    string.IsNullOrEmpty(_model.PrimaryContactPersonUserId) ? null : _model.PrimaryContactPersonUserId,
                    _model.PrimaryContactPhone, _model.PrimaryContactEmail, _model.Notes);
            }
            Nav.NavigateTo($"Teams/{TeamId}");
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = "Save failed: " + ex.Message;
        }
    }

    private class PlayerModel
    {
        [Required, StringLength(80)] public string FirstName { get; set; } = "";
        [Required, StringLength(80)] public string LastName { get; set; } = "";
        public DateTime? DateOfBirth { get; set; }
        public int? JerseyNumber { get; set; }
        [StringLength(80)] public string? Position { get; set; }
        public string? PrimaryContactPersonUserId { get; set; }
        [StringLength(40)] public string? PrimaryContactPhone { get; set; }
        [StringLength(120), EmailAddress] public string? PrimaryContactEmail { get; set; }
        [StringLength(500)] public string? Notes { get; set; }
    }
}
