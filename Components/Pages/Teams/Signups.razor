@page "/Teams/{TeamId:int}/Signups"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Parents &middot; @(_team?.Name ?? "Team")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

@if (!_hasLoaded)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_canView)
{
    @* Round-AY: gate failure message. Coaches (Team.CoachPersonUserId
       delegates via CanManageTeamAsync) and Admins/Coordinators of the
       parent org + the ministry coordinator + slot-tier coordinators see
       this. SystemAdmin can see this page as well — strictly visibility-
       only; they cannot edit the underlying Player.PrimaryContact* fields,
       only read the rendered roster. The "missing team + missing
       permission" signal is intentionally conflated — a wrong-teamId
       guess and an unauthorized-but-correct guess both fall through to
       the "Not authorized" panel below because _canView=false in both
       cases. Privacy: don't leak cross-org existence via a "Team not
       found" panel. *@
    <MudAlert Severity="Severity.Warning" Class="mt-3">
        <MudText Typo="Typo.h6">Not authorized</MudText>
        <MudText>You don't have permission to view the parent contacts for this team.</MudText>
        <MudText Typo="Typo.caption" Class="mt-2 mb-0">
            Team coaches, ministry directors, and organization administrators
            (plus SystemAdmin platform administrators) can see the parent
            contact list. To view a specific parent's profile from your own
            team page, use the link on the team detail's roster.
        </MudText>
    </MudAlert>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <div>
            <MudText Typo="Typo.h4" Class="mb-0 gradient-text">Parents &middot; @_team!.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                @_activePlayers.Count active player@(_activePlayers.Count == 1 ? "" : "s") on the current roster.
                &middot; <MudLink Href="@LinkBuilder.TeamHref(TeamId)">Back to team</MudLink>
            </MudText>
        </div>
    </MudStack>

    @if (!_activePlayers.Any())
    {
        <MudAlert Severity="Severity.Info">
            No active players on this team's roster yet. Once a coach adds a player
            with a primary-contact link, that parent's info surfaces here.
        </MudAlert>
    }
    else
    {
        <MudPaper Outlined="true" Class="glass-card">
            <MudTable T="Player" Items="_activePlayers" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Player</MudTh>
                    <MudTh>Pos</MudTh>
                    <MudTh>Parent / guardian</MudTh>
                    <MudTh>Contact</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@(context.JerseyNumber?.ToString() ?? "—")</MudTd>
                    <MudTd>@context.DisplayName</MudTd>
                    <MudTd>@(context.Position ?? "—")</MudTd>
                    <MudTd>
                        @if (context.PrimaryContactPerson is not null)
                        {
                            <MudLink Href="@LinkBuilder.PersonHref(context.PrimaryContactPersonUserId!)">@context.PrimaryContactPerson.DisplayName</MudLink>
                        }
                        else
                        {
                            <span class="mud-text-secondary">— not linked —</span>
                        }
                    </MudTd>
                    <MudTd>
                        @if (!string.IsNullOrEmpty(context.PrimaryContactPhone))
                        {
                            <div>@context.PrimaryContactPhone</div>
                        }
                        @if (!string.IsNullOrEmpty(context.PrimaryContactEmail))
                        {
                            <div>@context.PrimaryContactEmail</div>
                        }
                        @if (string.IsNullOrEmpty(context.PrimaryContactPhone) && string.IsNullOrEmpty(context.PrimaryContactEmail))
                        {
                            <span class="mud-text-secondary">—</span>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IOrgAuthService OrgAuth
@inject ITeamService TeamService
@inject AuthenticationStateProvider Auth
@code {
    [Parameter] public int TeamId { get; set; }
    private Team? _team;
    private List<Player> _activePlayers = new();
    // Two-tier gate: IsSystemAdminAsync OR CanManageTeamAsync. Default
    // false (deny) until OnInitializedAsync resolves both checks. Both
    // branches are short-circuited for callers that don't need a Per-
    // org check (SystemAdmin skips the EF round-trip entirely).
    private bool _canView;
    // Same _hasLoaded discipline as the parallel ministries/Signups
    // and Teams/Detail patterns: distinguish "still loading" from a
    // definitive outcome (not found / not authorized / no players)
    // so navigation never shows a spinner indefinitely.
    private bool _hasLoaded;
    private string _userId = "";

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the loaded team so it stays
    // in sync with whatever team the user is viewing.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Leagues", href: "Leagues"),
                new BreadcrumbItem(_team?.Name ?? $"Team #{TeamId}", href: LinkBuilder.TeamHref(TeamId)),
                new BreadcrumbItem("Parents", href: null, disabled: true),
            };
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        await using var db = await DbFactory.CreateDbContextAsync();

        // Bare-team fetch on this DbContext (just the Ministry nav for
        // a potential future "back to league" link, which the existing
        // Detail page also uses). The cross-team defense here is
        // redundant with the gate (CanManageTeamAsync grants are
        // team-scoped), but the FirstOrDefaultAsync(t.Id == TeamId)
        // lookup keeps a wrong-teamId guess from rendering a confusing
        // "no such team" panel — wrong ids fall through to the Not
        // authorized panel above (still privacy-friendly: doesn't
        // reveal whether the team exists).
        _team = await db.Teams
            .Include(t => t.Ministry)
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.Id == TeamId);
        if (_team is null) { _hasLoaded = true; return; }

        // Per-page OR widening (mirrors Ministries/Signups.razor) keeps
        // CanManageTeamAsync strictly per-team scoped: a SystemAdmin
        // caller who isn't a coach or org Admin still passes here, but
        // cannot mutate any Player rows (no edit affordances on this
        // page; the existing per-org edit gates elsewhere remain
        // unchanged).
        if (!string.IsNullOrEmpty(_userId))
        {
            _canView = await OrgAuth.IsSystemAdminAsync(_userId)
                || await OrgAuth.CanManageTeamAsync(_userId, TeamId);
        }

        if (_canView)
        {
            _activePlayers = await TeamService.ListActivePlayersWithContactsAsync(TeamId);
        }

        _hasLoaded = true;
    }
}
