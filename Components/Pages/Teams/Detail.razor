@page "/Teams/{TeamId:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_team?.Name ?? "Team")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

@if (_team is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap" Spacing="2">
        <div>
            <MudText Typo="Typo.h4" Class="mb-0">@_team.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                <MudLink Href="@LinkBuilder.LeagueHref(_team.MinistryId)">@_team.Ministry?.Name</MudLink>
                · @_team.Ministry?.Organization?.Name
                · @_team.AgeBracket @_team.Gender
            </MudText>
            @if (_team.CoachPerson is not null)
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    Coach: <MudLink Href="@LinkBuilder.PersonHref(_team.CoachPersonUserId)">@_team.CoachPerson.DisplayName</MudLink>
                </MudText>
            }
        </div>
        <MudStack Row="true" Spacing="2" Class="flex-wrap">
            <MudButton Href="@LinkBuilder.LeagueHref(_team.MinistryId)"
                       Color="Color.Default"
                       Variant="Variant.Outlined">Back to league</MudButton>
            @if (_canManage)
            {
                <MudButton Href="@AddPlayerHref"
                           Color="Color.Primary"
                           Variant="Variant.Filled">+ Add player</MudButton>
                <MudButton Href="@SignupsHref"
                           Color="Color.Default"
                           Variant="Variant.Outlined">View parents</MudButton>
            }
        </MudStack>
    </MudStack>

    @if (_isParent)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            You're a primary contact for a player on this team. You can see the roster and schedule; contact info for other players is hidden.
        </MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudCard Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Roster</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!_activePlayers.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No active players.</MudText>
                    }
                    else
                    {
                        <MudTable T="Player"
                                  Items="_activePlayers.OrderBy(p => p.JerseyNumber).ThenBy(p => p.LastName)"
                                  Dense="true"
                                  Hover="true"
                                  Striped="true">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>Name</MudTh>
                                <MudTh>Pos</MudTh>
                                @if (!_isParent) { <MudTh>Contact</MudTh> }
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@(context.JerseyNumber?.ToString() ?? "—")</MudTd>
                                <MudTd>
                                    @if (_canManage)
                                    {
                                        <MudLink Href="@($"Teams/{TeamId}/Players/{context.Id}/Edit")">@context.DisplayName</MudLink>
                                    }
                                    else
                                    {
                                        @context.DisplayName
                                    }
                                </MudTd>
                                <MudTd>@(context.Position ?? "—")</MudTd>
                                @if (!_isParent)
                                {
                                    <MudTd>
                                        @if (!string.IsNullOrEmpty(context.PrimaryContactPhone)) { <div>@context.PrimaryContactPhone</div> }
                                        @if (!string.IsNullOrEmpty(context.PrimaryContactEmail)) { <div>@context.PrimaryContactEmail</div> }
                                    </MudTd>
                                }
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Outlined="true">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Upcoming games</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!_upcomingGames.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No upcoming games.</MudText>
                    }
                    else
                    {
                        <MudList T="Game" Dense="true">
                            @foreach (var g in _upcomingGames)
                            {
                                var opp = g.HomeTeamId == TeamId ? g.AwayTeam : g.HomeTeam;
                                var home = g.HomeTeamId == TeamId;
                                <MudListItem T="Game" Href="@LinkBuilder.GameHref(g.Id)">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <span>@(home ? "vs" : "@") @opp.Name</span>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            <LocalTime Utc="@g.StartUtc" Format="ddd, MMM d h:mm tt" /> · @g.Arena.Name
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>

            <MudCard Outlined="true" Class="mt-3">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Recent results</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (!_pastGames.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No games played yet.</MudText>
                    }
                    else
                    {
                        <MudList T="Game" Dense="true">
                            @foreach (var g in _pastGames)
                            {
                                var opp = g.HomeTeamId == TeamId ? g.AwayTeam : g.HomeTeam;
                                var home = g.HomeTeamId == TeamId;
                                var us = home ? g.HomeScore : g.AwayScore;
                                var them = home ? g.AwayScore : g.HomeScore;
                                var outcome = (us, them) switch
                                {
                                    (null, _) or (_, null) => "—",
                                    (var u, var t) when u > t => "W",
                                    (var u, var t) when u < t => "L",
                                    _ => "D",
                                };
                                <MudListItem T="Game">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <span><strong>@outcome</strong> · @(home ? "vs" : "@") @opp.Name @us–@them</span>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            <LocalTime Utc="@g.StartUtc" Format="MMM d" />
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IOrgAuthService OrgAuth
@inject AuthenticationStateProvider Auth
@code {
    [Parameter] public int TeamId { get; set; }
    private Team? _team;
    private List<Player> _activePlayers = new();
    private List<Game> _upcomingGames = new();
    private List<Game> _pastGames = new();
    private bool _canManage;
    private bool _isParent;
    private string? _userId;

    // Computed hrefs for the action buttons. The Razor compiler chokes
    // on complex expressions like `LinkBuilder.TeamHref(TeamId) + "/Signups"`
    // inside an `Href="@(...)"` attribute (RZ9986), so we precompute them.
    private string AddPlayerHref => $"Teams/{TeamId}/Players/New";
    private string SignupsHref => $"Teams/{TeamId}/Signups";

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the loaded team so it stays
    // in sync with whatever team the user is viewing.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Leagues", href: "Leagues"),
            };
            if (_team is not null)
            {
                items.Add(new BreadcrumbItem(_team.Ministry?.Name ?? "League", href: LinkBuilder.LeagueHref(_team.MinistryId)));
            }
            items.Add(new BreadcrumbItem(_team?.Name ?? $"Team #{TeamId}", href: null, disabled: true));
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await using var db = await DbFactory.CreateDbContextAsync();
        _team = await db.Teams
            .Include(t => t.Ministry).ThenInclude(m => m.Organization)
            .Include(t => t.CoachPerson)
            .Include(t => t.Players)
            .AsNoTracking()
            .FirstOrDefaultAsync(t => t.Id == TeamId);
        if (_team is null) return;

        var now = DateTime.UtcNow;
        _activePlayers = _team.Players
            .Where(p => p.LeftUtc == null || p.LeftUtc > now)
            .ToList();

        var allGames = await db.Games
            .Include(g => g.HomeTeam)
            .Include(g => g.AwayTeam)
            .Include(g => g.Arena)
            .Where(g => (g.HomeTeamId == TeamId || g.AwayTeamId == TeamId))
            .OrderByDescending(g => g.StartUtc)
            .AsNoTracking()
            .ToListAsync();

        _upcomingGames = allGames.Where(g => g.StartUtc >= now && g.Status == GameStatus.Scheduled)
            .OrderBy(g => g.StartUtc).Take(8).ToList();
        _pastGames = allGames.Where(g => g.Status == GameStatus.Played)
            .OrderByDescending(g => g.StartUtc).Take(8).ToList();

        if (!string.IsNullOrEmpty(_userId))
        {
            _canManage = await OrgAuth.CanManageTeamAsync(_userId, TeamId);
            _isParent = !_canManage && await OrgAuth.IsParentOfAnyPlayerOnTeamAsync(_userId, TeamId);
        }
    }
}
