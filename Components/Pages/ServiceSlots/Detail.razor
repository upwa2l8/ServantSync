@page "/Organizations/{OrgId:int}/Ministries/{MinId:int}/Roles/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_slot?.Name ?? "Service slot")</PageTitle>

@if (_slot is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-0">@_slot.Name</h1>
            <div class="text-muted">@_slot.Description</div>
            @if (!string.IsNullOrWhiteSpace(_slot.Location))
            {
                <div class="text-muted small"><span class="bi bi-geo-alt" aria-hidden="true"></span> @_slot.Location</div>
            }
        </div>
        @* Manager-only action buttons. _canManage is already computed in
           OnInitializedAsync via SlotDocs.CanManageSlotAsync (which consults
           OrgAuthService); the same gate is also enforced server-side by the
           underlying Edit/Schedule/Series pages, so hiding here just avoids
           403-on-submit UX. *@
        @if (_canManage)
        {
            <div>
                <a class="btn btn-outline-secondary"
                   href="@($"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}/Edit")">Edit slot</a>
                <a class="btn btn-primary"
                   href="@($"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}/Schedule")">Schedule one</a>
                <a class="btn btn-secondary"
                   href="@($"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}/Series")">Schedule series</a>
            </div>
        }
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-header"><h5 class="mb-0"><span class="bi bi-person-badge me-1" aria-hidden="true"></span>Slot coordinator</h5></div>
        <div class="card-body">
            @if (_slot.CoordinatorPerson is null
                && string.IsNullOrWhiteSpace(_slot.CoordinatorEmail)
                && string.IsNullOrWhiteSpace(_slot.CoordinatorPhone))
            {
                <div class="text-muted small">No coordinator assigned. <a href="@($"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}/Edit")">Assign one</a> so the slot can be scheduled without going through the ministry coordinator.</div>
            }
            else
            {
                @if (_slot.CoordinatorPerson is not null)
                {
                    <div class="mb-2"><strong><a href="@($"People/{_slot.CoordinatorPerson.UserId}")">@_slot.CoordinatorPerson.DisplayName</a></strong></div>
                }
                @if (!string.IsNullOrWhiteSpace(_slot.CoordinatorEmail))
                {
                    <div class="text-muted small"><span class="bi bi-envelope" aria-hidden="true"></span> <a href="mailto:@_slot.CoordinatorEmail">@_slot.CoordinatorEmail</a></div>
                }
                @if (!string.IsNullOrWhiteSpace(_slot.CoordinatorPhone))
                {
                    <div class="text-muted small"><span class="bi bi-telephone" aria-hidden="true"></span> @_slot.CoordinatorPhone</div>
                }
            }
        </div>
    </div>

    <h5>Slot-specific training</h5>
    <SlotTrainingEditor ServiceSlotId="Id" />

    <h5 class="mt-4">Upcoming assignments</h5>
    @if (!_slot.Assignments.Any())
    {
        <div class="alert alert-info">None yet.</div>
    }
    else
    {
        <table class="table">                <thead><tr><th>When</th><th>Volunteer</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var a in _slot.Assignments.OrderBy(a => a.StartUtc))
                {
                    <tr>
                        <td><LocalTime Utc="@a.StartUtc" /> – <LocalTime Utc="@a.EndUtc" /></td>
                        <td><a href="@($"People/{a.PersonUserId}")">@a.Person.DisplayName</a></td>
                        <td>@a.Status</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="card mt-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><span class="bi bi-folder2-open me-1" aria-hidden="true"></span>Shared documents</h5>
            @if (_docGroups is not null && _totalDocCount > 0)
            {
                <span class="badge text-bg-light">@_totalDocCount file@(_totalDocCount == 1 ? "" : "s")</span>
            }
        </div>
        <div class="card-body">
            @if (_canManage)
            {
                <div class="card mb-3 border">
                    <div class="card-body">
                        <h6 class="card-title"><span class="bi bi-cloud-upload me-1" aria-hidden="true"></span>Upload a document</h6>
                        <p class="text-muted small">Share reference materials (bulletins, set lists, setup guides, run sheets) with the volunteers who hold this slot. Anyone assigned to the slot can download.</p>
                        <div class="mb-2">
                            <label for="doc-file" class="form-label small text-muted">File — PDF, DOCX, image, etc. (max @SlotUploadLimits.MaxFileSizeDisplay)</label>
                            <InputFile OnChange="HandleFileSelected" class="form-control" id="doc-file"
                                       accept=".pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.txt,.md,.csv,.png,.jpg,.jpeg,.gif,.webp,.svg" />
                        </div>
                        <div class="row g-2 mb-2">
                            <div class="col-md-7">
                                <label for="doc-title" class="visually-hidden">Document title</label>
                                <input @bind="_newDoc.Title" id="doc-title" placeholder="Title"
                                       class="form-control" aria-label="Document title" maxlength="160" />
                            </div>
                            <div class="col-md-5">
                                <label for="doc-category" class="visually-hidden">Category</label>
                                <input @bind="_newDoc.Category" id="doc-category" placeholder="Category (optional, e.g. Music, Setup)"
                                       class="form-control" aria-label="Category (optional)" maxlength="80" />
                            </div>
                        </div>
                        <label for="doc-description" class="visually-hidden">Description</label>
                        <textarea @bind="_newDoc.Description" id="doc-description" placeholder="Description (optional)"
                                  class="form-control mb-2" rows="2" aria-label="Description (optional)" maxlength="2000"></textarea>
                        @if (_uploadError is not null)
                        {
                            <div class="alert alert-danger py-2 mb-2 d-flex justify-content-between align-items-start gap-2" role="alert">
                                <div><strong>Upload failed:</strong> @_uploadError</div>
                                <button type="button" class="btn-close" @onclick="() => _uploadError = null" aria-label="Dismiss"></button>
                            </div>
                        }
                        <button @onclick="UploadDocumentAsync"
                                disabled="@(_busy || _newFile is null || string.IsNullOrWhiteSpace(_newDoc.Title))"
                                class="btn btn-primary">
                            @(_busy ? "Uploading…" : "Upload")
                        </button>
                    </div>
                </div>
            }

            @if (_deleteError is not null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Couldn't delete:</strong> @_deleteError
                    <button type="button" class="btn-close" @onclick="() => _deleteError = null" aria-label="Dismiss"></button>
                </div>
            }

            @if (_replaceError is not null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Couldn't replace:</strong> @_replaceError
                    <button type="button" class="btn-close" @onclick="() => _replaceError = null" aria-label="Dismiss"></button>
                </div>
            }

            @if (_docGroups is null)
            {
                <p class="text-muted mb-0"><em>Loading documents…</em></p>
            }
            else if (_docGroups.Count == 0)
            {
                <div class="text-center text-muted py-4">
                    <div class="bi bi-folder2 fs-1 d-block mb-2" aria-hidden="true"></div>
                    <div class="fw-semibold">No documents shared yet.</div>
                    @if (_canManage)
                    {
                        <div class="small">Use the upload form above to share your first reference document with the volunteers who hold this slot.</div>
                    }
                    else
                    {
                        <div class="small">Coordinators can upload bulletins, set lists, and other reference materials here.</div>
                    }
                </div>
            }
            else
            {
                @foreach (var group in _docGroups)
                {
                    <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
                        <h6 class="text-muted mb-0">
                            @if (string.IsNullOrEmpty(group.Category))
                            {
                                <span><span class="bi bi-tag me-1" aria-hidden="true"></span>Uncategorized</span>
                            }
                            else
                            {
                                <span><span class="bi bi-folder2 me-1" aria-hidden="true"></span>@group.Category</span>
                            }
                        </h6>
                        <span class="badge text-bg-light">@group.Documents.Count</span>
                    </div>
                    <ul class="list-group mb-2">
                        @foreach (var doc in group.Documents)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div class="me-3">
                                    <div>
                                        <span class="badge text-bg-light border me-2"
                                              title="@doc.OriginalFileName"
                                              aria-label="@GetFileTypeLabel(doc.OriginalFileName) document">@GetFileTypeLabel(doc.OriginalFileName)</span>
                                        <strong>@doc.Title</strong>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(doc.Description))
                                    {
                                        <div class="text-muted small mt-1">@doc.Description</div>
                                    }
                                    <div class="text-muted small mt-1">
                                        <span class="bi bi-paperclip" aria-hidden="true"></span> @doc.OriginalFileName
                                        <span class="ms-2">@FormatSize(doc.SizeBytes)</span>
                                        <span class="ms-2">· uploaded <LocalTime Utc="@doc.UploadedUtc" Format="MMM d, yyyy" /> by @(doc.UploadedByPerson?.DisplayName ?? "Unknown uploader")</span>
                                    </div>
                                </div>
                                <div class="btn-group btn-group-sm flex-shrink-0">
                                    <a class="btn btn-outline-primary"
                                       href="/slots/@doc.ServiceSlotId/documents/@doc.Id/download"
                                       target="_blank" rel="noopener"
                                       aria-label="Download @doc.Title">Download</a>
                                    @if (_canManage)
                                    {
                                        <InputFile OnChange="@(async e => await ReplaceFileAsync(doc.Id, e))"
                                                   id="@($"replace-{doc.Id}")"
                                                   accept=".pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.txt,.md,.csv,.png,.jpg,.jpeg,.gif,.webp,.svg"
                                                   class="d-none" />
                                        <label class="btn btn-outline-secondary"
                                               for="@($"replace-{doc.Id}")"
                                               aria-label="@($"Replace file for {doc.Title}")"
                                               title="Replace the file (keeps the same title, description, and category)">Replace</label>
                                        <button class="btn btn-outline-danger"
                                                @onclick="() => AskDelete(doc.Id, doc.Title)"
                                                disabled="@_busy"
                                                aria-label="Delete @doc.Title">Delete</button>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            }
        </div>
    </div>

    <ConfirmDialog Visible="_confirmingDelete"
                   Title="Delete document?"
                   ConfirmText="Delete"
                   CancelText="Cancel"
                   ConfirmButtonClass="btn-danger"
                   Busy="@_busy"
                   OnConfirm="PerformDeleteAsync"
                   OnCancel="CancelDelete">
        <p>The file will be removed from disk and the document will be removed from this slot's shared list. This cannot be undone.</p>
        @if (!string.IsNullOrEmpty(_deleteTargetTitle))
        {
            <p class="mb-0"><strong>@_deleteTargetTitle</strong></p>
        }
    </ConfirmDialog>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISlotDocumentService SlotDocs
@inject IOrgAuthService OrgAuth
@inject AuthenticationStateProvider Auth
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int MinId { get; set; }
    [Parameter] public int Id { get; set; }
    private ServiceSlot? _slot;
    private List<SlotDocumentGroup>? _docGroups;
    private bool _canManage;
    private IBrowserFile? _newFile;
    private NewDocModel _newDoc = new();
    private string? _uploadError;
    private string? _deleteError;
    private string? _replaceError;
    private bool _busy;
    private bool _confirmingDelete;
    private int? _deleteTargetId;
    private string? _deleteTargetTitle;
    private int _totalDocCount => _docGroups?.Sum(g => g.Documents.Count) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _slot = await db.ServiceSlots
            .Include(s => s.Assignments).ThenInclude(a => a.Person)
            .Include(s => s.CoordinatorPerson)
            .FirstOrDefaultAsync(s => s.Id == Id);

        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _canManage = !string.IsNullOrEmpty(userId) && await SlotDocs.CanManageSlotAsync(Id, userId);
        await ReloadDocumentsAsync();
    }

    private async Task ReloadDocumentsAsync()
    {
        _docGroups = await SlotDocs.ListGroupedByCategoryAsync(Id);
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _newFile = e.File;
        _uploadError = null;
        // Pre-fill the title with the file name (without extension) if the
        // coordinator hasn't typed one yet — common case.
        if (string.IsNullOrWhiteSpace(_newDoc.Title) && _newFile is not null)
        {
            var stem = Path.GetFileNameWithoutExtension(_newFile.Name);
            if (!string.IsNullOrWhiteSpace(stem)) _newDoc.Title = stem;
        }
    }

    private async Task UploadDocumentAsync()
    {
        if (_newFile is null || string.IsNullOrWhiteSpace(_newDoc.Title)) return;
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busy = true;
        _uploadError = null;
        try
        {
            // 10 MB cap from SlotUploadLimits; SlotDocumentService.UploadAsync enforces
            // the same limit on the server (throwing ArgumentException if exceeded).
            await using var stream = _newFile.OpenReadStream(maxAllowedSize: SlotUploadLimits.MaxFileSizeBytes);
            await SlotDocs.UploadAsync(
                Id, stream, _newFile.Name, _newFile.ContentType, _newFile.Size,
                _newDoc.Title, _newDoc.Description, _newDoc.Category, userId);

            _newFile = null;
            _newDoc = new();
            await ReloadDocumentsAsync();
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void AskDelete(int documentId, string title)
    {
        _deleteTargetId = documentId;
        _deleteTargetTitle = title;
        _deleteError = null;
        _confirmingDelete = true;
    }

    private void CancelDelete()
    {
        _confirmingDelete = false;
        _deleteTargetId = null;
        _deleteTargetTitle = null;
    }

    private async Task PerformDeleteAsync()
    {
        if (_deleteTargetId is null) return;
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            CancelDelete();
            return;
        }

        _busy = true;
        _deleteError = null;
        try
        {
            await SlotDocs.DeleteAsync(_deleteTargetId.Value, userId);
            await ReloadDocumentsAsync();
            CancelDelete();
        }
        catch (Exception ex)
        {
            // Close the modal so the user sees the error in the page-level
            // alert; the modal is dismissed by the "X" / Cancel button only
            // on success.
            _deleteError = ex.Message;
            _confirmingDelete = false;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReplaceFileAsync(int documentId, InputFileChangeEventArgs e)
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busy = true;
        _replaceError = null;
        try
        {
            // 10 MB cap from SlotUploadLimits; SlotDocumentService.ReplaceAsync enforces
            // the same limit on the server (throwing ArgumentException if exceeded),
            // which we surface via _replaceError.
            await using var stream = e.File.OpenReadStream(maxAllowedSize: SlotUploadLimits.MaxFileSizeBytes);
            await SlotDocs.ReplaceAsync(
                documentId, stream, e.File.Name, e.File.ContentType, e.File.Size, userId);
            await ReloadDocumentsAsync();
        }
        catch (Exception ex)
        {
            _replaceError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.#} MB";
    }

    /// <summary>
    /// Short, human-readable label for the file extension — used as a
    /// pill on each document row so volunteers can see at a glance
    /// what kind of file it is without reading the full file name.
    /// </summary>
    private static string GetFileTypeLabel(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "PDF",
            ".docx" or ".doc" => "DOCX",
            ".xlsx" or ".xls" => "XLSX",
            ".pptx" or ".ppt" => "PPTX",
            ".txt" or ".md" or ".csv" => "TEXT",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".svg" => "IMAGE",
            _ => "FILE",
        };
    }

    private class NewDocModel
    {
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public string? Category { get; set; }
    }
}
