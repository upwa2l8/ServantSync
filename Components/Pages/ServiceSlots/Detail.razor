@page "/Organizations/{OrgId:int}/Ministries/{MinId:int}/Roles/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_slot?.Name ?? "Service slot")</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

@if (_slot is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-3" Spacing="2">
        <div>
            <MudText Typo="Typo.h4" Class="mb-0">@_slot.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@_slot.Description</MudText>
            @if (!string.IsNullOrWhiteSpace(_slot.Location))
            {
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Outlined.Place" Size="Size.Small" /> @_slot.Location
                </MudText>
            }
        </div>
        <MudStack Spacing="2" AlignItems="AlignItems.End">
            @* Manager-only action buttons. _canManage is already computed in
               OnInitializedAsync via SlotDocs.CanManageSlotAsync (which consults
               OrgAuthService); the same gate is also enforced server-side by the
               underlying Edit/Schedule/Series pages, so hiding here just avoids
               403-on-submit UX. *@
            @if (_canManage)
            {
                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               Href="@LinkBuilder.SlotEditHref(OrgId, MinId, Id)">
                        Edit slot
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Href="@LinkBuilder.SlotScheduleHref(OrgId, MinId, Id)">
                        Schedule one
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               Href="@LinkBuilder.SlotSeriesHref(OrgId, MinId, Id)">
                        Schedule series
                    </MudButton>
                </MudStack>
            }
            @* Round-FR-7: per-volunteer Subscribe toggle. Anyone in the parent
               org sees this — it's the explicit opt-in surface for the
               slot-level filter on /Open. Out-of-org visitors (who hit the
               404 fallback above) don't see this row at all. The toggle
               mirrors the Ministries/Detail.razor "Join this ministry"
               affordance: single click → flicker-free flip via the
               optimistic local update; error reverts. *@
            @if (_isInOrg)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton Variant="@(_subscribed ? Variant.Outlined : Variant.Filled)"
                               Color="@(_subscribed ? Color.Success : Color.Primary)"
                               Disabled="@_busySubscribe"
                               OnClick="ToggleSubscriptionAsync"
                               StartIcon="@(_subscribed ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.BookmarkAdd)"
                               title="@(_subscribed ? "Stop including this slot's shifts in the My slots filter on /Open" : "Add this slot's shifts to the My slots filter on /Open")">
                        @if (_subscribed)
                        {
                            @(_busySubscribe ? "Updating…" : $"Subscribed (since {_subscribedUtc:MMM d, yyyy})")
                        }
                        else
                        {
                            @(_busySubscribe ? "Updating…" : "Subscribe to this slot")
                        }
                    </MudButton>
                    @if (_subscribeError is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Error">@_subscribeError</MudText>
                    }
                </MudStack>
            }
        </MudStack>
    </MudStack>

    <MudPaper Outlined="true" Class="mb-4 pa-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-2">
            <MudIcon Icon="@Icons.Material.Outlined.Badge" />
            <MudText Typo="Typo.h6">Slot coordinator</MudText>
        </MudStack>
        @if (_slot.CoordinatorPerson is null
            && string.IsNullOrWhiteSpace(_slot.CoordinatorEmail)
            && string.IsNullOrWhiteSpace(_slot.CoordinatorPhone))
        {
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                No coordinator assigned. <MudLink Href="@LinkBuilder.SlotEditHref(OrgId, MinId, Id)">Assign one</MudLink> so the slot can be scheduled without going through the ministry coordinator.
            </MudText>
        }
        else
        {
            @if (_slot.CoordinatorPerson is not null)
            {
                <MudText Class="mb-2"><strong><MudLink Href="@LinkBuilder.PersonHref(_slot.CoordinatorPerson.UserId)">@_slot.CoordinatorPerson.DisplayName</MudLink></strong></MudText>
            }
            @if (!string.IsNullOrWhiteSpace(_slot.CoordinatorEmail))
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Outlined.Email" Size="Size.Small" />
                    <MudLink Href="@LinkBuilder.MailtoHref(_slot.CoordinatorEmail)">@_slot.CoordinatorEmail</MudLink>
                </MudText>
            }
            @if (!string.IsNullOrWhiteSpace(_slot.CoordinatorPhone))
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    <MudIcon Icon="@Icons.Material.Outlined.Phone" Size="Size.Small" /> @_slot.CoordinatorPhone
                </MudText>
            }
        }
    </MudPaper>

    @* Manager-only: the SlotTrainingEditor is the affordance for adding
       or removing TrainingRequirement rows scoped to this slot. A
       volunteer (or any non-manager) must not be able to mark training
       mandatory — only an Admin or Coordinator of the slot's ministry
       can drive the EditForm. _canManage is already computed in
       OnInitializedAsync via SlotDocs.CanManageSlotAsync, which is the
       same gate ServiceSlots/Schedule.razor applies server-side. The
       <h5> heading is inside the gate so non-managers don't see an
       orphan section header. *@
    @if (_canManage)
    {
        <MudText Typo="Typo.h6" Class="mb-2">Slot-specific training</MudText>
        <SlotTrainingEditor ServiceSlotId="Id" />
    }

    <MudText Typo="Typo.h6" Class="mt-4 mb-2">Upcoming assignments</MudText>
    @if (!_slot.Assignments.Any())
    {
        <MudAlert Severity="Severity.Info">None yet.</MudAlert>
    }
    else
    {
        <MudPaper Outlined="true">
            <MudTable Items="_slot.Assignments.OrderBy(a => a.StartUtc).ToList()" Hover="true" Dense="true" Elevation="0">
                <HeaderContent>
                    <MudTh>When</MudTh>
                    <MudTh>Volunteer</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="When">
                        <LocalTime Utc="@context.StartUtc" /> – <LocalTime Utc="@context.EndUtc" />
                    </MudTd>
                    <MudTd DataLabel="Volunteer">
                        <MudLink Href="@LinkBuilder.PersonHref(context.PersonUserId)">@context.Person.DisplayName</MudLink>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@AssignmentStatusUi.MudColorFor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    <MudPaper Outlined="true" Class="mt-4 pa-3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudIcon Icon="@Icons.Material.Outlined.FolderOpen" />
                <MudText Typo="Typo.h6">Shared documents</MudText>
            </MudStack>
            @if (_docGroups is not null && _totalDocCount > 0)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                    @_totalDocCount file@(_totalDocCount == 1 ? "" : "s")
                </MudChip>
            }
        </MudStack>
        @if (_canManage)
        {
            <MudPaper Outlined="true" Class="mb-3 pa-3">
                <MudText Typo="Typo.subtitle1" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Size="Size.Small" /> Upload a document
                </MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                    Share reference materials (bulletins, set lists, setup guides, run sheets) with the volunteers who hold this slot. Anyone assigned to the slot can download.
                </MudText>
                <MudStack Spacing="2">
                    <MudFileUpload T="IBrowserFile"
                                   FilesChanged="HandleFileSelected"
                                   Accept=".pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.txt,.md,.csv,.png,.jpg,.jpeg,.gif,.webp,.svg">
                        <ActivatorContent>
                            <MudButton HtmlTag="label"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.CloudUpload">
                                @(_newFile is null ? "Choose file" : _newFile.Name)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">
                        Max file size: @SlotUploadLimits.MaxFileSizeDisplay
                    </MudText>
                    <MudTextField T="string" @bind-Value="_newDoc.Title"
                                  Label="Title" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" MaxLength="160" />
                    <MudTextField T="string" @bind-Value="_newDoc.Category"
                                  Label="Category (optional, e.g. Music, Setup)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="80" />
                    <MudTextField T="string" @bind-Value="_newDoc.Description"
                                  Label="Description (optional)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" MaxLength="2000" />
                    @if (_uploadError is not null)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" ShowCloseIcon="true"
                                  CloseIconClicked="() => _uploadError = null">
                            <strong>Upload failed:</strong> @_uploadError
                        </MudAlert>
                    }
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="@(_busy || _newFile is null || string.IsNullOrWhiteSpace(_newDoc.Title))"
                               OnClick="UploadDocumentAsync">
                        @(_busy ? "Uploading…" : "Upload")
                    </MudButton>
                </MudStack>
            </MudPaper>
        }

        @if (_deleteError is not null)
        {
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                      CloseIconClicked="() => _deleteError = null">
                <strong>Couldn't delete:</strong> @_deleteError
            </MudAlert>
        }

        @if (_replaceError is not null)
        {
            <MudAlert Severity="Severity.Error" ShowCloseIcon="true"
                      CloseIconClicked="() => _replaceError = null">
                <strong>Couldn't replace:</strong> @_replaceError
            </MudAlert>
        }

        @if (_docGroups is null)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_docGroups.Count == 0)
        {
            <div class="text-center mud-text-secondary py-4">
                <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Large" Class="d-block mx-auto mb-2" />
                <div class="fw-semibold">No documents shared yet.</div>
                @if (_canManage)
                {
                    <MudText Typo="Typo.caption">Use the upload form above to share your first reference document with the volunteers who hold this slot.</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption">Coordinators can upload bulletins, set lists, and other reference materials here.</MudText>
                }
            </div>
        }
        else
        {
            @foreach (var group in _docGroups)
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-3 mb-2">
                    <MudText Typo="Typo.subtitle1" Class="mb-0 mud-text-secondary">
                        @if (string.IsNullOrEmpty(group.Category))
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Tag" Size="Size.Small" /><text> Uncategorized</text>
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Outlined.Folder" Size="Size.Small" /> @group.Category
                        }
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@group.Documents.Count</MudChip>
                </MudStack>
                <MudPaper Outlined="true" Class="mb-2">
                    <MudList T="SlotDocument" Dense="true">
                        @foreach (var doc in group.Documents)
                        {
                            <MudListItem T="SlotDocument" Icon="@Icons.Material.Outlined.Description">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                    <div>
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mr-2"
                                                 title="@doc.OriginalFileName"
                                                 aria-label="@GetDocAriaLabel(doc.OriginalFileName)">
                                            @GetFileTypeLabel(doc.OriginalFileName)
                                        </MudChip>
                                        <strong>@doc.Title</strong>
                                        @if (!string.IsNullOrWhiteSpace(doc.Description))
                                        {
                                            <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">@doc.Description</MudText>
                                        }
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                                            <MudIcon Icon="@Icons.Material.Outlined.AttachFile" Size="Size.Small" /> @doc.OriginalFileName
                                            <span class="ml-2">@FormatSize(doc.SizeBytes)</span>
                                            <span class="ml-2">· uploaded <LocalTime Utc="@doc.UploadedUtc" Format="MMM d, yyyy" /> by @(doc.UploadedByPerson?.DisplayName ?? "Unknown uploader")</span>
                                        </MudText>
                                    </div>
                                    <MudStack Row="true" Spacing="1" Class="flex-shrink-0">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                   Href="@LinkBuilder.DocDownloadHref(doc.ServiceSlotId, doc.Id)"
                                                   Target="_blank" rel="noopener"
                                                   aria-label="@DownloadAriaLabel(doc.Title)"
                                                   StartIcon="@Icons.Material.Outlined.Download">
                                            Download
                                        </MudButton>
                                        @if (_canManage)
                                        {
                                            <MudFileUpload T="IBrowserFile"
                                                           FilesChanged="e => ReplaceFileAsync(doc.Id, e)"
                                                           Accept=".pdf,.docx,.doc,.xlsx,.xls,.pptx,.ppt,.txt,.md,.csv,.png,.jpg,.jpeg,.gif,.webp,.svg">
                                                <ActivatorContent>
                                                    <MudButton HtmlTag="label"
                                                               Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                                               aria-label="@ReplaceAriaLabel(doc.Title)"
                                                               title="Replace the file (keeps the same title, description, and category)"
                                                               StartIcon="@Icons.Material.Outlined.SwapHoriz">
                                                        Replace
                                                    </MudButton>
                                                </ActivatorContent>
                                            </MudFileUpload>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => AskDelete(doc.Id, doc.Title))"
                                                       Disabled="@_busy"
                                                       aria-label="@DeleteAriaLabel(doc.Title)"
                                                       StartIcon="@Icons.Material.Outlined.Delete">
                                                Delete
                                            </MudButton>
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            }
        }
    </MudPaper>

    <ConfirmDialog Visible="_confirmingDelete"
                   Title="Delete document?"
                   ConfirmText="Delete"
                   CancelText="Cancel"
                   ConfirmButtonClass="btn-danger"
                   Busy="@_busy"
                   OnConfirm="PerformDeleteAsync"
                   OnCancel="CancelDelete">
        <p>The file will be removed from disk and the document will be removed from this slot's shared list. This cannot be undone.</p>
        @if (!string.IsNullOrEmpty(_deleteTargetTitle))
        {
            <p class="mb-0"><strong>@_deleteTargetTitle</strong></p>
        }
    </ConfirmDialog>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ISlotDocumentService SlotDocs
@inject IOrgAuthService OrgAuth
@inject ISlotInterestService Slots
@inject AuthenticationStateProvider Auth
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int MinId { get; set; }
    [Parameter] public int Id { get; set; }
    private ServiceSlot? _slot;
    private List<SlotDocumentGroup>? _docGroups;
    private bool _canManage;
    private IBrowserFile? _newFile;
    private NewDocModel _newDoc = new();
    private string? _uploadError;
    private string? _deleteError;
    private string? _replaceError;
    private bool _busy;
    private bool _confirmingDelete;
    private int? _deleteTargetId;
    private string? _deleteTargetTitle;
    private int _totalDocCount => _docGroups?.Sum(g => g.Documents.Count) ?? 0;
    // Round-FR-7: per-slot subscription state. Computed in
    // OnInitializedAsync via ISlotInterestService.ListSubscribedAsync; the
    // header Subscribe toggle flips it inline via the ToggleSubscriptionAsync
    // handler. The picker is gated on _isInOrg so out-of-org visitors don't
    // see it (they're funneled to a 404/empty state in the page header above).
    private bool _isInOrg;
    private bool _subscribed;
    private DateTime? _subscribedUtc;
    private bool _busySubscribe;
    private string? _subscribeError;
    // Per-page breadcrumb trail. Same shape as the rest of the migrated
    // pages — `MudBreadcrumbs` is the MudBlazor equivalent of the old
    // <ol class="breadcrumb"> block. Slot #N is appended after the
    // slot row is loaded (when the title becomes known).
    private List<BreadcrumbItem> _crumbs = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _slot = await db.ServiceSlots
            .Include(s => s.Assignments).ThenInclude(a => a.Person)
            .Include(s => s.CoordinatorPerson)
            .FirstOrDefaultAsync(s => s.Id == Id);

        // Build the breadcrumb once we have the slot row. The intermediate
        // ids (Org / Ministry) are real even before their data is loaded,
        // so the static path is enough — the user clicks back to the
        // ministry page even if the underlying name never renders.
        _crumbs = new()
        {
            new BreadcrumbItem("Home", href: ""),
            new BreadcrumbItem("Organizations", href: "Organizations"),
            new BreadcrumbItem($"Org #{OrgId}", href: $"Organizations/{OrgId}"),
            new BreadcrumbItem($"Ministry #{MinId}", href: $"Organizations/{OrgId}/Ministries/{MinId}"),
            new BreadcrumbItem(_slot?.Name ?? $"Slot #{Id}", href: null, disabled: true),
        };

        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _canManage = !string.IsNullOrEmpty(userId) && await SlotDocs.CanManageSlotAsync(Id, userId);

        if (!string.IsNullOrEmpty(userId) && _slot is not null)
        {
            // In-org check is the local mirror of the SlotInterest gate:
            // a volunteer can't subscribe to a slot whose parent ministry
            // is in an org they don't belong to. The service layer's gate
            // is authoritative; this is purely UX (hide the toggle).
            _isInOrg = await db.OrganizationMemberships
                .AnyAsync(m => m.OrganizationId == OrgId && m.PersonUserId == userId);
            if (_isInOrg)
            {
                var subs = await Slots.ListSubscribedAsync(userId);
                var sub = subs.FirstOrDefault(s => s.ServiceSlotId == Id);
                _subscribed = sub is not null;
                _subscribedUtc = sub?.SubscribedUtc;
            }
        }
        await ReloadDocumentsAsync();
    }

    private async Task ReloadDocumentsAsync()
    {
        _docGroups = await SlotDocs.ListGroupedByCategoryAsync(Id);
    }

    private void HandleFileSelected(IBrowserFile? file)
    {
        _newFile = file;
        _uploadError = null;
        // Pre-fill the title with the file name (without extension) if the
        // coordinator hasn't typed one yet — common case.
        if (string.IsNullOrWhiteSpace(_newDoc.Title) && _newFile is not null)
        {
            var stem = Path.GetFileNameWithoutExtension(_newFile.Name);
            if (!string.IsNullOrWhiteSpace(stem)) _newDoc.Title = stem;
        }
    }

    private async Task UploadDocumentAsync()
    {
        if (_newFile is null || string.IsNullOrWhiteSpace(_newDoc.Title)) return;
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busy = true;
        _uploadError = null;
        try
        {
            // 10 MB cap from SlotUploadLimits; SlotDocumentService.UploadAsync enforces
            // the same limit on the server (throwing ArgumentException if exceeded).
            await using var stream = _newFile.OpenReadStream(maxAllowedSize: SlotUploadLimits.MaxFileSizeBytes);
            await SlotDocs.UploadAsync(
                Id, stream, _newFile.Name, _newFile.ContentType, _newFile.Size,
                _newDoc.Title, _newDoc.Description, _newDoc.Category, userId);

            _newFile = null;
            _newDoc = new();
            await ReloadDocumentsAsync();
        }
        catch (Exception ex)
        {
            _uploadError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void AskDelete(int documentId, string title)
    {
        _deleteTargetId = documentId;
        _deleteTargetTitle = title;
        _deleteError = null;
        _confirmingDelete = true;
    }

    private void CancelDelete()
    {
        _confirmingDelete = false;
        _deleteTargetId = null;
        _deleteTargetTitle = null;
    }

    private async Task PerformDeleteAsync()
    {
        if (_deleteTargetId is null) return;
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            CancelDelete();
            return;
        }

        _busy = true;
        _deleteError = null;
        try
        {
            await SlotDocs.DeleteAsync(_deleteTargetId.Value, userId);
            await ReloadDocumentsAsync();
            CancelDelete();
        }
        catch (Exception ex)
        {
            // Close the modal so the user sees the error in the page-level
            // alert; the modal is dismissed by the "X" / Cancel button only
            // on success.
            _deleteError = ex.Message;
            _confirmingDelete = false;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ReplaceFileAsync(int documentId, IBrowserFile? file)
    {
        if (file is null) return;
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busy = true;
        _replaceError = null;
        try
        {
            // 10 MB cap from SlotUploadLimits; SlotDocumentService.ReplaceAsync enforces
            // the same limit on the server (throwing ArgumentException if exceeded),
            // which we surface via _replaceError.
            await using var stream = file.OpenReadStream(maxAllowedSize: SlotUploadLimits.MaxFileSizeBytes);
            await SlotDocs.ReplaceAsync(
                documentId, stream, file.Name, file.ContentType, file.Size, userId);
            await ReloadDocumentsAsync();
        }
        catch (Exception ex)
        {
            _replaceError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.#} MB";
    }

    /// <summary>
    /// Screen-reader label for the file-type pill on each document
    /// row. Pre-computed via a helper because the inline Razor
    /// expression with a string-literal inside the aria-label attribute
    /// was ambiguous to the Razor parser in .NET 9.
    /// </summary>
    private static string GetDocAriaLabel(string fileName) =>
        $"{GetFileTypeLabel(fileName)} document";

    // Aria-label helpers below are page-specific (they reference
    // document titles) and stay file-local. All href builders now
    // live in the shared Components/Shared/LinkBuilder.cs.
    private static string DownloadAriaLabel(string title) =>
        $"Download {title}";

    private static string ReplaceAriaLabel(string title) =>
        $"Replace file for {title}";

    private static string DeleteAriaLabel(string title) =>
        $"Delete {title}";

    /// <summary>
    /// Short, human-readable label for the file extension — used as a
    /// pill on each document row so volunteers can see at a glance
    /// what kind of file it is without reading the full file name.
    /// </summary>
    private static string GetFileTypeLabel(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".pdf" => "PDF",
            ".docx" or ".doc" => "DOCX",
            ".xlsx" or ".xls" => "XLSX",
            ".pptx" or ".ppt" => "PPTX",
            ".txt" or ".md" or ".csv" => "TEXT",
            ".png" or ".jpg" or ".jpeg" or ".gif" or ".webp" or ".svg" => "IMAGE",
            _ => "FILE",
        };
    }

    private class NewDocModel
    {
        public string Title { get; set; } = "";
        public string? Description { get; set; }
        public string? Category { get; set; }
    }

    /// <summary>
    /// Round-FR-7: enable / disable the user's slot-level subscription
    /// from this page (mirrors the per-row pill on
    /// <c>Ministries/Detail.razor</c> and the per-card toggle on
    /// <c>Open.razor</c>). Single-flight via the
    /// <c>_busySubscribe</c> flag so rapid double-clicks are a no-op.
    /// Optimistic flip of <c>_subscribed</c> + revert on error. Uses
    /// <c>state.User.FindFirst</c> (not a cached <c>_userId</c> field)
    /// to match the existing handlers in this file — the field would
    /// be one optimization away from a working state.
    /// </summary>
    private async Task ToggleSubscriptionAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId) || !_isInOrg) return;

        _busySubscribe = true;
        _subscribeError = null;
        try
        {
            var wasSubscribed = _subscribed;
            if (wasSubscribed)
            {
                _subscribed = false;
                var result = await Slots.UnsubscribeAsync(userId, userId, Id);
                if (result == SlotInterestLeaveResult.PermissionDenied)
                {
                    _subscribed = true;
                    _subscribeError = "You can only stop subscribing to slots in organizations you belong to.";
                }
                else if (result == SlotInterestLeaveResult.SlotNotFound)
                {
                    _subscribed = true;
                    _subscribeError = "This slot no longer exists.";
                }
            }
            else
            {
                _subscribed = true;
                _subscribedUtc = DateTime.UtcNow;
                var result = await Slots.SubscribeAsync(userId, userId, Id, SlotInterestSource.Explicit);
                if (result == SlotInterestJoinResult.PermissionDenied)
                {
                    _subscribed = false;
                    _subscribedUtc = null;
                    _subscribeError = "You can only subscribe to slots in organizations you belong to.";
                }
                else if (result == SlotInterestJoinResult.SlotNotFound)
                {
                    _subscribed = false;
                    _subscribedUtc = null;
                    _subscribeError = "This slot no longer exists.";
                }
            }
        }
        finally
        {
            _busySubscribe = false;
        }
    }
}
