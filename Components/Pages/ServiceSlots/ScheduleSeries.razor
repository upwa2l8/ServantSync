@page "/Organizations/{OrgId:int}/Ministries/{MinId:int}/Roles/{Id:int}/Series"
@attribute [Authorize]
@rendermode InteractiveServer
@using ServantSync.Services

<PageTitle>Schedule series · @(_slot?.Name ?? "Slot")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

@if (_slot is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudText Typo="Typo.h4" Class="mb-0 gradient-text">@_slot.Name</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">@_slot.Description</MudText>

    <MudText Typo="Typo.h6">Create a weekly series</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
        Expands into one Assignment per matching weekday in the range. Occurrences that
        would conflict with another assignment, or where the volunteer lacks valid training,
        are skipped-with-reason — the rest are still created.
    </MudText>

    <EditForm Model="_form" OnValidSubmit="Generate" FormName="series" Context="ctx">
        <MudGrid Spacing="2" AlignItems="Center" Class="mb-2">
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="string"
                           @bind-Value="_form.PersonUserId"
                           Label="Volunteer"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("")">— pick person —</MudSelectItem>
                    @foreach (var p in _orgMembers)
                    {
                        <MudSelectItem T="string" Value="@p.UserId">@p.DisplayName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3" md="3">
                <MudSelect T="DayOfWeek"
                           @bind-Value="_form.DayOfWeek"
                           Label="Day of week"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var d in Enum.GetValues<DayOfWeek>())
                    {
                        <MudSelectItem T="DayOfWeek" Value="@d">@d</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <MudTextField T="string"
                              Label="Start (local HH:mm)"
                              InputType="InputType.Time"
                              @bind-Value="_form.StartLocal"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <MudNumericField T="int"
                                 @bind-Value="_form.DurationMinutes"
                                 Label="Duration (min)"
                                 Min="0"
                                 Step="15"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <MudDatePicker Label="First date"
                               @bind-Date="_form.StartDate"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <MudDatePicker Label="Last date (exclusive)"
                               @bind-Date="_form.EndDate"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           @bind-Value="_form.TimeZoneId"
                           Label="Time zone"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var tz in _timeZones)
                    {
                        <MudSelectItem T="string" Value="@tz.Id">@tz.DisplayName</MudSelectItem>
                    }
                </MudSelect>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                    @if (!string.IsNullOrEmpty(TzProvider.TimeZoneId))
                    {
                        <span>Detected from your browser: <code>@TzProvider.TimeZoneId</code></span>
                    }
                    else
                    {
                        <span>Browser timezone unavailable — using server default until you pick.</span>
                    }
                </MudText>
            </MudItem>
            <MudItem xs="12" Class="mt-2">
                <MudButton ButtonType="ButtonType.Submit"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@(_busy || !_canSchedule)">
                    @(_busy ? "Generating…" : (_canSchedule ? "Generate series" : "Coordinators only"))
                </MudButton>
            </MudItem>
        </MudGrid>
    </EditForm>

    <StatusMessage Message="@_message" IsError="@_isError" />

    @if (_result is not null)
    {
        <MudGrid Spacing="3" Class="mt-4">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6">Created (@_result.Created.Count)</MudText>
                @if (!_result.Created.Any())
                {
                    <MudAlert Severity="Severity.Warning">No occurrences created (all skipped).</MudAlert>
                }
                else
                {
                    <MudPaper Outlined="true" Class="glass-card">
                        <MudTable T="Assignment" Items="_result.Created.OrderBy(a => a.StartUtc)" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>When (UTC)</MudTh>
                                <MudTh>Duration</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><LocalTime Utc="@context.StartUtc" /> – <LocalTime Utc="@context.EndUtc" /></MudTd>
                                <MudTd>@((context.EndUtc - context.StartUtc).TotalMinutes) min</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.h6">Skipped (@_result.Skipped.Count)</MudText>
                @if (!_result.Skipped.Any())
                {
                    <MudAlert Severity="Severity.Success">All occurrences were scheduled.</MudAlert>
                }
                else
                {
                    <MudList T="ScheduleSeriesSkipped" Dense="true">
                        @foreach (var s in _result.Skipped.OrderBy(s => s.ProposedStartUtc))
                        {
                            <MudListItem T="ScheduleSeriesSkipped">
                                <strong><LocalTime Utc="@s.ProposedStartUtc" Format="ddd, MMM d h:mm tt" /></strong>
                                <ul class="mb-0">
                                    @foreach (var r in s.Reasons)
                                    {
                                        <li>@r</li>
                                    }
                                </ul>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudItem>
            @if (_result.CapReached)
            {
                <MudItem xs="12" Class="mt-2">
                    <MudAlert Severity="Severity.Warning">
                        Note: the series hit the safety cap of 500 occurrences. Split your range
                        into smaller chunks if you need more.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IAssignmentService AssignmentService
@inject UserTimeZoneProvider TzProvider
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int MinId { get; set; }
    [Parameter] public int Id { get; set; }

    private ServiceSlot? _slot;
    private List<Person> _orgMembers = new();
    // [SupplyParameterFromForm] — see Organizations/Edit.razor for rationale.
    [SupplyParameterFromForm] private SeriesForm _form { get; set; } = new();
    private ScheduleSeriesResult? _result;
    private bool _busy;
    private string? _message;
    private bool _isError;
    private bool _canSchedule;

    private List<TimeZoneInfo> _timeZones = TimeZoneInfo.GetSystemTimeZones()
        .OrderBy(tz => tz.BaseUtcOffset).ThenBy(tz => tz.Id).ToList();

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the route params + loaded
    // slot so it stays in sync with whatever slot the user is viewing.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Organizations", href: "Organizations"),
                new BreadcrumbItem($"Org #{OrgId}", href: $"Organizations/{OrgId}"),
                new BreadcrumbItem($"Ministry #{MinId}", href: $"Organizations/{OrgId}/Ministries/{MinId}"),
                new BreadcrumbItem(_slot?.Name ?? $"Slot #{Id}", href: $"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}"),
                new BreadcrumbItem("Schedule series", href: null, disabled: true),
            };
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        // Gate on CanManageSlotAsync (not CanManageOrgAsync) so a ministry coordinator
        // of the slot's ministry — or the slot's own coordinator — can drive the
        // Series UI, matching the parallel gate on Schedule.razor. Using the org
        // gate here would wrongly label the button "Coordinators only" for any user
        // whose coordinator role is at the ministry/slot tier rather than the
        // org tier (e.g. Rob Test, coordinator of the Referees ministry).
        _canSchedule = !string.IsNullOrEmpty(userId)
            && await OrgAuth.CanManageSlotAsync(userId, Id);

        await Reload();

        _form.StartDate = DateTime.Today;
        _form.EndDate = DateTime.Today.AddMonths(3);
        _form.DayOfWeek = DayOfWeek.Sunday;
        _form.DurationMinutes = _slot?.DefaultDurationMinutes ?? 60;
        _form.TimeZoneId = TzProvider.TimeZoneId
            ?? TimeZoneInfo.Local.Id;
    }

    private async Task Reload()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _slot = await db.ServiceSlots.AsNoTracking().FirstOrDefaultAsync(s => s.Id == Id);
        _orgMembers = await db.OrganizationMemberships
            .Where(m => m.OrganizationId == OrgId)
            .Select(m => m.Person)
            .OrderBy(p => p.LastName)
            .ToListAsync();
    }

    private async Task Generate()
    {
        if (!_canSchedule) return;
        _busy = true;
        _message = null;
        _isError = false;
        try
        {
            if (string.IsNullOrEmpty(_form.PersonUserId))
            {
                _isError = true;
                _message = "Pick a volunteer first.";
                return;
            }
            if (!TimeSpan.TryParse(_form.StartLocal, out var stime))
            {
                _isError = true;
                _message = "Start time must be HH:mm.";
                return;
            }
            if (_form.StartDate is null || _form.EndDate is null)
            {
                _isError = true;
                _message = "Pick both first and last dates.";
                return;
            }
            if (_form.EndDate <= _form.StartDate)
            {
                _isError = true;
                _message = "Last date must be after first date.";
                return;
            }
            if (_form.DurationMinutes <= 0)
            {
                _isError = true;
                _message = "Duration must be positive.";
                return;
            }

            _result = await AssignmentService.ScheduleSeriesAsync(
                _form.PersonUserId,
                Id,
                _form.DayOfWeek,
                stime,
                _form.DurationMinutes,
                _form.StartDate.Value.Date,
                _form.EndDate.Value.Date,
                _form.TimeZoneId ?? TimeZoneInfo.Local.Id);

            _message = $"Series evaluated. Created {_result.Created.Count}, skipped {_result.Skipped.Count}."
                + (_result.CapReached ? " (Hit the 500-occurrence safety cap.)" : "");
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = "Series generation failed: " + ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private class SeriesForm
    {
        public string? PersonUserId { get; set; }
        public DayOfWeek DayOfWeek { get; set; }
        public string StartLocal { get; set; } = "09:00";
        public int DurationMinutes { get; set; }
        // MudDatePicker binds to DateTime? (nullable). Original used
        // <InputDate> with non-nullable DateTime; nullable here matches
        // the MudBlazor component contract and Generate() handles the
        // null case explicitly.
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string? TimeZoneId { get; set; }
    }
}
