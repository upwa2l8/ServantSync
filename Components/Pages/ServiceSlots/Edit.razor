@page "/Organizations/{OrgId:int}/Ministries/{MinId:int}/Roles/{Id:int}/Edit"
@page "/Organizations/{OrgId:int}/Ministries/{MinId:int}/Roles/New"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New service slot" : "Edit slot")</PageTitle>

<h1>@(_isNew ? "New service slot" : "Edit service slot")</h1>
<StatusMessage Message="@_message" IsError="@_isError" />

<EditForm Model="_model" OnValidSubmit="Save" FormName="slot">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-floating mb-3">
        <InputText id="name" class="form-control" @bind-Value="_model.Name" />
        <label for="name">Name</label>
    </div>
    <div class="form-floating mb-3">
        <InputTextArea id="desc" class="form-control" style="height: 5rem" @bind-Value="_model.Description" />
        <label for="desc">Description</label>
    </div>
    <div class="form-floating mb-3">
        <InputText id="loc" class="form-control" @bind-Value="_model.Location" />
        <label for="loc">Location</label>
    </div>
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Default duration (minutes)</label>
            <input class="form-control" type="number" min="0" step="15" @bind="_model.DefaultDurationMinutes" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Capacity (volunteers per occurrence)</label>
            <input class="form-control" type="number" min="1" step="1" @bind="_model.Capacity"
                   title="How many volunteers can sign up for a single time this slot runs. Default 1; bump to 3 for a referee slot that needs 3 per game." />
            <div class="form-text">How many volunteers can serve per scheduled occurrence of this slot.</div>
        </div>
        <div class="col-md-4 form-check mb-2">
            <input type="checkbox" class="form-check-input" id="active" @bind="_model.IsActive" />
            <label class="form-check-label" for="active">Active (accepting volunteers)</label>
        </div>
    </div>

    <h5 class="mt-4">Coordinator</h5>
    <p class="text-muted small">The slot coordinator can schedule shifts for this slot without being the ministry coordinator. Leave blank if the ministry coordinator handles this slot.</p>
    <div class="row g-2">
        <div class="col-md-6">
            <label class="form-label">Coordinator</label>
            <select class="form-select" @bind="_model.CoordinatorPersonUserId">
                <option value="">— none —</option>
                @foreach (var p in _members)
                {
                    <option value="@p.UserId">@p.DisplayName</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <div class="form-floating">
                <InputText id="cemail" class="form-control" @bind-Value="_model.CoordinatorEmail" />
                <label for="cemail">Coordinator email</label>
            </div>
        </div>
    </div>
    <div class="form-floating mt-2">
        <InputText id="cphone" class="form-control" @bind-Value="_model.CoordinatorPhone" />
        <label for="cphone">Coordinator phone</label>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" type="submit" disabled="@(!_canSubmit)">Save</button>
        <a class="btn btn-outline-secondary ms-2"
           href="@(_isNew ? $"Organizations/{OrgId}/Ministries/{MinId}" : $"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}")">Cancel</a>
    </div>
</EditForm>

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject ISlotManagementService SlotMgmt
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int MinId { get; set; }
    [Parameter] public int? Id { get; set; }
    private bool _isNew => Id is null;
    // EditForm requires the bound model to be a PROPERTY marked with
    // [SupplyParameterFromForm] — without it the form data is submitted
    // but never deserialized into the model, so Save gets an empty _model
    // and DataAnnotationsValidator flags Name as required. A private field
    // is silently ignored by the form-binding pipeline. (See
    // Components/Account/Pages/Login.razor for the same comment.)
    [SupplyParameterFromForm] private SlotModel _model { get; set; } = new();
    // Cached org members list so the coordinator dropdown has names to
    // show. Loaded in OnInitializedAsync alongside the slot itself.
    private List<Person> _members = new();
    private string? _message;
    private bool _isError;
    // Round-BA split gate. _canCreate and _canEdit drive BOTH the
    // button-disable state AND the Save() server-side check.
    //
    //  _canCreate = CanManageMinistryAsync(MinId)
    //    Ministry-tier: org Admin/Coordinator + ministry Coordinator +
    //    parent-ministry Coordinator (transitive). Widens the prior
    //    CanManageOrgAsync gate so the ministry coordinator — who can
    //    already schedule shifts in their own slot via Schedule.razor —
    //    can also CREATE the slot definition.
    //
    //  _canEdit = CanManageSlotAsync(Id)
    //    Slot-tier (delegated also to CoordinatorPersonUserId on the
    //    slot row). Matches ServiceSlots/Detail.razor + Schedule.razor +
    //    ScheduleSeries.razor so the three slot surfaces share one gate.
    //    Crucially a slot coordinator can edit their own slot without
    //    being escalated to ministry tier.
    //
    // Both intentionally do NO `|| IsSystemAdminAsync` widening — slot
    // mutations stay in the strict-per-org blast radius (round-AZ
    // precedent). SystemAdmin can READ every org but doesn't get
    // auto-write to slots in arbitrary orgs.
    private bool _canCreate;
    private bool _canEdit;
    // button-bind state for the Save button. Re-derives in OnInitialized
    // (and on form re-render) — never trust client-side evaluation of a
    // gate the server also re-checks inside SlotManagementService.
    private bool _canSubmit => _isNew ? _canCreate : _canEdit;
    private string _userId = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        // ── Tier-split gate ─────────────────────────────────────────────
        // At create-time there's no slot row yet so we MUST use the
        // ministry-tier gate (slot-tier has no slot-coordinator FK yet).
        // At edit-time the slot-tier gate ALSO honors the slot's own
        // CoordinatorPersonUserId, which is the whole point of having
        // per-slot coordinators in the first place.
        if (_isNew)
        {
            _canCreate = !string.IsNullOrEmpty(_userId)
                && await OrgAuth.CanManageMinistryAsync(_userId, MinId);
        }
        else
        {
            _canEdit = !string.IsNullOrEmpty(_userId)
                && await OrgAuth.CanManageSlotAsync(_userId, Id!.Value);
        }

        if (!_canSubmit)
        {
            _isError = true;
            _message = _isNew
                ? "You don't have permission to add slots to this ministry."
                : "You don't have permission to manage this service slot.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        // Org members are needed for the coordinator dropdown — load them
        // on both the new and edit paths so it's available before the user
        // touches the picker.
        _members = await db.OrganizationMemberships
            .Where(m => m.OrganizationId == OrgId)
            .Select(m => m.Person)
            .OrderBy(p => p.LastName)
            .ToListAsync();

        if (_isNew) return;
        var slot = await db.ServiceSlots
            .Where(s => s.Id == Id!.Value && s.MinistryId == MinId
                && s.Ministry!.OrganizationId == OrgId)
            .FirstOrDefaultAsync();
        if (slot is null)
        {
            _isError = true;
            _message = "Slot not found.";
            return;
        }
        _model = new SlotModel
        {
            Name = slot.Name,
            Description = slot.Description,
            Location = slot.Location,
            DefaultDurationMinutes = slot.DefaultDurationMinutes ?? 0,
            IsActive = slot.IsActive,
            Capacity = slot.Capacity,
            CoordinatorPersonUserId = slot.CoordinatorPersonUserId,
            CoordinatorEmail = slot.CoordinatorEmail,
            CoordinatorPhone = slot.CoordinatorPhone,
        };
    }


    private async Task Save()
    {
        // Server-side gate re-check — mirrors SlotManagementService's
        // tier-split internal gate. The page-side gate already disabled
        // the button; this is defense in depth in case a future
        // contributor removes the disabled attribute.
        if (_isNew ? !_canCreate : !_canEdit)
        {
            _isError = true;
            _message = "You don't have permission to do that.";
            return;
        }

        var result = await SlotMgmt.UpsertAsync(
            callerUserId: _userId,
            organizationId: OrgId,
            ministryId: MinId,
            slotId: Id,
            name: _model.Name,
            description: _model.Description,
            location: _model.Location,
            defaultDurationMinutes: _model.DefaultDurationMinutes,
            isActive: _model.IsActive,
            capacity: _model.Capacity,
            coordinatorPersonUserId: _model.CoordinatorPersonUserId,
            coordinatorEmail: _model.CoordinatorEmail,
            coordinatorPhone: _model.CoordinatorPhone);

        switch (result)
        {
            case SlotUpsertResult.Saved:
                Nav.NavigateTo(_isNew
                    ? $"Organizations/{OrgId}/Ministries/{MinId}"
                    : $"Organizations/{OrgId}/Ministries/{MinId}/Roles/{Id}");
                return;
            case SlotUpsertResult.NotFound:
                _isError = true;
                _message = "Slot not found.";
                return;
            case SlotUpsertResult.PermissionDenied:
            default:
                _isError = true;
                _message = "You don't have permission to do that.";
                return;
        }
    }

    private class SlotModel
    {
        [Required, StringLength(160)] public string Name { get; set; } = "";
        [StringLength(2000)] public string? Description { get; set; }
        [StringLength(200)] public string? Location { get; set; }
        public int DefaultDurationMinutes { get; set; }
        public bool IsActive { get; set; } = true;
        // Capacity defaults to 1 in the C# initializer (matches the DB column
        // default). Coordinator can bump on slots where one occurrence needs
        // multiple volunteers (e.g. 3 referees at one game).
        public int Capacity { get; set; } = 1;
        // Per-slot coordinator. Empty string (not null) keeps the form
        // binding's two-way <option value=""> mapping consistent.
        public string? CoordinatorPersonUserId { get; set; }
        [StringLength(120), EmailAddress] public string? CoordinatorEmail { get; set; }
        [StringLength(40)] public string? CoordinatorPhone { get; set; }
    }
}
