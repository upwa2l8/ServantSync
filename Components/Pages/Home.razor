@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>ServantSync</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pb-8">
    <MudStack Spacing="4">
        <div>
            <MudText Typo="Typo.h3">Welcome to ServantSync</MudText>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                A volunteer database that handles org memberships, ministry sign-ups,
                training (video, slideshow, or PDF), and conflict-free scheduling.
            </MudText>
        </div>

        <AuthorizeView>
            <Authorized>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Ministries available</MudText>
                            @if (!_loaded)
                            {
                                <MudSkeleton Width="60%" Height="36px" />
                            }
                            else
                            {
                                <MudText Typo="Typo.h4">@_ministryCount</MudText>
                            }
                            <MudLink Href="Organizations" Typo="Typo.body2">Open organizations →</MudLink>
                        </MudPaper>
                    </MudItem>
                    @if (_isManager)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Outlined="true" Class="pa-4">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Volunteers</MudText>
                                @if (!_loaded)
                                {
                                    <MudSkeleton Width="60%" Height="36px" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.h4">@_personCount</MudText>
                                }
                                <MudLink Href="People" Typo="Typo.body2">Open directory →</MudLink>
                            </MudPaper>
                        </MudItem>
                    }
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">My pending training</MudText>
                            @if (!_loaded)
                            {
                                <MudSkeleton Width="60%" Height="36px" />
                            }
                            else
                            {
                                <MudText Typo="Typo.h4">@_myPending</MudText>
                            }
                            <MudLink Href="Training" Typo="Typo.body2">Open my training →</MudLink>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Outlined="true" Class="pa-4">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Next 30 days</MudText>
                            @if (!_loaded)
                            {
                                <MudSkeleton Width="60%" Height="36px" />
                            }
                            else
                            {
                                <MudText Typo="Typo.h4">@_myUpcoming</MudText>
                            }
                            <MudLink Href="MySchedule" Typo="Typo.body2">Open my schedule →</MudLink>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (_loaded)
                {
                    <MudPaper Outlined="true" Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-3">
                            <div>
                                <MudText Typo="Typo.h6">My ministries</MudText>
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                    Ministries you have opted to follow. Sign-up opportunities on these show up on
                                    <MudLink Href="Open">Browse open slots</MudLink>.
                                </MudText>
                            </div>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       Href="Organizations" StartIcon="@Icons.Material.Outlined.Explore">
                                Browse ministries
                            </MudButton>
                        </MudStack>

                        @if (!_hasAnyOrgMembership)
                        {
                            <WordmarkSplash Width="120" Loading="lazy" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2">
                                You're not yet a member of any organization, so there are no ministries to follow.
                            </MudText>
                        }
                        else if (_myMinistries.Count == 0)
                        {
                            <WordmarkSplash Width="120" Loading="lazy" />
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-2 mb-3">
                                You're not following any ministries yet. Tap "Join this ministry" on any ministry
                                page to start seeing its open shifts here.
                            </MudText>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                       Href="Organizations" StartIcon="@Icons.Material.Outlined.Explore">
                                Browse ministries in your organizations
                            </MudButton>
                        }
                        else
                        {
                            <MudList T="MinistryInterest" Dense="true">
                                @foreach (var mi in _myMinistries)
                                {
                                    <MudListItem T="MinistryInterest" Icon="@Icons.Material.Outlined.Church">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <div>
                                                <MudLink Href="@LinkBuilder.MinistryHref(mi.Ministry.OrganizationId, mi.MinistryId)">
                                                    <strong>@mi.Ministry.Name</strong>
                                                </MudLink>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">
                                                    in @mi.Ministry.Organization.Name
                                                </MudText>
                                            </div>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                                       Disabled="@(_busyLeaveId == mi.MinistryId)"
                                                       OnClick="@(() => LeaveFromHomeAsync(mi.MinistryId, mi.Ministry.Name))">
                                                @(_busyLeaveId == mi.MinistryId ? "Leaving…" : "Leave")
                                            </MudButton>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>

                    <MudPaper Outlined="true" Class="pa-4">
                        <MudStack Class="mb-3">
                            <MudText Typo="Typo.h6">Slots I'm subscribed to (@_mySubscribedSlots.Count)</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                Slots you have explicitly opted into. Their open shifts will show up under the
                                "My slots" filter on <MudLink Href="Open">Browse open slots</MudLink>.
                            </MudText>
                        </MudStack>

                        @if (_mySubscribedSlots.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                You haven't subscribed to any specific slots yet. Visit a slot's page (try one in the
                                ministry list above) and tap <strong>Subscribe to this slot</strong> to narrow the
                                Browse page to only that slot's shifts.
                            </MudText>
                        }
                        else
                        {
                            <MudList T="SlotInterest" Dense="true">
                                @foreach (var sub in _mySubscribedSlots)
                                {
                                    var slot = sub.ServiceSlot;
                                    var ministry = slot.Ministry;
                                    var orgId = ministry.OrganizationId;
                                    <MudListItem T="SlotInterest" Icon="@Icons.Material.Outlined.BookmarkAdded">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <div>
                                                <MudLink Href="@LinkBuilder.SlotHref(orgId, ministry.Id, slot.Id)">
                                                    <strong>@slot.Name</strong>
                                                </MudLink>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary ml-2">
                                                    in @ministry.Name
                                                </MudText>
                                            </div>
                                            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                                       Disabled="@(_busyLeaveSlotId == slot.Id)"
                                                       OnClick="@(() => LeaveSlotFromHomeAsync(slot.Id, slot.Name))">
                                                @(_busyLeaveSlotId == slot.Id ? "Leaving…" : "Unsubscribe")
                                            </MudButton>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>

                    @if (_lastMessage is not null)
                    {
                        <MudAlert Severity="@(_lastIsError ? Severity.Error : Severity.Success)" Dense="true" Class="mt-2">
                            @_lastMessage
                        </MudAlert>
                    }
                }
            </Authorized>
            <NotAuthorized>
                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="Account/Login" StartIcon="@Icons.Material.Outlined.Login">
                        Sign in
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="Account/Register" StartIcon="@Icons.Material.Outlined.PersonAdd">
                        Register
                    </MudButton>
                </MudStack>
            </NotAuthorized>
        </AuthorizeView>
    </MudStack>
</MudContainer>

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject ITrainingService TrainingService
@inject IMinistryInterestService MinistryInterest
@inject ISlotInterestService Slots
@inject IOrgAuthService OrgAuth
@code {
    // State and RBAC are unchanged from the prior Home.razor — every field
    // and method's semantics match the original; only the markup was
    // reshaped to MudBlazor. See `Components/Pages/Home.razor` git
    // history for the Promise.foundation migration context.
    private int _ministryCount, _personCount, _myPending, _myUpcoming;
    private bool _loaded;
    private bool _isManager;
    private List<MinistryInterest> _myMinistries = new();
    private bool _hasAnyOrgMembership = true;
    private int _busyLeaveId;
    private List<SlotInterest> _mySubscribedSlots = new();
    private int _busyLeaveSlotId;
    private string? _lastMessage;
    private bool _lastIsError;

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(userId))
        {
            _loaded = true;
            return;
        }

        _isManager = await OrgAuth.IsAnyOrgManagerAsync(userId);

        await using var db = await DbFactory.CreateDbContextAsync();

        var myOrgIds = await db.OrganizationMemberships
            .Where(m => m.PersonUserId == userId)
            .Select(m => m.OrganizationId)
            .ToListAsync();
        _ministryCount = myOrgIds.Count > 0
            ? await db.Ministries.CountAsync(m => myOrgIds.Contains(m.OrganizationId))
            : 0;

        _personCount = _isManager ? await db.People.CountAsync() : 0;

        var fromUtc = DateTime.UtcNow;
        var toUtc = fromUtc.AddDays(30);
        _myUpcoming = await db.Assignments
            .CountAsync(a => a.PersonUserId == userId
                && a.StartUtc >= fromUtc && a.StartUtc < toUtc
                && a.Status != AssignmentStatus.Cancelled);

        var outstanding = await TrainingService.FindMyOutstandingRequirementsAsync(userId);
        _myPending = outstanding.Count;
        _hasAnyOrgMembership = outstanding.Count > 0
            || (await db.OrganizationMemberships
                .AnyAsync(m => m.PersonUserId == userId));

        _myMinistries = await MinistryInterest.ListJoinedAsync(userId);
        _mySubscribedSlots = await Slots.ListSubscribedAsync(userId);

        _loaded = true;
    }

    private async Task LeaveFromHomeAsync(int ministryId, string ministryName)
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busyLeaveId = ministryId;
        _lastMessage = null;
        try
        {
            var result = await MinistryInterest.LeaveAsync(userId, userId, ministryId);
            switch (result)
            {
                case MinistryInterestLeaveResult.Left:
                case MinistryInterestLeaveResult.NotInterested:
                    _myMinistries = _myMinistries.Where(m => m.MinistryId != ministryId).ToList();
                    _lastIsError = false;
                    _lastMessage = $"You stopped following {ministryName}.";
                    break;
                case MinistryInterestLeaveResult.PermissionDenied:
                    _lastIsError = true;
                    _lastMessage = "You can only stop following ministries in organizations you belong to.";
                    break;
                case MinistryInterestLeaveResult.MinistryNotFound:
                    _lastIsError = true;
                    _lastMessage = "This ministry no longer exists.";
                    break;
            }
        }
        finally
        {
            _busyLeaveId = 0;
        }
    }

    private async Task LeaveSlotFromHomeAsync(int slotId, string slotName)
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) return;

        _busyLeaveSlotId = slotId;
        _lastMessage = null;
        try
        {
            var result = await Slots.UnsubscribeAsync(userId, userId, slotId);
            switch (result)
            {
                case SlotInterestLeaveResult.Unsubscribed:
                case SlotInterestLeaveResult.NotSubscribed:
                    _mySubscribedSlots = _mySubscribedSlots.Where(s => s.ServiceSlotId != slotId).ToList();
                    _lastIsError = false;
                    _lastMessage = $"You stopped subscribing to {slotName}. Its shifts will no longer show up under \"My slots\" on the Browse page.";
                    break;
                case SlotInterestLeaveResult.PermissionDenied:
                    _lastIsError = true;
                    _lastMessage = "You can only stop subscribing to slots in organizations you belong to.";
                    break;
                case SlotInterestLeaveResult.SlotNotFound:
                    _lastIsError = true;
                    _lastMessage = "This slot no longer exists.";
                    break;
            }
        }
        finally
        {
            _busyLeaveSlotId = 0;
        }
    }
}
