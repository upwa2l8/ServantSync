@page "/Open"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Browse open slots</PageTitle>

<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Browse open slots</li>
    </ol>
</nav>

<h1>Browse open slots</h1>
<p class="text-muted">
    Open shifts that coordinators have queued for your organizations. Sign-up is
    immediate — the slot becomes <strong>Scheduled</strong> on your
    <a href="MySchedule">My schedule</a> right away. Missing training will block
    the sign-up button so the coordinator can route you to the right content.
</p>

@* Round-FR-7: the 3-way pill-segment below combines three orthogonal
   filters. The volunteer picks the narrowness: "All slots" (every open
   shift across the user's orgs), "My ministries" (only shifts from
   MinistryInterest rows), or "My slots" (only shifts from SlotInterest
   rows). The first paint auto-selects based on which preference set the
   user has populated; subsequent clicks override and persist for the
   rest of the session (no cross-session persistence in round 1). The
   org picker still scopes each option when set. *@
@if (_userIdPresent && _hasMembership && !_loading)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <div class="btn-group" role="group" aria-label="Filter open shifts by scope">
                <button type="button"
                        class="btn btn-sm @(_filterMode == OpenSlotFilterMode.MySlots ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SetFilterMode(OpenSlotFilterMode.MySlots)"
                        title="Show only open shifts for slots you have explicitly subscribed to">
                    My slots (@_subscribedSlotIds.Count)
                </button>
                <button type="button"
                        class="btn btn-sm @(_filterMode == OpenSlotFilterMode.MyMinistries ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SetFilterMode(OpenSlotFilterMode.MyMinistries)"
                        title="Show only open shifts from ministries you have joined">
                    My ministries (@_joinedMinistryIds.Count)
                </button>
                <button type="button"
                        class="btn btn-sm @(_filterMode == OpenSlotFilterMode.AllSlots ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SetFilterMode(OpenSlotFilterMode.AllSlots)"
                        title="Show every open shift across every ministry in your organizations">
                    All slots
                </button>
            </div>
            <select class="form-select form-select-sm" style="width:auto" @bind="_selectedOrgId" @bind:after="OnOrgChanged">
                <option value="0">All organizations (@_orgs.Count)</option>
                @foreach (var o in _orgs)
                {
                    <option value="@o.Id">@o.Name</option>
                }
            </select>
        </div>
        @if (_subscribedSlotIds.Count > 0 || _joinedMinistryIds.Count > 0)
        {
            <a class="btn btn-sm btn-outline-secondary" href="@OrgLink">Manage my subscriptions</a>
        }
    </div>
}

@if (_loading)
{
    <p><em>Loading…</em></p>
}
else if (!_userIdPresent)
{
    <div class="alert alert-warning">You need to be signed in to see open slots.</div>
}
else if (!_hasMembership)
{
    @* Wordmark above the no-membership empty-state. Parallel to
       the Home no-org splash. See WordmarkSplash. *@
    <WordmarkSplash Width="120" Loading="lazy" />
    <div class="alert alert-info">
        You're not a member of any organization yet. Once an Admin invites you,
        open slots from that org will show up here.
    </div>
}
else if (_filterMode == OpenSlotFilterMode.MySlots && _subscribedSlotIds.Count == 0)
{
    @* "My slots" filter applied + zero slot-level subscriptions → the
       user has explicitly opted into slot-level filtering but has no
       data to show. Distinct empty-state CTA so the user can either
       widen the scope OR subscribe to a slot from another surface. *@
    <WordmarkSplash Width="120" Loading="lazy" />
    <div class="alert alert-info">
        <h6 class="alert-heading mb-2">You haven't subscribed to any slots yet</h6>
        <p class="mb-2">
            Turn on slot-level filtering to see only shifts for slots you specifically want.
            Visit a slot's detail page and tap <strong>Subscribe</strong>, or browse the ministry
            page to subscribe to one or two slots at a time.
        </p>
        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="() => SetFilterMode(OpenSlotFilterMode.AllSlots)">
            Switch to All slots
        </button>
    </div>
}
else if (_filterMode == OpenSlotFilterMode.MyMinistries && _joinedMinistryIds.Count == 0)
{
    @* Filter-induced empty-state (NOT data-empty): the user toggled
       the "My ministries" pill-segment and the joined set is empty,
       so the filter provably has nothing to show. Distinct from the
       data-empty branches above (no membership / no shifts queued) in
       that the user has agency — switching to "All slots" or
       following one ministry re-populates the page. The wordmark
       stays for brand consistency but the WHY here names the
       distinction so the next maintainer doesn't read
       "0 results + wordmark = optimism" and quietly tone it down. *@
    <WordmarkSplash Width="120" Loading="lazy" />
    <div class="alert alert-info">
        <h6 class="alert-heading mb-2">You haven't joined any ministries yet</h6>
        <p class="mb-2">
            You're filtering to your followed ministries, but you haven't followed any. Switch to <strong>All slots</strong> to see everything, or pick a few ministries from your organizations.
        </p>
        <a class="btn btn-primary btn-sm" href="/">Pick ministries to follow</a>
        <button class="btn btn-outline-secondary btn-sm ms-2" type="button" @onclick="() => SetFilterMode(OpenSlotFilterMode.AllSlots)">
            Switch to All slots
        </button>
    </div>
}
else if (!_openShifts.Any())
{
    @* Wordmark above the no-shifts empty-state. *@
    <WordmarkSplash Width="120" Loading="lazy" />
    <div class="alert alert-info">
        Nothing open @EmptyMessageSuffix(). Check back later, or ask a coordinator to queue a shift for a slot you care about.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var s in _openShifts)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-1">@s.SlotName</h5>
                        <div class="text-muted small mb-2">
                            <a href="Organizations/@s.OrganizationId">@s.MinistryName</a>
                        </div>
                        <p class="mb-2">
                            @* Format is wrapped in @("…") so Razor evaluates the C#
                               string literal and resolves the \u2022 Unicode escape
                               into an actual bullet ( • ) character. Without the
                               @(...) wrapper, Razor treats the attribute as a plain
                               HTML value and the literal six characters "\u2022"
                               pass through to DateTime.ToString, which renders them
                               as plain text "u2022" instead of the bullet. The wrap
                               preserves the user's design intent (keep the bullet)
                               per the round-AV design decision. *@
                            <strong><LocalTime Utc="@s.StartUtc" Format="@("ddd, MMM d \u2022 h:mm tt")" FallbackTimeZoneId="@s.OrganizationTimeZoneId" /></strong>
                            &ndash; <LocalTime Utc="@s.EndUtc" Format="h:mm tt" FallbackTimeZoneId="@s.OrganizationTimeZoneId" />
                            @if (!string.IsNullOrEmpty(s.Location))
                            {
                                <span class="text-muted small ms-2">@s.Location</span>
                            }
                        </p>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="badge bg-secondary">
                                @s.SignedUpCount / @s.Capacity signed up
                            </span>
                            @if (s.SignedUpCount + 1 >= s.Capacity)
                            {
                                <span class="badge bg-warning text-dark">Last spot</span>
                            }
                        </div>
                        @if (!s.TrainingCompliant)
                        {
                            <div class="alert alert-warning py-2 small mb-2">
                                Training required before signing up:
                                <ul class="mb-0">
                                    @foreach (var t in s.MissingTrainings)
                                    {
                                        <li>@t</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        @* Per-card Subscribe/Unsubscribe toggle (Round-FR-7).
                           The button label flips based on local
                           _subscribedSlotIds membership. Click optimistically
                           mutates the local cache; the service call below
                           reconciles with the DB. On error the cache is undone
                           so the UI stays in sync with the DB. *@
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            @if (_subscribedSlotIds.Contains(s.ServiceSlotId))
                            {
                                <button class="btn btn-sm btn-outline-success flex-grow-1"
                                        disabled="@(_busySlotId == s.ServiceSlotId)"
                                        @onclick="() => ToggleSlotSubscriptionAsync(s.ServiceSlotId, s.SlotName)"
                                        title="Stop including this slot's shifts in the My slots filter">
                                    <span class="bi bi-check-circle-fill me-1" aria-hidden="true"></span>
                                    @(_busySlotId == s.ServiceSlotId ? "Updating…" : "Subscribed")
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary flex-grow-1"
                                        disabled="@(_busySlotId == s.ServiceSlotId || !_inAnyOrgForSlot.Contains(s.OrganizationId))"
                                        @onclick="() => ToggleSlotSubscriptionAsync(s.ServiceSlotId, s.SlotName)"
                                        title="@(_inAnyOrgForSlot.Contains(s.OrganizationId) ? "Add this slot's shifts to the My slots filter" : "You can only subscribe to slots in organizations you belong to")">
                                    @(_busySlotId == s.ServiceSlotId ? "Updating…" : (IsSubFilterActive() ? "Subscribe to keep in My slots" : "Subscribe"))
                                </button>
                            }
                            @if (_lastSlotError is not null && _lastSlotError.SlotId == s.ServiceSlotId)
                            {
                                <span class="text-danger small" role="alert">@_lastSlotError.Message</span>
                            }
                        </div>
                        @if (!_joinedMinistryIds.Contains(s.MinistryId))
                        {
                            <button class="btn btn-outline-primary w-100"
                                    disabled="@(!s.TrainingCompliant || _busyId == s.OccurrenceId)"
                                    @onclick="() => JoinAndSignUp(s)">
                                @(_busyId == s.OccurrenceId
                                    ? "Joining\u2026"
                                    : (s.TrainingCompliant ? "Join ministry and sign up" : "Update training to sign up"))
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-primary w-100"
                                    disabled="@(!s.TrainingCompliant || _busyId == s.OccurrenceId)"
                                    @onclick="() => SignUp(s)">
                                @(_busyId == s.OccurrenceId
                                    ? "Signing up\u2026"
                                    : (s.TrainingCompliant ? "Sign up" : "Update training to sign up"))
                            </button>
                        }
                        @if (_lastResult is not null && _lastResult.Id == s.OccurrenceId)
                        {
                            <div class="alert @(_lastResult.Succeeded ? "alert-success" : "alert-danger") py-2 small mt-2 mb-0">
                                @_lastResult.Message
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IAssignmentService AssignmentService
@inject IMinistryInterestService MinistryInterest
@inject ISlotInterestService Slots
@inject AuthenticationStateProvider Auth
@inject UserTimeZoneProvider TzProvider
@code {
    // Round-FR-7: 3-way filter mode. Default on first paint is
    // AllSlots; the first Reload after auth-resolved flips it to the
    // most-populated preference set (slots first, then ministries) so
    // a user with explicit slot subscriptions sees their shifts
    // rather than the broader ministry-driven list. After that the
    // filter is fully user-controlled.
    private enum OpenSlotFilterMode { AllSlots, MyMinistries, MySlots }

    private bool _loading = true;
    private string? _userId;
    private bool _userIdPresent;
    private bool _hasMembership;
    private List<OpenSlotOccurrenceView> _openShifts = new();
    private int _busyId;
    private SignupResult? _lastResult;
    private OpenSlotFilterMode _filterMode = OpenSlotFilterMode.AllSlots;
    // True when the volunteer has interacted with the filter at least
    // once during this session — separates "first paint auto-default"
    // from "user-chosen mode" so subsequent Reloads (e.g., after
    // sign-up) don't snap the filter back to a different default.
    private bool _filterModeUserChosen;

    // Cached joined-ministry ids, populated alongside the open-shifts
    // query in Reload. Drives the empty-state CTA and the pill-segment
    // count badge.
    private HashSet<int> _joinedMinistryIds = new();
    // Round-FR-7: cached slot-level subscription set. Driven by
    // ISlotInterestService.ListSubscribedAsync(userId) in Reload. The
    // per-card Subscribe toggle reads + writes this set optimistically;
    // errors revert.
    private HashSet<int> _subscribedSlotIds = new();
    // Cross-org sandbox pre-check: a volunteer can only subscribe to
    // a slot if they belong to the slot's parent org. We precompute
    // this set in Reload so the per-card Subscribe button can disable
    // itself cleanly without round-tripping the service for every
    // card click.
    private HashSet<int> _inAnyOrgForSlot = new();
    // In-flight tracking for the per-card Subscribe button so only the
    // clicked card's button shows the spinner.
    private int _busySlotId;
    // Surface Subscribe failures inline next to the card button rather
    // than in a page-level alert (which would lose the row-anchor).
    private SlotSubscribeError? _lastSlotError;
    private record SlotSubscribeError(int SlotId, string Message);

    // Org picker: user's organization memberships (id + name) and the
    // currently selected org. 0 = "All organizations" (no org filter).
    // Cached set of every org the user belongs to (independent of the
    // picker) so the per-card Subscribe button can do a fast in-org
    // membership lookup.
    // Public so EF Core can access the constructor during query projection.
    public record OrgItem(int Id, string Name);
    private List<OrgItem> _orgs = new();
    private int _selectedOrgId;
    private HashSet<int> _myOrgIds = new();
    // Cached active ministry IDs for the currently selected org.
    // Populated in Reload when _selectedOrgId > 0; drives org-scoped
    // filtering for both "My ministries" and "All slots" modes.
    private HashSet<int> _orgMinistryIds = new();

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task SetFilterMode(OpenSlotFilterMode mode)
    {
        if (_filterMode == mode && _filterModeUserChosen) return;
        _filterMode = mode;
        _filterModeUserChosen = true;
        await Reload();
    }

    private bool IsSubFilterActive() => _filterMode == OpenSlotFilterMode.MySlots;

    // Link target for "Manage my ministries" button. When a specific
    // org is selected, goes directly to that org's detail page
    // (Ministries tab). Otherwise links to the org listing.
    private string OrgLink => _selectedOrgId > 0
        ? $"Organizations/{_selectedOrgId}"
        : "Organizations";

    private async Task OnOrgChanged()
    {
        await Reload();
    }

    /// <summary>
    /// Monotonic counter incremented on every Reload entry. Each call
    /// captures <c>version</c> at entry; on exit it compares against the
    /// latest. If they differ, a more recent Reload has started and this
    /// one is stale — its prospective writes would otherwise lose to a
    /// fresh call.
    /// </summary>
    private int _reloadVersion;

    /// <summary>
    /// Re-query the open-shifts list (joined ministries + slot-level
    /// subscriptions + filter pill). Race-safe against rapid pill clicks
    /// / SignUp-triggered re-runs: each invocation captures a
    /// <see cref="_reloadVersion"/> at entry, reads every result into a
    /// LOCAL, and only commits to Blazor fields after passing the FINAL
    /// version guard. A stale Reload that loses the race simply
    /// abandons its locals without ever mutating the bound fields.
    /// <para>
    /// We deliberately don't pass a <see cref="CancellationToken"/> to the
    /// awaits: doing so risks an unhandled
    /// <see cref="OperationCanceledException"/> surfacing as a runtime
    /// error in Blazor's interactive-server circuit when one Reload
    /// cancels another. The version-token pattern achieves the same
    /// outcome without the OCE surface.
    /// </para>
    /// </summary>
    private async Task Reload()
    {
        var version = System.Threading.Interlocked.Increment(ref _reloadVersion);
        bool iAmLatest() => version == _reloadVersion;

        _loading = true;
        try
        {
            var state = await Auth.GetAuthenticationStateAsync();
            if (!iAmLatest()) return;

            var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
            var userIdPresent = !string.IsNullOrEmpty(userId);

            if (!userIdPresent)
            {
                if (!iAmLatest()) return;
                _userId = userId;
                _userIdPresent = false;
                _lastResult = null;
                _hasMembership = false;
                _openShifts = new();
                _joinedMinistryIds = new();
                _subscribedSlotIds = new();
                _orgs = new();
                _myOrgIds = new();
                _inAnyOrgForSlot = new();
                _orgMinistryIds = new();
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            if (!iAmLatest()) return;

            // Track every org the user belongs to (cached locally so the
            // per-card Subscribe button can disable itself for out-of-org
            // slots without re-querying).
            var myOrgIds = await db.OrganizationMemberships
                .Where(m => m.PersonUserId == userId)
                .Select(m => m.OrganizationId)
                .ToListAsync();
            if (!iAmLatest()) return;
            var myOrgIdsSet = myOrgIds.ToHashSet();
            var hasMembership = myOrgIdsSet.Count > 0;

            // Fetch org memberships with names for the org picker dropdown.
            // OrderBy comes before Select so EF Core can translate the
            // sort to SQL. After projecting into the OrgItem record,
            // EF Core can't trace property access back to DB columns.
            var orgs = await db.OrganizationMemberships
                .Where(m => m.PersonUserId == userId)
                .OrderBy(m => m.Organization.Name)
                .Select(m => new OrgItem(m.OrganizationId, m.Organization.Name))
                .ToListAsync();
            if (!iAmLatest()) return;

            // Refresh the joined-ministry id set each time so the pill
            // count and the empty-state CTA track any join/leave the
            // user just made elsewhere (e.g., on Home or on Ministries/Detail).
            var joined = await MinistryInterest.ListJoinedAsync(userId);
            if (!iAmLatest()) return;

            // Round-FR-7: refresh slot-level subscription set so the per-card
            // Subscribe button and the "My slots" filter pill each see the
            // authoritative list.
            var subs = await Slots.ListSubscribedAsync(userId);
            if (!iAmLatest()) return;

            // If a specific org is selected, fetch its active ministry IDs
            // so we can scope all three filter modes to that org.
            // Otherwise (_selectedOrgId == 0), leave it empty and the
            // service-scoped query will cover all user orgs.
            HashSet<int> orgMinistryIds;
            if (_selectedOrgId > 0)
            {
                var ids = await db.Ministries
                    .Where(m => m.OrganizationId == _selectedOrgId)
                    .Select(m => m.Id)
                    .ToListAsync();
                if (!iAmLatest()) return;
                orgMinistryIds = ids.ToHashSet();
            }
            else
            {
                orgMinistryIds = new();
            }

            // 90-day forward window matches the MySchedule default chip.
            var fromUtc = DateTime.UtcNow;
            var toUtc = fromUtc.AddDays(90);

            // Filter assembly based on the 3-way filter mode.
            //   AllSlots        → no ministry / slot narrowing (both null)
            //   MyMinistries    → ministry narrowing only
            //   MySlots         → slot narrowing only
            // The selected org picker further narrows the ministry / slot
            // sets when set.
            var joinedIds = joined.Select(i => i.MinistryId).ToHashSet();
            var subscribedIds = subs.Select(s => s.ServiceSlotId).ToHashSet();

            IReadOnlyCollection<int>? ministryFilter = null;
            IReadOnlyCollection<int>? slotFilter = null;

            switch (_filterMode)
            {
                case OpenSlotFilterMode.MyMinistries:
                    if (joinedIds.Count > 0)
                    {
                        if (_selectedOrgId > 0)
                        {
                            ministryFilter = joinedIds.Where(id => orgMinistryIds.Contains(id)).ToHashSet();
                        }
                        else
                        {
                            ministryFilter = joinedIds;
                        }
                    }
                    break;
                case OpenSlotFilterMode.MySlots:
                    if (subscribedIds.Count > 0)
                    {
                        if (_selectedOrgId > 0)
                        {
                            // Org-scoped slot filter: every slot in the
                            // selected org + every slot whose ministry is
                            // one of the org's ministries.
                            var orgSlotIds = await db.ServiceSlots
                                .Where(s => s.Ministry.OrganizationId == _selectedOrgId)
                                .Select(s => s.Id)
                                .ToListAsync();
                            if (!iAmLatest()) return;
                            slotFilter = orgSlotIds.Intersect(subscribedIds).ToHashSet();
                        }
                        else
                        {
                            slotFilter = subscribedIds;
                        }
                    }
                    break;
                case OpenSlotFilterMode.AllSlots:
                default:
                    // Both null = no narrowing.
                    break;
            }

            // Sentinel: when the org has no entries for the active filter
            // (e.g., selected an org with no joined ministries while in
            // MyMinistries mode AND the user has no joined ministries in
            // that org), force zero rows instead of falling back to
            // "all my orgs" via the empty-filter short circuit the
            // service applies.
            if (_filterMode == OpenSlotFilterMode.MyMinistries
                && ministryFilter is { Count: 0 })
            {
                ministryFilter = new HashSet<int> { -1 };
            }
            if (_filterMode == OpenSlotFilterMode.MySlots
                && slotFilter is { Count: 0 })
            {
                slotFilter = new HashSet<int> { -1 };
            }

            var openShifts = await AssignmentService.ListOpenSlotOccurrencesAsync(userId, fromUtc, toUtc, ministryFilter, slotFilter);

            if (!iAmLatest()) return;

            // First-paint auto-default: on the very first load (before
            // the user has clicked any pill) pick the most-populated
            // preference set so the page lands on what they care about.
            // MySlots wins over MyMinistries when both have rows so the
            // narrower, more-explicit preference signals take priority.
            if (!_filterModeUserChosen)
            {
                if (subscribedIds.Count > 0)
                {
                    _filterMode = OpenSlotFilterMode.MySlots;
                }
                else if (joinedIds.Count > 0)
                {
                    _filterMode = OpenSlotFilterMode.MyMinistries;
                }
                else
                {
                    _filterMode = OpenSlotFilterMode.AllSlots;
                }
            }

            // ---- Commit ---- every prior iAmLatest() check has passed,
            // so this Reload is the most recent run and its locals can
            // safely flow into the Blazor-bound fields.
            _userId = userId;
            _userIdPresent = true;
            _lastResult = null;
            _hasMembership = hasMembership;
            _myOrgIds = myOrgIdsSet;
            _orgs = orgs;
            _orgMinistryIds = orgMinistryIds;
            _joinedMinistryIds = joinedIds;
            _subscribedSlotIds = subscribedIds;
            _inAnyOrgForSlot = myOrgIdsSet;
            _openShifts = openShifts.ToList();
        }
        finally
        {
            // Only the latest Reload owns _loading — otherwise a slow,
            // lost-race Reload would clobber a newer one's _loading=true.
            if (iAmLatest()) _loading = false;
        }
    }

    private string EmptyMessageSuffix()
    {
        if (_filterMode == OpenSlotFilterMode.MySlots && _subscribedSlotIds.Count > 0)
            return " in slots you're subscribed to";
        if (_filterMode == OpenSlotFilterMode.MyMinistries && _joinedMinistryIds.Count > 0)
            return " in your followed ministries";
        return "";
    }

    /// <summary>
    /// Sign-up for a shift. After the assignment succeeds, fan out an
    /// auto-subscribe to the underlying slot (Round-FR-7 spec Q1 YES
    /// decision) so the volunteer's "My slots" filter automatically
    /// captures this slot — the next visit to /Open preserves their
    /// preference without requiring a second click. Silent on
    /// AlreadySubscribed (idempotent); any other result is ignored so
    /// the volunteer doesn't see a confusing toast about a non-blocking
    /// preference write that the coordinator-side roster surfaces on
    /// next page load anyway.
    /// </summary>
    private async Task SignUp(OpenSlotOccurrenceView s)
    {
        if (string.IsNullOrEmpty(_userId)) return;
        _busyId = s.OccurrenceId;
        _lastResult = null;
        try
        {
            // Use the existing AssignAsync path so the same validation
            // (conflict + missing training + capacity) applies uniformly.
            var result = await AssignmentService.AssignAsync(_userId, s.ServiceSlotId, s.StartUtc, s.EndUtc);
            if (result.Succeeded)
            {
                _lastResult = new SignupResult(s.OccurrenceId, true,
                    $"You're signed up for {s.SlotName} on {s.StartUtc:ddd, MMM d h:mm tt}.");

                // Round-FR-7 cross-service fan-out: auto-subscribe to the
                // underlying slot with the AutoFromAssignment source so
                // round-2 audit / data-quality tooling can distinguish
                // coordinator-driven AssignAsync writes from volunteer-driven
                // /Open sign-ups. Silent on AlreadySubscribed (idempotent
                // double-click case).
                await Slots.SubscribeAsync(_userId, _userId, s.ServiceSlotId, SlotInterestSource.AutoFromAssignment);

                await Reload();
            }
            else
            {
                var why = result.Conflicts.FirstOrDefault() ?? result.MissingTrainings.FirstOrDefault()
                    ?? "Unable to sign up.";
                _lastResult = new SignupResult(s.OccurrenceId, false, why);
            }
        }
        finally
        {
            _busyId = 0;
        }
    }

    private async Task JoinAndSignUp(OpenSlotOccurrenceView s)
    {
        if (string.IsNullOrEmpty(_userId)) return;
        _busyId = s.OccurrenceId;
        _lastResult = null;
        try
        {
            var joinResult = await MinistryInterest.JoinAsync(_userId, _userId, s.MinistryId);
            if (joinResult is MinistryInterestJoinResult.PermissionDenied or MinistryInterestJoinResult.MinistryNotFound)
            {
                _lastResult = new SignupResult(s.OccurrenceId, false,
                    "Couldn't join this ministry. You may not be a member of its organization.");
                return;
            }
            // Now sign up for the shift.
            var result = await AssignmentService.AssignAsync(_userId, s.ServiceSlotId, s.StartUtc, s.EndUtc);
            if (result.Succeeded)
            {
                _lastResult = new SignupResult(s.OccurrenceId, true,
                    $"You joined {s.MinistryName} and signed up for {s.SlotName} on {s.StartUtc:ddd, MMM d h:mm tt}.");

                // Round-FR-7 cross-service fan-out mirrors SignUp's.
                await Slots.SubscribeAsync(_userId, _userId, s.ServiceSlotId, SlotInterestSource.AutoFromAssignment);

                await Reload();
            }
            else
            {
                var why = result.Conflicts.FirstOrDefault() ?? result.MissingTrainings.FirstOrDefault()
                    ?? "Unable to sign up.";
                _lastResult = new SignupResult(s.OccurrenceId, false, why);
            }
        }
        finally
        {
            _busyId = 0;
        }
    }

    /// <summary>
    /// Per-card Subscribe / Unsubscribe toggle handler. Optimistically
    /// flips the local _subscribedSlotIds cache so the button label
    /// updates instantly; on a server refusal (PermissionDenied etc.) we
    /// revert and surface the error inline.
    /// </summary>
    private async Task ToggleSlotSubscriptionAsync(int slotId, string slotNameForError)
    {
        if (string.IsNullOrEmpty(_userId)) return;

        var wasSubscribed = _subscribedSlotIds.Contains(slotId);
        _busySlotId = slotId;
        _lastSlotError = null;
        try
        {
            if (wasSubscribed)
            {
                _subscribedSlotIds.Remove(slotId);  // optimistic flip
                var result = await Slots.UnsubscribeAsync(_userId, _userId, slotId);
                if (result == SlotInterestLeaveResult.PermissionDenied)
                {
                    _subscribedSlotIds.Add(slotId);  // revert
                    _lastSlotError = new SlotSubscribeError(slotId, "You can only stop subscribing to slots in organizations you belong to.");
                }
                else if (result == SlotInterestLeaveResult.SlotNotFound)
                {
                    _subscribedSlotIds.Add(slotId);  // revert
                    _lastSlotError = new SlotSubscribeError(slotId, "This slot no longer exists.");
                }
            }
            else
            {
                _subscribedSlotIds.Add(slotId);  // optimistic flip
                var result = await Slots.SubscribeAsync(_userId, _userId, slotId, SlotInterestSource.Explicit);
                if (result == SlotInterestJoinResult.PermissionDenied)
                {
                    _subscribedSlotIds.Remove(slotId);  // revert
                    _lastSlotError = new SlotSubscribeError(slotId, "You can only subscribe to slots in organizations you belong to.");
                }
                else if (result == SlotInterestJoinResult.SlotNotFound)
                {
                    _subscribedSlotIds.Remove(slotId);  // revert
                    _lastSlotError = new SlotSubscribeError(slotId, "This slot no longer exists.");
                }
            }
        }
        finally
        {
            _busySlotId = 0;
        }
    }

    private record SignupResult(int Id, bool Succeeded, string Message);
}
