@page "/Leagues/{MinistryId:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_ministry?.Name ?? "League")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (_ministry is null)
{
    <MudText><em>Loading…</em></MudText>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h4">@_ministry.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@_ministry.Organization.Name · @_ministry.Description</MudText>
        </div>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            @if (_isOrgAdmin)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="@LinkBuilder.MinistryEditHref(_ministry.OrganizationId, MinistryId)">Edit ministry</MudButton>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@LinkBuilder.LeagueStandingsHref(MinistryId)">Full standings</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@LinkBuilder.LeagueScheduleHref(MinistryId)">Schedule</MudButton>
        </MudStack>
    </MudStack>

    @if (_canManage)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <span>You can manage this league.</span>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Href="@LinkBuilder.TeamNewHref(MinistryId)">+ Add team</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Href="@LinkBuilder.GameNewHref(MinistryId)">+ Schedule a game</MudButton>
            </MudStack>
        </MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" md="7">
            <MudCard>
                <MudCardHeader>Teams</MudCardHeader>
                <MudCardContent>
                    @if (!_ministry.Teams.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No teams yet.</MudText>
                    }
                    else
                    {
                        <MudList T="Team">
                            @foreach (var t in _ministry.Teams.OrderBy(t => t.AgeBracket).ThenBy(t => t.Name))
                            {
                                <MudListItem>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudLink Href="@LinkBuilder.TeamHref(t.Id)">@t.Name</MudLink>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            @t.AgeBracket · @t.Gender · coach: @(t.CoachPerson?.DisplayName ?? "—")
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>

            <MudCard Class="mt-3">
                <MudCardHeader>Upcoming games</MudCardHeader>
                <MudCardContent>
                    @if (!_upcomingGames.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No upcoming games.</MudText>
                    }
                    else
                    {
                        <MudList T="Game">
                            @foreach (var g in _upcomingGames)
                            {
                                <MudListItem>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudLink Href="@LinkBuilder.GameHref(g.Id)">@g.HomeTeam.Name vs @g.AwayTeam.Name</MudLink>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            <LocalTime Utc="@g.StartUtc" Format="ddd, MMM d h:mm tt" /> · @g.Arena.Name
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>

            @if (_ministry.SubMinistries.Any())
            {
                <MudCard Class="mt-3">
                    <MudCardHeader>Sub-ministries (coordinated separately)</MudCardHeader>
                    <MudCardContent>
                        <MudList T="Ministry">
                            @foreach (var s in _ministry.SubMinistries.OrderBy(s => s.Name))
                            {
                                <MudListItem>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <span>@s.Name</span>
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                            coordinator: @(s.CoordinatorPerson?.DisplayName ?? "—") · @s.ServiceSlots.Count slots
                                        </MudText>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>

        <MudItem xs="12" md="5">
            <MudCard>
                <MudCardHeader>Top of standings</MudCardHeader>
                <MudCardContent>
                    @if (!_topStandings.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No games played yet.</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Hover="true" Striped="true" Dense="true" Bordered="false">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Team</th>
                                    <th>P</th>
                                    <th>W-D-L</th>
                                    <th>GD</th>
                                    <th>Pts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < _topStandings.Count; i++)
                                {
                                    var s = _topStandings[i];
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td><MudLink Href="@LinkBuilder.TeamHref(s.TeamId)">@s.TeamName</MudLink></td>
                                        <td>@s.Played</td>
                                        <td>@s.Wins-@s.Draws-@s.Losses</td>
                                        <td>@(s.GoalDifference > 0 ? "+" : "")@s.GoalDifference</td>
                                        <td><strong>@s.Points</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mt-2" Href="@LinkBuilder.LeagueStandingsHref(MinistryId)">Full table</MudButton>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IStandingsService Standings
@inject IOrgAuthService OrgAuth
@inject AuthenticationStateProvider Auth
@code {
    [Parameter] public int MinistryId { get; set; }
    private Ministry? _ministry;
    private List<Game> _upcomingGames = new();
    private List<TeamStanding> _topStandings = new();
    private bool _canManage;
    // Narrower admin-only gate for Edit ministry (target page requires
    // IsOrgAdminAsync). Distinct from _canManage (CanManageMinistryAsync)
    // which is the right gate for Add team / Schedule game.
    private bool _isOrgAdmin;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the route param so it stays
    // in sync if the user navigates between leagues.
    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem("Home", href: LinkBuilder.HomeHref()),
        new BreadcrumbItem("Leagues", href: LinkBuilder.LeaguesHref()),
        new BreadcrumbItem(_ministry?.Name ?? $"League #{MinistryId}", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        await using var db = await DbFactory.CreateDbContextAsync();
        _ministry = await db.Ministries
            .Include(m => m.Organization)
            .Include(m => m.Teams).ThenInclude(t => t.CoachPerson)
            .Include(m => m.SubMinistries).ThenInclude(s => s.CoordinatorPerson)
            .Include(m => m.SubMinistries).ThenInclude(s => s.ServiceSlots)
            .AsNoTracking()
            .FirstOrDefaultAsync(m => m.Id == MinistryId);

        if (_ministry is null) return;

        var fromUtc = DateTime.UtcNow;
        _upcomingGames = await db.Games
            .Include(g => g.HomeTeam)
            .Include(g => g.AwayTeam)
            .Include(g => g.Arena)
            .Where(g => g.MinistryId == MinistryId
                && g.StartUtc >= fromUtc
                && g.Status == GameStatus.Scheduled)
            .OrderBy(g => g.StartUtc)
            .Take(8)
            .AsNoTracking()
            .ToListAsync();

        _topStandings = (await Standings.CalculateForMinistryAsync(MinistryId)).Take(5).ToList();

        if (!string.IsNullOrEmpty(userId))
        {
            _canManage = await OrgAuth.CanManageMinistryAsync(userId, MinistryId);
            _isOrgAdmin = await OrgAuth.IsOrgAdminAsync(userId, _ministry.OrganizationId);
        }
    }
}
