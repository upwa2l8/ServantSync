@page "/Leagues"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Leagues</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-2">Leagues</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    @if (_isSystemAdmin)
    {
        <text>Every league across every organization (SystemAdmin view).</text>
    }
    else
    {
        <text>Ministries you can view. A "league" is any ministry that has sports teams; the term is interchangeable here.</text>
    }
</MudText>

@if (_rows is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_rows.Any())
{
    @if (_isSystemAdmin)
    {
        <MudAlert Severity="Severity.Normal">No leagues yet across any organization in the database.</MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Normal">
            You're not a member of any ministry yet. Browse <MudLink Href="Organizations">organizations</MudLink> to find one.
        </MudAlert>
    }
}
else
{
    <MudPaper Outlined="true">
        <MudTable Items="_rows" Hover="true" Striped="true" Dense="false" Elevation="0">
            <HeaderContent>
                <MudTh>League</MudTh>
                <MudTh>Organization</MudTh>
                <MudTh>Teams</MudTh>
                <MudTh>Upcoming games</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="League">
                    <MudLink Href="@LinkBuilder.LeagueHref(context.MinistryId)">@context.MinistryName</MudLink>
                    @if (context.SubMinistryCount > 0)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">
                            · @context.SubMinistryCount sub-ministries
                        </MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Organization">@context.OrgName</MudTd>
                <MudTd DataLabel="Teams">@context.TeamCount</MudTd>
                <MudTd DataLabel="Upcoming games">@context.UpcomingGameCount</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    private List<LeagueRow>? _rows;
    // Round-BB SystemAdmin dual-branch flag. When true the page query
    // bypasses the myOrgIds filter and shows every league in the database.
    private bool _isSystemAdmin;
    private List<BreadcrumbItem> _crumbs = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("Leagues", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId)) { _rows = new(); return; }

        _isSystemAdmin = await OrgAuth.IsSystemAdminAsync(userId);

        await using var db = await DbFactory.CreateDbContextAsync();

        var orgIds = _isSystemAdmin
            ? new List<int>()
            : await db.OrganizationMemberships
                .Where(m => m.PersonUserId == userId)
                .Select(m => m.OrganizationId)
                .Distinct()
                .ToListAsync();
        if (!_isSystemAdmin && orgIds.Count == 0) { _rows = new(); return; }

        var ministries = await db.Ministries
            .Where(m => _isSystemAdmin || orgIds.Contains(m.OrganizationId))
            .Where(m => m.Teams.Any())
            .Include(m => m.Organization)
            .Include(m => m.Teams)
            .Include(m => m.SubMinistries)
            .AsNoTracking()
            .ToListAsync();
        var fromUtc = DateTime.UtcNow;
        var gameCounts = await db.Games
            .Where(g => g.StartUtc >= fromUtc && g.Status == GameStatus.Scheduled)
            .GroupBy(g => g.MinistryId)
            .Select(g => new { MinistryId = g.Key, Count = g.Count() })
            .ToDictionaryAsync(x => x.MinistryId, x => x.Count);

        _rows = ministries.Select(m => new LeagueRow
        {
            MinistryId = m.Id,
            MinistryName = m.Name,
            OrgName = m.Organization.Name,
            TeamCount = m.Teams.Count,
            SubMinistryCount = m.SubMinistries.Count,
            UpcomingGameCount = gameCounts.TryGetValue(m.Id, out var c) ? c : 0,
        })
        .OrderBy(r => r.OrgName).ThenBy(r => r.MinistryName)
        .ToList();
    }

    private class LeagueRow
    {
        public int MinistryId { get; set; }
        public string MinistryName { get; set; } = "";
        public string OrgName { get; set; } = "";
        public int TeamCount { get; set; }
        public int SubMinistryCount { get; set; }
        public int UpcomingGameCount { get; set; }
    }
}
