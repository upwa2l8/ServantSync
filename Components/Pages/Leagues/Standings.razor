@page "/Leagues/{MinistryId:int}/Standings"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Standings · @(_ministry?.Name ?? "League")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap gap-2">
    <div>
        <MudText Typo="Typo.h4" Class="gradient-text">Standings</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@_ministry?.Organization?.Name · @_ministry?.Name</MudText>
    </div>
    <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="@LinkBuilder.LeagueHref(MinistryId)">Back to league</MudButton>
</MudStack>

@if (_rows is null)
{
    <MudText><em>Loading…</em></MudText>
}
else if (!_rows.Any())
{
    <MudAlert Severity="Severity.Info">No teams in this league yet.</MudAlert>
}
else
{
    @* Raw HTML table kept for simplicity (no sorting/filtering needed).
       Bootstrap CSS is still loaded for the Phase 3 components, so the
       table-striped + table-hover classes still work. When Phase 4
       removes Bootstrap CSS, migrate to <MudTable>. *@
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Team</th>
                    <th class="text-end">Played</th>
                    <th class="text-end">W</th>
                    <th class="text-end">D</th>
                    <th class="text-end">L</th>
                    <th class="text-end">GF</th>
                    <th class="text-end">GA</th>
                    <th class="text-end">GD</th>
                    <th class="text-end">Pts</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < _rows.Count; i++)
                {
                    var r = _rows[i];
                    <tr class="@(i == 0 ? "table-success" : "")">
                        <td>@(i + 1)</td>
                        <td><a href="@LinkBuilder.TeamHref(r.TeamId)">@r.TeamName</a></td>
                        <td class="text-end">@r.Played</td>
                        <td class="text-end">@r.Wins</td>
                        <td class="text-end">@r.Draws</td>
                        <td class="text-end">@r.Losses</td>
                        <td class="text-end">@r.GoalsFor</td>
                        <td class="text-end">@r.GoalsAgainst</td>
                        <td class="text-end">@(r.GoalDifference > 0 ? "+" : "")@r.GoalDifference</td>
                        <td class="text-end"><strong>@r.Points</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <MudText Typo="Typo.caption" Class="mud-text-secondary">
        Points: 3 per win, 1 per draw, 0 per loss. Tiebreakers: goal difference,
        goals scored, then team name. Only games that were actually played are
        counted.
    </MudText>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IStandingsService StandingsSvc
@code {
    [Parameter] public int MinistryId { get; set; }
    private Ministry? _ministry;
    private List<TeamStanding>? _rows;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the route param so it stays
    // in sync if the user navigates between leagues.
    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem("Home", href: LinkBuilder.HomeHref()),
        new BreadcrumbItem("Leagues", href: LinkBuilder.LeaguesHref()),
        new BreadcrumbItem(_ministry?.Name ?? $"League #{MinistryId}", href: LinkBuilder.LeagueHref(MinistryId)),
        new BreadcrumbItem("Standings", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _ministry = await db.Ministries.Include(m => m.Organization).AsNoTracking().FirstOrDefaultAsync(m => m.Id == MinistryId);
        _rows = await StandingsSvc.CalculateForMinistryAsync(MinistryId);
    }
}
