@page "/MySchedule"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My schedule</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-3">My schedule</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @* ---- Subscribe (.ics) link — works in Google / Apple / Outlook calendar ---- *@
    <MudStack Row="true" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center" Class="mb-2" Spacing="2">
        @* "All" → 90-day substitution (see SubscribeUrl below). The user
           picked "All" for the on-page view; the feed collapses to 90d
           because external calendar clients can't ingest unbounded feeds.
           Surface the substitution here so it isn't a silent discrepancy
           between the on-page window and the subscribed feed window. *@
        @if (_toUtc == DateTime.MaxValue || (_toUtc - _fromUtc).TotalDays > 360)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                     title="External calendar clients can't ingest unbounded feeds, so the subscribed feed is limited to 90 days; the on-page view above is unbounded.">
                Feed: last 90 days
            </MudChip>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   Href="@SubscribeUrl" Target="_blank"
                   title="@SubscribeTooltip"
                   StartIcon="@Icons.Material.Outlined.CalendarMonth">
            Subscribe (.ics)
        </MudButton>
    </MudStack>

    @* ---- Scope + window + view controls ---- *@
    <MudGrid Spacing="2" Class="mb-3 align-end">
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Scope</MudText>
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">My assignments</MudChip>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           Href="Open" StartIcon="@Icons.Material.Outlined.Search">
                    Browse open slots
                </MudButton>
            </MudStack>
        </MudItem>
        <MudItem xs="12" md="5">
            <DateRangeChips InitialMode="DateRangeChips.RangeMode.Next30"
                            FromUtc="_fromUtc" ToUtc="_toUtc"
                            OnRangeChanged="OnRangeChanged" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">View</MudText>
            <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small">
                <MudButton Variant="@(_view == ViewMode.List ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           OnClick="() => _view = ViewMode.List"
                           StartIcon="@Icons.Material.Outlined.ViewList">List</MudButton>
                <MudButton Variant="@(_view == ViewMode.Calendar ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           OnClick="() => _view = ViewMode.Calendar"
                           StartIcon="@Icons.Material.Outlined.CalendarMonth">Calendar</MudButton>
            </MudButtonGroup>
        </MudItem>
    </MudGrid>

    @if (_view == ViewMode.Calendar)
    {
        @if (!_calendarEvents.Any())
        {
            <WordmarkSplash Width="120" Loading="lazy" />
            <MudAlert Severity="Severity.Info" Class="mt-2">Nothing on the schedule in this window.</MudAlert>
        }
        else
        {
            <AssignmentCalendar Events="_calendarEvents" AnchorDate="_anchorDate"
                                AnchorDateChanged="d => _anchorDate = d" />
        }
    }
    else
    {
        <MudText Typo="Typo.h6" Class="mt-2">Upcoming assignments</MudText>
        @if (!_assignments.Any())
        {
            <WordmarkSplash Width="120" Loading="lazy" />
            <MudAlert Severity="Severity.Info" Class="mt-2">
                Nothing on the schedule. Find a <MudLink Href="@OrgLink">ministry</MudLink> to volunteer with.
            </MudAlert>
        }
        else
        {
            <MudPaper Outlined="true" Class="mt-2">
                <MudTable Items="_assignments" Hover="true" Striped="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>When</MudTh>
                        <MudTh>Where</MudTh>
                        <MudTh>Slot</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="When">
                            <LocalTime Utc="@context.StartUtc" /> – <LocalTime Utc="@context.EndUtc" />
                        </MudTd>
                        <MudTd DataLabel="Where">@(context.ServiceSlot.Location ?? context.ServiceSlot.Ministry.Name)</MudTd>
                        <MudTd DataLabel="Slot">@context.ServiceSlot.Ministry.Name · @context.ServiceSlot.Name</MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@AssignmentStatusUi.MudColorFor(context.Status)">
                                @context.Status
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @* Round-FR-2.3 polish-3 follow-up (ii): a separate "Upcoming
           training" section surfaces the volunteer's own in-person
           training sessions in the visible window. *@
        @if (_myTrainingSessions.Any())
        {
            <MudText Typo="Typo.h6" Class="mt-4">Upcoming training</MudText>
            <MudPaper Outlined="true" Class="mt-2">
                <MudTable Items="_myTrainingSessions" Hover="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>When</MudTh>
                        <MudTh>Where</MudTh>
                        <MudTh>Session</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="When">
                            <LocalTime Utc="@context.StartUtc" /> – <LocalTime Utc="@context.EndUtc" />
                        </MudTd>
                        <MudTd DataLabel="Where">@context.Location</MudTd>
                        <MudTd DataLabel="Session">
                            <MudLink Href="@LinkBuilder.TrainingSessionHref(context.OrganizationId, context.Id)">@context.Title</MudLink>
                            @if (context.TrainingContent is not null)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">Linked: @context.TrainingContent.Title</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Status</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }
    }

    @* Round-discoverability: "Available in-person training sessions". *@
    <MudText Typo="Typo.h6" Class="mt-4">Available in-person training sessions</MudText>
    @if (!_availableSessions.Any())
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Nothing scheduled across your organizations right now. A coordinator might add one to <MudLink Href="@OrgLink">the Organizations page</MudLink> in their <em>Org training</em> tab.
        </MudText>
    }
    else
    {
        <MudGrid Spacing="3" Class="mt-2">
            @foreach (var s in _availableSessions)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Outlined="true" Class="pa-4 h-100 d-flex flex-column">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-2">
                            <MudText Typo="Typo.h6" Class="mb-0">@s.Title</MudText>
                            @if (s.IsFull)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Full</MudChip>
                            }
                            else if (s.HasLinkedTraining)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Counts toward training</MudChip>
                            }
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                            <MudLink Href="@LinkBuilder.OrganizationHref(s.OrganizationId)">@s.OrganizationName</MudLink>
                            @if (!string.IsNullOrEmpty(s.Location))
                            {
                                <span> · @s.Location</span>
                            }
                        </MudText>
                        <MudText Class="mb-2">
                            <strong><LocalTime Utc="@s.StartUtc" Format="@("ddd, MMM d \u2022 h:mm tt")" /></strong>
                            – <LocalTime Utc="@s.EndUtc" Format="h:mm tt" />
                        </MudText>
                        @if (s.MaxAttendees.HasValue)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mb-2">
                                @s.SignedUpCount / @s.MaxAttendees signed up
                            </MudChip>
                        }
                        @if (!string.IsNullOrEmpty(s.Description))
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">@s.Description</MudText>
                        }
                        <div class="mt-auto">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       Disabled="@(_busySignUpSessionId == s.SessionId || s.IsFull)"
                                       OnClick="@(() => SignUpAvailable(s))">
                                @(_busySignUpSessionId == s.SessionId
                                    ? "Signing up…"
                                    : (s.IsFull ? "Full" : "Sign up"))
                            </MudButton>
                            @if (_availableMessage is not null && _availableMessage.SessionId == s.SessionId)
                            {
                                <MudAlert Severity="@(_availableMessage.Succeeded ? Severity.Success : Severity.Error)"
                                          Dense="true" Class="mt-2 mb-0">
                                    @_availableMessage.Message
                                </MudAlert>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    <MudText Typo="Typo.h6" Class="mt-4">Outstanding training</MudText>
    @if (!_outstanding.Any())
    {
        <MudAlert Severity="Severity.Success">All caught up.</MudAlert>
    }
    else
    {
        <MudPaper Outlined="true" Class="mt-2">
            <MudList T="OutstandingRow" Dense="true">
                @foreach (var r in _outstanding)
                {
                    <MudListItem T="OutstandingRow" Icon="@Icons.Material.Outlined.School">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudLink Href="@LinkBuilder.TrainingHref(r.TrainingContentId)">@r.Title</MudLink>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@r.Scope</MudChip>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IAssignmentService AssignmentService
@inject ITrainingService TrainingService
@inject ITrainingSessionService TrainingSessionService
@inject AuthenticationStateProvider Auth
@code {
    private enum ViewMode { List, Calendar }

    private bool _loading = true;
    private ViewMode _view = ViewMode.List;
    private string? _userId;
    private List<int> _myOrgIds = new();
    private DateTime _fromUtc = DateTime.UtcNow;
    private DateTime _toUtc = DateTime.UtcNow.AddDays(30);
    private DateTime _anchorDate = new(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);

    private List<Assignment> _assignments = new();
    private List<CalendarEvent> _calendarEvents = new();
    private List<TrainingSession> _myTrainingSessions = new();
    private List<AvailableTrainingSessionView> _availableSessions = new();
    private int _busySignUpSessionId;
    private SignupFeedback? _availableMessage;
    private List<OutstandingRow> _outstanding = new();
    private List<BreadcrumbItem> _crumbs = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("My schedule", href: null, disabled: true),
    };

    private string SubscribeUrl
    {
        get
        {
            var days = Math.Clamp((int)Math.Round((_toUtc - _fromUtc).TotalDays), 1, 365);
            if (days >= 360) days = 90;
            return $"/MySchedule/ics?scope=mine&days={days}";
        }
    }

    private string SubscribeTooltip
    {
        get
        {
            var days = Math.Round((_toUtc - _fromUtc).TotalDays);
            if (days >= 360)
                return "Subscribe to see the NEXT 90 DAYS in Google / Apple / Outlook " +
                       "(on-page view is unbounded; feeds are limited to 90 days because external clients can't ingest unlimited events).";
            return "Subscribe in Google / Apple / Outlook to see this schedule in your personal calendar.";
        }
    }

    // Single-org user → link directly to their org's ministry page.
    // Multi-org / zero-org user → link to the org picker.
    private string OrgLink => _myOrgIds.Count == 1
        ? $"Organizations/{_myOrgIds[0]}"
        : "Organizations";

    protected override async Task OnParametersSetAsync() => await Reload();

    private async Task OnRangeChanged((DateTime From, DateTime To) range)
    {
        _fromUtc = range.From;
        _toUtc = range.To;
        _anchorDate = _fromUtc.Year < 1900
            ? new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1)
            : new DateTime(_fromUtc.Year, _fromUtc.Month, 1);
        await Reload();
    }

    private async Task Reload()
    {
        _loading = true;
        try
        {
            var state = await Auth.GetAuthenticationStateAsync();
            _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(_userId))
            {
                _assignments = new();
                _calendarEvents = new();
                _outstanding = new();
                _myOrgIds = new();
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();

            _myOrgIds = await db.OrganizationMemberships
                .Where(m => m.PersonUserId == _userId)
                .Select(m => m.OrganizationId)
                .Distinct()
                .ToListAsync();

            _assignments = await db.Assignments
                .Include(a => a.Person)
                .Include(a => a.ServiceSlot).ThenInclude(s => s.Ministry)
                .Where(a => a.PersonUserId == _userId
                    && a.StartUtc >= _fromUtc
                    && a.StartUtc < _toUtc
                    && a.Status != AssignmentStatus.Cancelled)
                .OrderBy(a => a.StartUtc)
                .AsNoTracking()
                .ToListAsync();

            if (_myOrgIds.Count > 0)
            {
                _myTrainingSessions = await TrainingSessionService.ListMyScheduledSessionsAsync(
                    _userId!, _fromUtc, _toUtc);
                _availableSessions = await TrainingSessionService.ListAvailableForUserAsync(
                    _userId!, _fromUtc, _toUtc);
            }
            else
            {
                _myTrainingSessions = new();
                _availableSessions = new();
            }

            var assignmentEvents = _assignments.Select(a => new CalendarEvent
            {
                Id = a.Id,
                StartUtc = a.StartUtc,
                EndUtc = a.EndUtc,
                Title = $"{a.ServiceSlot.Ministry.Name} · {a.ServiceSlot.Name}",
                Subtitle = a.ServiceSlot.Ministry.Name,
                Location = a.ServiceSlot.Location,
                Status = a.Status.ToString(),
                StatusColor = AssignmentStatusUi.ColorFor(a.Status),
                Href = $"Organizations/{a.ServiceSlot.Ministry.OrganizationId}/Ministries/{a.ServiceSlot.MinistryId}/Roles/{a.ServiceSlotId}",
            });
            var trainingEvents = _myTrainingSessions.Select(s => new CalendarEvent
            {
                Id = s.Id,
                StartUtc = s.StartUtc,
                EndUtc = s.EndUtc,
                Title = s.Title,
                Subtitle = s.TrainingContent?.Title,
                Location = s.Location,
                Status = s.Status.ToString(),
                StatusColor = "info",
                Href = $"Organizations/{s.OrganizationId}/Training/Sessions/{s.Id}",
                IsTraining = true,
            });
            _calendarEvents = assignmentEvents.Concat(trainingEvents)
                .OrderBy(e => e.StartUtc)
                .ToList();

            var reqs = await TrainingService.FindMyOutstandingRequirementsAsync(_userId!);
            _outstanding = reqs.Select(r => new OutstandingRow
            {
                TrainingContentId = r.TrainingContentId,
                Title = r.TrainingContent.Title,
                Scope = r.Scope,
            }).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private class OutstandingRow
    {
        public int TrainingContentId { get; set; }
        public string Title { get; set; } = "";
        public string Scope { get; set; } = "";
    }

    private record SignupFeedback(int SessionId, bool Succeeded, string Message);

    private async Task SignUpAvailable(AvailableTrainingSessionView s)
    {
        if (string.IsNullOrEmpty(_userId)) return;
        _busySignUpSessionId = s.SessionId;
        _availableMessage = null;
        try
        {
            var result = await TrainingSessionService.SignUpAsync(
                s.SessionId, _userId!, _userId!);
            switch (result)
            {
                case TrainingSessionSignupResult.SignedUp:
                    _availableMessage = new SignupFeedback(s.SessionId, true,
                        $"You're signed up for {s.Title}.");
                    await Reload();
                    break;
                case TrainingSessionSignupResult.AlreadySignedUp:
                    _availableMessage = new SignupFeedback(s.SessionId, false,
                        "You're already signed up for this session.");
                    await Reload();
                    break;
                case TrainingSessionSignupResult.SessionFull:
                    _availableMessage = new SignupFeedback(s.SessionId, false,
                        "This session just filled up.");
                    break;
                case TrainingSessionSignupResult.SessionCancelled:
                    _availableMessage = new SignupFeedback(s.SessionId, false,
                        "This session was just cancelled.");
                    break;
                case TrainingSessionSignupResult.NotFound:
                    _availableMessage = new SignupFeedback(s.SessionId, false,
                        "Sign-ups aren't open to your account for this session.");
                    break;
            }
        }
        finally
        {
            _busySignUpSessionId = 0;
        }
    }
}
