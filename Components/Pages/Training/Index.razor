@page "/Training"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>My training</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-3">
    <div>
        <MudText Typo="Typo.h4" Class="gradient-text">My training</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            The training this database requires <em>you</em> to take, plus your
            personal training history. Required training comes from the organizations
            you belong to and from any specific slot you are scheduled for.
        </MudText>
    </div>
    @if (_canManageCatalog)
    {
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="Training/Manage">
            Manage catalog
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @* ---- Action needed ---- *@
    <MudPaper Outlined="true" Class="glass-card mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="px-4 py-3">
            <div>
                <MudText Typo="Typo.h6" Class="mb-0">Action needed</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-small mud-text-secondary">
                    Training you have not yet satisfied — re-takes show up here when a previous completion has expired.
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small"
                     Color="@(_actionNeeded.Count == 0 ? Color.Success : Color.Warning)">
                @_actionNeeded.Count
            </MudChip>
        </MudStack>
        <div class="px-4 pb-3">
            @if (!_hasAnyOrgMembership)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-0">
                    You are not yet a member of any organization, so nothing applies.
                    Once you accept a registration link, training will appear here.
                </MudText>
            }
            else if (_actionNeeded.Count == 0)
            {
                <MudAlert Severity="Severity.Success" Class="mb-0">
                    You're up to date. You have completed all required training for your ministries.
                </MudAlert>
            }
            else
            {
                <MudList T="OutstandingRow" Dense="true">
                    @foreach (var r in _actionNeeded)
                    {
                        <MudListItem T="OutstandingRow">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <div>
                                    <MudLink Href="@LinkBuilder.TrainingHref(r.TrainingContentId)">
                                        <strong>@r.Title</strong>
                                    </MudLink>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="ms-2">@r.ScopeLabel</MudChip>
                                    @if (!string.IsNullOrEmpty(r.ContextLabel))
                                    {
                                        <MudText Typo="Typo.caption" Class="mud-text-secondary ms-2 d-inline">@r.ContextLabel</MudText>
                                    }
                                </div>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           Href="@LinkBuilder.TrainingHref(r.TrainingContentId)">
                                    Take
                                </MudButton>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        </div>
    </MudPaper>

    @* ---- My history ---- *@
    <MudPaper Outlined="true" Class="glass-card">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="px-4 py-3">
            <div>
                <MudText Typo="Typo.h6" Class="mb-0">My history</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-small mud-text-secondary">
                    Every training completion recorded for you, newest first. A
                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="mx-1">Valid</MudChip> badge means the
                    completion is still current; an
                    <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="mx-1">Expired</MudChip> badge means you
                    need to retake it (it will also appear in "Action needed" above).
                </MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_history.Count</MudChip>
        </MudStack>
        <div class="px-4 pb-3">
            @if (_history.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-0">
                    You haven't completed any training yet. Take one above to get started.
                </MudText>
            }
            else
            {
                <MudTable Items="_history" Hover="true" Dense="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Training</MudTh>
                        <MudTh>Version</MudTh>
                        <MudTh>Completed</MudTh>
                        <MudTh>Expires</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Training">@(context.TrainingContent?.Title ?? "(removed)")</MudTd>
                        <MudTd DataLabel="Version">v@context.TrainingContentVersion</MudTd>
                        <MudTd DataLabel="Completed"><LocalTime Utc="@context.CompletionUtc" /></MudTd>
                        <MudTd DataLabel="Expires">
                            @if (context.ExpiresUtc.HasValue)
                            {
                                <LocalTime Utc="@context.ExpiresUtc.Value" Format="yyyy-MM-dd" />
                            }
                            else
                            {
                                <span class="mud-text-secondary mud-text-small">never</span>
                            }
                        </MudTd>
                        <MudTd DataLabel="Status">
                            @{
                                var valid = context.IsValid(DateTime.UtcNow);
                            }
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(valid ? Color.Success : Color.Error)">
                                @(valid ? "Valid" : "Expired")
                            </MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>
    </MudPaper>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject ITrainingService TrainingService
@code {
    private bool _loading = true;
    // The "Action needed" list. We keep raw TrainingRequirement rows
    // loaded via the service aggregate rather than fetching TrainingContent
    // separately — the service eager-loads TrainingContent for us.
    private List<OutstandingRow> _actionNeeded = new();
    // The "My history" list. Eager-loaded TrainingContent so we can
    // render titles + versions without an N+1 trip on render.
    private List<TrainingCompletion> _history = new();
    // Distinguishes the "no org memberships yet" empty state from the
    // "you're all caught up" positive empty state on Action needed.
    private bool _hasAnyOrgMembership = true;
    // Show the "Manage catalog" CTA only to org admins — the
    // /Training/Manage page itself re-checks the gate as defense in depth.
    private bool _canManageCatalog;
    // Per-page breadcrumb trail. Same shape as the rest of the migrated
    // pages — `MudBreadcrumbs` is the MudBlazor equivalent of the old
    // <ol class="breadcrumb"> block.
    private List<BreadcrumbItem> _crumbs = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("My training", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _loading = false;
            return;
        }

        // Cheap up-front check: do we even need to query? If the user has
        // no memberships at all, both lists are guaranteed empty.
        await using var db = await DbFactory.CreateDbContextAsync();
        _hasAnyOrgMembership = await db.OrganizationMemberships
            .AnyAsync(m => m.PersonUserId == userId);

        var outstanding = await TrainingService.FindMyOutstandingRequirementsAsync(userId);
        _actionNeeded = outstanding.Select(r => new OutstandingRow
        {
            TrainingContentId = r.TrainingContentId,
            Title = r.TrainingContent?.Title ?? "(removed)",
            // Build the "where this comes from" badge text inline. Org-scoped
            // -> "Org: <name>"; slot-scoped -> "Slot: <org> › <ministry> › <slot>".
            // Using the navigation properties that TrainingService already
            // eager-loaded saves a second round-trip.
            ScopeLabel = r.Scope == "Organization" ? "Org" : "Slot",
            ContextLabel = r.OrganizationId.HasValue
                ? (r.Organization?.Name ?? "—")
                : (r.ServiceSlot is null
                    ? "—"
                    : $"{r.ServiceSlot.Ministry.Organization.Name} › {r.ServiceSlot.Ministry.Name} › {r.ServiceSlot.Name}"),
        }).ToList();

        _history = await TrainingService.ListMyHistoryAsync(userId);

        _canManageCatalog = await OrgAuth.IsAnyOrgAdminAsync(userId);
        _loading = false;
    }

    private sealed class OutstandingRow
    {
        public int TrainingContentId { get; set; }
        public string Title { get; set; } = "";
        public string ScopeLabel { get; set; } = "";
        public string ContextLabel { get; set; } = "";
    }
}
