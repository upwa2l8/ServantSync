@page "/Training/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_content?.Title ?? "Training")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (_content is null)
{
    <MudText><em>Loading…</em></MudText>
}
else if (!_inOwningOrg)
{
    @* Per-org access gate: a volunteer who isn't a member of the
       content's org can't take it. The service refuses anyway; mirror
       here for UX clarity. *@
    <MudAlert Severity="Severity.Warning" Class="mt-3">
        <MudText Typo="Typo.h5" Class="mb-2">Training belongs to @_content.Organization?.Name</MudText>
        <MudText Class="mb-2">You're not currently a member of this organization, so you can't start or complete this training here.</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-0">
            Ask the owning organization's admin for a registration link, or browse the
            <MudLink Href="Organizations">organizations</MudLink> you're already part of for their catalog.
        </MudText>
    </MudAlert>
}
else
{
    @* Progress badge — the volunteer can see how close they are to
       unlocking "Mark as completed". Hidden until the server snapshot
       has been read once. *@
    @if (_eligibility is not null)
    {
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @_eligibility.Reason
            </MudText>
            <MudChip T="string" Size="Size.Small" Color="@(_eligibility.IsEligible ? Color.Success : Color.Warning)">@ProgressLabel(_eligibility)</MudChip>
        </MudStack>
    }

    @* Format-specific viewer host.

       Round-AO: conditional `ratio ratio-16x9` wrapper (dropped for
       local PDFs). Without it, Bootstrap 5's `.ratio > *` rule
       (`position: absolute; inset: 0`) collides on the local-PDF
       branch: it applies to BOTH `#pdf-canvas-host` and `.btn-group`,
       so the Prev/Next button group fills the entire 16:9 box and
       visually covers the PDF.js canvas (user reported "PDF isn't
       loading" on /Training/3). See STATUS.md round-AO.

       NOTE: The viewer host (and its children — #pdf-canvas-host,
       <iframe>, <video>) MUST stay as raw HTML / Bootstrap-classed
       elements. The JS bridge in trainingview.js hooks ElementReference
       IDs (`pdf-canvas-host`, `video-iframe`, `native-video`) via
       document.getElementById; wrapping them in MudBlazor components
       would change the DOM topology and break the bridge. The
       surrounding chrome (alert, title, mark-completed button,
       manual-mark card) is migrated to MudBlazor. *@
    <div class="@(_content.Format == TrainingFormat.Pdf && !_content.FilePathOrUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? "mb-3" : "ratio ratio-16x9 mb-3")" id="training-host">
        @switch (_content.Format)
        {
            case TrainingFormat.Pdf:
                if (_content.FilePathOrUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                {
                    // External PDF — no per-page hook, drop to best-effort timer.
                    <iframe id="external-pdf" src="@_content.FilePathOrUrl" allowfullscreen
                            @ref="_iframeEl"></iframe>
                }
                else
                {
                    @* Round-AP: defensive visible-state for the local-PDF
                       canvas host. After round-AO dropped the `ratio-16x9`
                       wrapper for local PDFs, the canvas is in normal block
                       flow with display:block (round-AP CSS). The host gets
                       a subtle gray bg + min-height so the canvas's extent
                       is VISIBLE (not white-on-white-invisible) even when
                       page-1's top region is whitespace; the direct-download
                       link gives the volunteer a guaranteed-readable surface
                       if PDF.js ever fails to paint (e.g., browser without ES
                       modules, encryption mismatch, etc.). *@
                    <div id="pdf-canvas-host" @ref="_pdfHostEl" class="pdf-canvas-host border rounded p-1" style="overflow:auto; min-height: 60vh; background: #f8f9fa; width: 100%;"></div>
                    <div class="btn-group btn-group-sm mt-2" role="group" aria-label="PDF navigation">
                        <button type="button" class="btn btn-outline-secondary" data-pdf-action="prev" data-pdf-target="pdf-canvas-host">◀ Prev</button>
                        <button type="button" class="btn btn-outline-secondary" data-pdf-action="next" data-pdf-target="pdf-canvas-host">Next ▶</button>
                    </div>
                    <div class="small text-muted mt-1">
                        <a href="@_content.FilePathOrUrl" target="_blank" rel="noopener">Open PDF directly</a>
                        <span class="ms-2">(always available, even if PDF.js can't render)</span>
                    </div>
                }
                break;

            case TrainingFormat.Video:
                if (_content.FilePathOrUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                {
                    var embedUrl = ToYouTubeEmbed(_content.FilePathOrUrl);
                    if (embedUrl is null)
                    {
                        <iframe src="@_content.FilePathOrUrl" allowfullscreen @ref="_iframeEl"></iframe>
                    }
                    else
                    {
                        <iframe id="video-iframe"
                                src="@embedUrl?enablejsapi=1"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                                @ref="_iframeEl"></iframe>
                    }
                }
                else
                {
                    <video class="w-100" controls preload="metadata" src="@_content.FilePathOrUrl" @ref="_videoEl" id="native-video"></video>
                }
                break;

            case TrainingFormat.Slideshow:
            default:
                // Slideshow / external URL — best-effort timer only.
                <iframe src="@_content.FilePathOrUrl" allowfullscreen @ref="_iframeEl"></iframe>
                break;
        }
    </div>

    @* Fallback for PDF when the JS bridge failed to mount PDF.js —
       alert + a real iframe so the volunteer can still read the file.
       Engagement won't be tracked, but the IsInsufficientEngagement
       gate at Mark Completed still serves as the trust boundary.
       Critically: this block is OUTSIDE the #training-host div above
       so an unpaired close tag can't accidentally swallow it. *@
    @if (_trackingFailed && _content is { Format: TrainingFormat.Pdf, FilePathOrUrl: var path } && !path.StartsWith("http", StringComparison.OrdinalIgnoreCase))
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2 mb-2">
            Engagement tracking unavailable in this browser — using native rendering. Mark-completed gating is still enforced.
            @if (!string.IsNullOrEmpty(_lastError))
            {
                @* Round-AR: surface the actual C# exception text
                   inside the structural fallback panel. Before this
                   fix, _lastError ("Viewer tracking unavailable: {ex.Message}")
                   was set but only rendered deep in the markup near
                   the Mark Completed button — easy to miss if the
                   user was focused on the gray canvas-host area.
                   With the round-AR trainingview.js paintErr helper,
                   the gray box ALSO paints the JS-side message
                   inline; this change covers the (rarer) case
                   where the throw happens OUTSIDE the JS catch
                   (e.g., a Blazor SignalR circuit drop surfaces a
                   JSException that bubbles up before mountPdf runs)
                   so the user can still read the cause here. *@
                <MudText Typo="Typo.caption" Class="mt-1 mb-0 text-danger" Style="font-family: monospace;">@_lastError</MudText>
            }
        </MudAlert>
        <iframe class="w-100" style="height: 70vh;" src="@path"></iframe>
    }

    <MudText Typo="Typo.h4" Class="mt-3">@_content.Title <small class="mud-text-secondary">v@_content.Version</small></MudText>
    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
        Owned by <strong>@_content.Organization?.Name</strong>
    </MudText>
    <MudText Typo="Typo.body1" Class="mb-3">@_content.Description</MudText>

    @if (_myCompletion is null || !_myCompletion.IsValid(DateTime.UtcNow))
    {
        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   OnClick="RecordCompletion"
                   Disabled="@(_saving || (_eligibility is not null && !_eligibility.IsEligible))">
            @(_saving ? "Saving…" : "Mark as completed")
        </MudButton>
        @if (_lastError is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2 mb-0">@_lastError</MudAlert>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Success" Class="mt-2">
            Completed @_myCompletion.CompletionUtc.ToString("u")
            @if (_myCompletion.ExpiresUtc.HasValue)
            {
                <span> · valid until @_myCompletion.ExpiresUtc.Value.ToString("u")</span>
            }
        </MudAlert>
    }

    @* Round-FR-2.3c: coord/admin "Mark as completed by a coordinator"
       affordance. Calls ITrainingService.MarkSingleCompleteAsync
       (FR-2.2 service) which writes a TrainingCompletion row with
       CompletionSource=CoordinatorManualSingle + MarkedCompleteByUserId
       + ManualCompletionNotes (the audit-trail triple). Bypasses the
       engagement-eligibility gate entirely (decision Q6) — the marker
       is asserting out-of-band competence. Notes REQUIRED (decision
       Q5). The form posts to a per-volunteer picker so a coord can
       mark any org member, not just themselves. Only rendered for
       Admin/Coordinator of the content's org (the service re-gates
       server-side). *@
    @if (_canMarkManually)
    {
        <MudCard Outlined="true" Class="mt-4" Style="border-color: var(--mud-palette-warning-lighten);">
            <MudCardHeader>
                <MudText Typo="Typo.subtitle1">Mark as completed by a coordinator</MudText>
            </MudCardHeader>
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mud-text-secondary mb-2">
                    For cases where a volunteer has demonstrated competence outside the
                    online flow (in-person walkthrough, prior-experience waiver, etc.).
                    Requires a non-empty note so the audit trail distinguishes this from
                    a self-paced online completion.
                </MudText>
                <MudGrid Spacing="2" Class="align-items-center">
                    <MudItem xs="12" md="5">
                        <MudSelect T="string" @bind-Value="_manualUserId" Label="Volunteer (org member)" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem T="string" Value="@("")">— pick a volunteer —</MudSelectItem>
                            @foreach (var m in _orgMembersForManual)
                            {
                                <MudSelectItem T="string" Value="@m.UserId">@m.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="_manualNote" Label="Note (required)"
                                      Placeholder="e.g. walked through the safety checklist in person on 2026-07-06"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                   OnClick="MarkManuallyAsync"
                                   Disabled="@(!CanMarkManually)">
                            @(_savingManual ? "Saving…" : "Mark complete")
                        </MudButton>
                    </MudItem>
                </MudGrid>
                @if (_manualError is not null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2 mb-0">@_manualError</MudAlert>
                }
                @if (_manualResult is not null)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2 mb-0">@_manualResult</MudAlert>
                }
            </MudCardContent>
        </MudCard>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject ITrainingService TrainingService
@inject IJSRuntime JS
@inject AuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject IPdfPageCountHealer PdfHealer
@inject IOrgAuthService OrgAuth
@implements IAsyncDisposable
@code {
    [Parameter] public int Id { get; set; }
    private TrainingContent? _content;
    private TrainingCompletion? _myCompletion;
    // Snapshot returned by CheckEligibilityAsync. The JS bridge mirrors
    // its truth locally so the UI feels live, but the server-side rule
    // is the trust boundary at RecordCompletionAsync time.
    private TrainingEligibilitySnapshot? _eligibility;
    private bool _saving;
    private bool _inOwningOrg = true;
    private string? _lastError;
    // JS-interop handles for the per-format viewer mount.
    private ElementReference _pdfHostEl;
    private ElementReference _iframeEl;
    // Bound to the <video> element when Format == Video and the source is
    // an uploaded path. The JS bridge hooks its timeupdate / ended events
    // to drive HighestWatchedSec up the round-trip to SyncProgress.
    private ElementReference _videoEl;
    // True once the JS bridge has had a chance to attach event hooks.
    // Drives the "show me the content even if tracking failed" fallback
    // in the render tree when the bridge fails on a no-PDF.js browser.
    private bool _trackingFailed;
    private DotNetObjectReference<Take>? _dotNetRef;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the content title so it stays
    // in sync with whatever training the volunteer is taking.
    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("My training", href: "Training"),
        new BreadcrumbItem(_content?.Title ?? $"Training #{Id}", href: null, disabled: true)
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _content is null || !_inOwningOrg) return;
        await MountViewerAsync();
    }

    private async Task MountViewerAsync()
    {
        try
        {
            if (_dotNetRef is null)
            {
                _dotNetRef = DotNetObjectReference.Create(this);
            }
            // Round-AL (CURRENT): revert round-AK's per-tick cache-bust.
            // The user-reported runtime crash — JSException followed by
            // ServantSync.exe exiting with code 4294967295 — fired
            // after the second OnInitializedAsync pass on /Training/3.
            // Mechanism unconfirmed; round-AK's per-tick URL was the
            // only JS-side delta between round-AG (known-good — user
            // observed "PDF looks fine to me") and the crash. Reverting
            // returns to known-good. See STATUS.md round-AL for the
            // full triage.
            var module = await JS.InvokeAsync<IJSObjectReference>("import",
                "/js/trainingview.js");

            if (_content!.Format == TrainingFormat.Pdf
                && !_content.FilePathOrUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            {
                // Local PDF — render with PDF.js.
                // Round-AU: pass element id as string, not ElementReference.
                // On ACA/.NET 9 InteractiveServer, ElementReference arrives as a
                // plain serialized object — not a real DOM node — so the JS
                // mountPdf receives a non-DOM target and canvasRoot.appendChild
                // throws "is not a function". Passing the id string lets the JS
                // side resolve via document.getElementById, which works reliably
                // across all hosting models. See STATUS.md round-AU.
                await module.InvokeVoidAsync("ServantSyncTraining.mountPdf",
                    "pdf-canvas-host", _content.FilePathOrUrl, _dotNetRef, Id);
            }
            else if (_content.Format == TrainingFormat.Video)
            {
                if (_content.FilePathOrUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                    && ToYouTubeEmbed(_content.FilePathOrUrl) is not null)
                {
                    // YouTube IFrame Player API — works against the bound
                    // iframe ref. Without the @ref on the iframe element
                    // this silently no-ops; that's the round-M bug.
                    await module.InvokeVoidAsync("ServantSyncTraining.mountYouTube",
                        "video-iframe", _dotNetRef, Id);
                }
                else
                {
                    // Native <video>: pass the bound ElementReference so
                    // the bridge can hook its timeupdate / ended events.
                    // The mountVideo JS function attaches listeners on
                    // the element ref; null here short-circuits all
                    // engagement tracking.
                    await module.InvokeVoidAsync("ServantSyncTraining.mountVideo",
                        "native-video", _dotNetRef, Id);
                }
            }
            else
            {
                await module.InvokeVoidAsync("ServantSyncTraining.mountBestEffortDwell",
                    _dotNetRef, Id);
            }
        }
        catch (Exception ex)
        {
            // Non-fatal — content still renders (via tracked element's
            // native controls); only engagement tracking is degraded.
            // The monitor reported `_trackingFailed = true` so the
            // render tree can show the warning + the JS bridge failure
            // user-visible. We deliberately do NOT swallow — the page
            // still requires InsufficientEngagement to clear before a
            // Mark-as-completed can succeed, so the trust boundary
            // remains intact.
            //
            // Round-AQ: explicitly re-render after set. Before this fix,
            // the catch flipped `_trackingFailed = true` mid-render and
            // went silent — Blazor Server does not auto-rerender after
            // a state mutation from inside an awaited task, so the
            // structural fallback warning + <iframe> below stayed
            // un-rendered even though the flag flipped. Symptom: empty
            // gray box forever, volunteer has no idea why. The JS-side
            // half of round-AQ also paints the actual JS error text
            // directly into #pdf-canvas-host — see trainingview.js
            // mountPdf catch block. Together these convert the
            // silent-failure UX into a self-diagnosing one. See
            // STATUS.md round-AQ.
            _trackingFailed = true;
            _lastError = $"Viewer tracking unavailable: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public async Task SyncProgress(int contentId, TrainingActivitySync sync)
    {
        if (_content is null || contentId != _content.Id) return;
        await TrainingService.SyncActivityAsync(
            await CurrentUserId() ?? "",
            _content.Id,
            sync);
        // Periodically refresh the snapshot so the progress badge updates
        // without polling from .NET. Cheap: single small read per sync.
        _eligibility = await TrainingService.CheckEligibilityAsync(
            await CurrentUserId() ?? "", _content.Id);
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _content = await db.TrainingContents
            .Include(c => c.Organization)
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == Id);

        var userId = await CurrentUserId();
        if (_content is not null && userId is not null)
        {
            _inOwningOrg = await db.OrganizationMemberships
                .AnyAsync(m => m.PersonUserId == userId
                    && m.OrganizationId == _content.OrganizationId);

            _myCompletion = await db.TrainingCompletions
                .Where(c => c.PersonUserId == userId && c.TrainingContentId == Id
                    && c.TrainingContentVersion == _content.Version)
                .OrderByDescending(c => c.CompletionUtc)
                .FirstOrDefaultAsync();

            if (_inOwningOrg)
            {
                // Round-AI: self-heal the row's TotalPageCount if PdfPig
                // can derive it from the on-disk PDF. Closes the gap for
                // legacy uploads predating PdfPageCounter's wiring and
                // for files whose upload-time extension/MIME check
                // silently missed the .pdf case — without this the
                // volunteer would see "PDF page count unknown — admin
                // re-upload required." at the top of every visit until
                // an admin re-uploaded, even though the on-disk file is
                // openable. Heal updates ONLY TotalPageCount (no
                // Version bump) so any in-flight activity the volunteer
                // already accumulated at the current version stays
                // valid; if the heal returns null (encrypted / missing
                // file / malformed) we fall through with the existing
                // "unknown" gate untouched.
                await TryHealPdfPageCountAsync();

                // Seed an empty activity row immediately so the
                // FirstOpenedUtc anchor starts ticking even before the JS
                // bridge has had a chance to fire SyncProgress.
                _eligibility = await TrainingService.CheckEligibilityAsync(userId, Id);
                if (_eligibility.IsEligible == false && _eligibility.DwellSec == 0)
                {
                    await TrainingService.SyncActivityAsync(userId, Id, new TrainingActivitySync());
                    _eligibility = await TrainingService.CheckEligibilityAsync(userId, Id);
                }

                // Round-FR-2.3c: compute the manual-mark affordance's
                // visibility + preload the org-members picker. Same
                // gate as TrainingSessionService.MarkAttendeesCompleteAsync
                // (Admin or Coordinator of the content's org). The
                // service re-gates server-side; the load is just the
                // dropdown options.
                _canMarkManually = await OrgAuth.CanManageOrgAsync(userId, _content.OrganizationId);
                if (_canMarkManually)
                {
                    _orgMembersForManual = await db.People
                        .Where(p => p.Memberships.Any(m => m.OrganizationId == _content.OrganizationId))
                        .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                        .AsNoTracking()
                        .ToListAsync();
                }
            }
        }
    }

    private async Task<string?> CurrentUserId()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        return state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    }

    private async Task RecordCompletion()
    {
        _saving = true;
        _lastError = null;
        try
        {
            var userId = await CurrentUserId();
            if (userId is null || _content is null) return;
            // Force a fresh eligibility snapshot at click time — the
            // JS bridge has been posting SyncProgress but we want to be
            // sure the value the server checks against is <= now.
            _eligibility = await TrainingService.CheckEligibilityAsync(userId, _content.Id);
            var result = await TrainingService.RecordCompletionAsync(userId, _content.Id, DateTime.UtcNow);
            switch (result)
            {
                case TrainingCompletionResult.Recorded:
                    {
                        await using var db = await DbFactory.CreateDbContextAsync();
                        _myCompletion = await db.TrainingCompletions
                            .Where(c => c.PersonUserId == userId && c.TrainingContentId == _content.Id
                                && c.TrainingContentVersion == _content.Version)
                            .OrderByDescending(c => c.CompletionUtc)
                            .FirstOrDefaultAsync();
                    }
                    break;
                case TrainingCompletionResult.NotInOrg:
                    _inOwningOrg = false;
                    break;
                case TrainingCompletionResult.ContentNotFound:
                    _lastError = "This training is no longer available.";
                    break;
                case TrainingCompletionResult.InsufficientEngagement:
                    _lastError = "You haven't engaged with this training enough yet. " +
                                 (_eligibility?.Reason ?? "Try again in a minute.");
                    break;
            }
        }
        catch (Exception ex)
        {
            _lastError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private static string ProgressLabel(TrainingEligibilitySnapshot e) => e.Format switch
    {
        TrainingFormat.Pdf => e.TotalPages > 0 ? $"{e.ViewedPagesCount} / {e.TotalPages} pages" : "PDF",
        TrainingFormat.Video => e.ActualDurationSec > 0
            ? $"{(int)(100.0 * e.HighestWatchedSec / e.ActualDurationSec)}% watched"
            : "Video",
        _ => $"{e.DwellSec}s elapsed",
    };

    // Round-AI: PDF self-heal wrapper. Delegates the actual write to
    // IPdfPageCountHealer.TryHealAsync (Services/PdfPageCountHealer.cs)
    // which is fully unit-tested. This thin wrapper's only job is
    // gating the call to the right conditions (PDF + null page count)
    // and re-fetching the in-memory _content snapshot so the subsequent
    // CheckEligibilityAsync reads the healed TotalPageCount without
    // requiring a second OnInitializedAsync pass.
    private async Task TryHealPdfPageCountAsync()
    {
        if (_content is null) return;
        if (_content.Format != TrainingFormat.Pdf) return;
        if (_content.TotalPageCount.HasValue) return;

        var pages = await PdfHealer.TryHealAsync(_content.Id);
        if (!pages.HasValue) return; // heal didn't fix it — keep gate as-is

        await using var db = await DbFactory.CreateDbContextAsync();
        _content = await db.TrainingContents
            .Include(c => c.Organization)
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == _content.Id);
    }

    // Plain-string Youtube-watch?v=… → embed/… rewrite; null when the
    // URL points at a non-watchable resource. Hand-rolled query parse
    // keeps us off System.Web (not default in ASP.NET Core) so the
    // project file doesn't need an extra reference.
    private static string? ToYouTubeEmbed(string url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        try
        {
            var u = new Uri(url);
            var host = u.Host;
            if (host.EndsWith("youtube.com", StringComparison.OrdinalIgnoreCase)
                && u.AbsolutePath.StartsWith("/watch", StringComparison.OrdinalIgnoreCase))
            {
                string? v = null;
                foreach (var part in u.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
                {
                    var eq = part.IndexOf('=');
                    if (eq <= 0) continue;
                    var key = part[..eq];
                    var val = part[(eq + 1)..];
                    if (string.Equals(key, "v", StringComparison.OrdinalIgnoreCase))
                    {
                        v = Uri.UnescapeDataString(val);
                        break;
                    }
                }
                return v is null ? null : $"https://www.youtube.com/embed/{v}";
            }
            if (host.EndsWith("youtu.be", StringComparison.OrdinalIgnoreCase))
            {
                var id = u.AbsolutePath.Trim('/');
                return string.IsNullOrEmpty(id) ? null : $"https://www.youtube.com/embed/{id}";
            }
        }
        catch { }
        return null;
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    // ─── Round-FR-2.3c: admin "Mark as completed by a coordinator" ───
    // Bypasses the engagement-eligibility gate via the FR-2.2
    // service's MarkSingleCompleteAsync — the marker asserts
    // out-of-band competence (decision Q6). Notes REQUIRED (decision
    // Q5). The picker lists every org member of the content's
    // owning org so a coord can mark any of them, not just
    // themselves. The completed completion row carries the
    // audit-trail source (CoordinatorManualSingle) + the marker's
    // user id + the note.

    private bool _canMarkManually;
    private string _manualUserId = "";
    private string _manualNote = "";
    private string? _manualError;
    private string? _manualResult;
    private bool _savingManual;
    private List<Person> _orgMembersForManual = new();

    private bool CanMarkManually =>
        !_savingManual
        && !string.IsNullOrEmpty(_manualUserId)
        && !string.IsNullOrWhiteSpace(_manualNote)
        && _content is not null;

    private async Task MarkManuallyAsync()
    {
        if (_content is null || !CanMarkManually) return;
        _savingManual = true;
        _manualError = null;
        _manualResult = null;
        try
        {
            var markerId = await CurrentUserId() ?? "";
            if (string.IsNullOrEmpty(markerId))
            {
                _manualError = "Couldn't determine the current user.";
                return;
            }
            var result = await TrainingService.MarkSingleCompleteAsync(
                _content.Id, _manualUserId, markerId, _manualNote);
            switch (result)
            {
                case TrainingCompletionResult.ManualMarkRecorded:
                    _manualResult = "Marked complete. The completion row carries the audit-trail source (CoordinatorManualSingle) and your note.";
                    _manualUserId = "";
                    _manualNote = "";
                    break;
                case TrainingCompletionResult.ManualMarkNotesRequired:
                    _manualError = "A non-empty note is required.";
                    break;
                case TrainingCompletionResult.ManualMarkPermissionDenied:
                    _manualError = "You don't have permission to mark completion for this org.";
                    break;
                case TrainingCompletionResult.NotInOrg:
                    _manualError = "That volunteer isn't a member of this training's organization.";
                    break;
                case TrainingCompletionResult.ContentNotFound:
                    _manualError = "This training is no longer available.";
                    break;
                case TrainingCompletionResult.InsufficientEngagement:
                    // Service can't return this for the manual path
                    // (the gate is bypassed) but the enum is shared —
                    // surface a friendly fallback in case the contract
                    // ever changes.
                    _manualError = "Unexpected engagement-gate result. Contact an admin.";
                    break;
            }
        }
        catch (Exception ex)
        {
            _manualError = ex.Message;
        }
        finally
        {
            _savingManual = false;
        }
    }
}
