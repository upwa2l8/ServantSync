@page "/Training/New"
@page "/Training/{Id:int}/Edit"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New training" : $"Edit · {_model.Title}")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-2 gradient-text">@(_isNew ? "New training content" : "Edit training content")</MudText>
<StatusMessage Message="@_message" IsError="@_isError" />

@if (!_authChecked)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

<EditForm Model="_model" OnValidSubmit="Save" FormName="training-content-edit">
    @* Round-AF: FormName="training-content-edit" RESTORED per .NET 9 docs
       guidance — "Always provide a FormName to EditForm when using
       InteractiveServer mode. The FormName helps Blazor maintain state
       consistency during re-renders." Round-AE removed FormName on a
       doc-contradicting hypothesis; the user-visible "Upload file" pill
       button remained inert AFTER round-AE because removing FormName
       destabilized the form-aware wiring, not because FormName caused
       it. The EditForm is ALSO no longer conditionally mounted — the
       auth-gate is now internal via <fieldset disabled> so the form's
       render-mode wiring is established on initial render and stays
       stable through re-renders. The @if (!_authChecked) sentinel above
       the form shows the loading state ONLY until the single
       once-per-page OnInitializedAsync completes. See STATUS.md round-AF
       for the corrected diagnosis. *@
    <DataAnnotationsValidator />
    <ValidationSummary />
    <fieldset disabled="@(!_authChecked || !_canSubmit)">

        @* Per-org scoping (round N): every TrainingContent belongs to one
           Organization. For NEW: a dropdown of orgs the caller is Admin of.
           If the caller only Admin's one org, auto-pick + hide the dropdown
           so a normal admin doesn't see friction. For EDIT: the org is
           locked (grayed-out badge above the title). "Move training to a
           different org" is intentionally not implemented — the clean path
           is delete-and-recreate; training versioning is per-catalog so a
           cross-org move would orphan version history anyway. *@
        <div class="mb-3">
            @if (_isNew)
            {
                <MudSelect T="int"
                           @bind-Value="_model.OrganizationId"
                           Label="Organization"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Disabled="@(!_adminOfMultipleOrgs)">
                    <MudSelectItem T="int" Value="0">— pick the owning organization —</MudSelectItem>
                    @foreach (var o in _adminOrgs)
                    {
                        <MudSelectItem T="int" Value="@o.Id">@o.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (!_adminOfMultipleOrgs)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        Auto-assigned to the only organization you administer. Cross-org sharing isn't supported.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1">
                        Training belongs to one organization and is visible only to members of that org.
                    </MudText>
                }
            }
            else if (_existingOrg is not null)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-1">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Owned by:</MudChip>
                    <strong>@_existingOrg.Name</strong>
                </MudStack>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                    To move training to another organization, delete and recreate it.
                </MudText>
            }
        </div>

        <MudTextField T="string"
                      Label="Title"
                      @bind-Value="_model.Title"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="mb-3"
                      Required="true"
                      RequiredError="Title is required" />
        <MudTextField T="string"
                      Label="Description"
                      @bind-Value="_model.Description"
                      Lines="3"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="mb-3" />
        <MudGrid Spacing="2" Class="mb-2">
            <MudItem xs="12" md="6">
                <MudSelect T="TrainingFormat"
                           @bind-Value="_model.Format"
                           Label="Format"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    @foreach (var f in Enum.GetValues<TrainingFormat>())
                    {
                        <MudSelectItem T="TrainingFormat" Value="@f">@f</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudNumericField T="int?"
                                 @bind-Value="_model.DurationMinutes"
                                 Label="Estimated duration (minutes)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <div class="mt-3">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Source</MudText>
            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Class="mb-2">
                <MudButton OnClick="@(() => _source = "url")"
                           Variant="@(_source == "url" ? Variant.Filled : Variant.Outlined)">Use URL</MudButton>
                <MudButton OnClick="@(() => _source = "upload")"
                           Variant="@(_source == "upload" ? Variant.Filled : Variant.Outlined)">Upload file</MudButton>
            </MudButtonGroup>

            @if (_source == "url")
            {
                <MudTextField T="string"
                              Label="URL (YouTube/Vimeo/Drive/etc.)"
                              @bind-Value="_model.FilePathOrUrl"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Class="mb-3" />
            }
            else
            {
                <InputFile OnChange="HandleUpload" class="form-control mb-2" accept="video/*,application/pdf" />
                @if (_uploading)
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Uploading…</MudText>
                }
                else if (!string.IsNullOrEmpty(_uploadedPath))
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-1">
                        <MudText Typo="Typo.caption" Color="Color.Success">Uploaded: @_uploadedPath</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _model.FilePathOrUrl = _uploadedPath!)">Use this</MudButton>
                    </MudStack>
                }
            }
        </div>

        <MudStack Row="true" Spacing="2" Class="mt-3">
            <MudButton ButtonType="ButtonType.Submit"
                       Color="Color.Primary"
                       Variant="Variant.Filled">Save</MudButton>
            <MudButton Href="@LinkBuilder.TrainingManageHref()"
                       Color="Color.Default"
                       Variant="Variant.Outlined">Cancel</MudButton>
        </MudStack>
    </fieldset>
</EditForm>

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IUploadPathProvider Uploads
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    [Parameter] public int? Id { get; set; }
    private bool _isNew => Id is null;
    // [SupplyParameterFromForm] — see Organizations/Edit.razor for rationale.
    [SupplyParameterFromForm] private ContentModel _model { get; set; } = new();
    private string? _message;
    private bool _isError;
    private string _source = "url";
    private bool _uploading;
    private string? _uploadedPath;
    // Page count extracted server-side from the just-uploaded PDF
    // (computed in HandleUpload). Pre-fills TotalPageCount on the
    // model so Save() persists it alongside the new TrainingContent
    // row. Null for non-PDF formats — the eligibility rule then uses
    // duration / dwell instead.
    private int? _detectedPageCount;
    // Per-org auth: gated on being Admin of _at least one_ org AND (for
    // EDIT) of the specific content's owning org. The gate is re-checked
    // inside Save() — page-level checks can be bypassed via DOM poke.
    private bool _canSubmit;
    // Round-AF: Loading-vs-loaded sentinel. Set true at the END of every
    // OnInitializedAsync path (early-return OR success), so the
    // EditForm's <fieldset disabled> gate can take over from the
    // structural conditional-mount pattern used in round-AE. Initial
    // value false so the EditForm renders disabled + the @if sentinel
    // shows the loading stub until auth-check finishes.
    private bool _authChecked;
    // Orgs the caller is Admin of. Drives the NEW-mode dropdown + auto-pick.
    private List<OrganizationLite> _adminOrgs = new();
    private bool _adminOfMultipleOrgs;
    // EDIT-mode: the persisted owning org, loaded once on init, shown as a
    // locked badge above the title. Null if the requested content id doesn't
    // resolve or if the caller isn't Admin of it (in which case Save is
    // refused explicitly).
    private OrganizationLite? _existingOrg;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the route param + isNew flag
    // + loaded data so it stays in sync whether the user is creating or
    // editing training.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Training catalog", href: LinkBuilder.TrainingManageHref()),
            };
            if (!_isNew && _model is not null && !string.IsNullOrEmpty(_model.Title))
            {
                items.Add(new BreadcrumbItem(_model.Title, href: _model.Id > 0 ? LinkBuilder.TrainingHref(_model.Id) : null));
            }
            items.Add(new BreadcrumbItem(_isNew ? "New training" : "Edit", href: null, disabled: true));
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _isError = true;
            _message = "Only organization administrators can edit training content.";
            _authChecked = true;
            return;
        }

        // Org the caller is Admin of (one row per (Org, User, Admin)). Drives
        // both NEW and EDIT gates: if you can't Admin any org, neither mode
        // is allowed.
        await using var db = await DbFactory.CreateDbContextAsync();
        _adminOrgs = await db.OrganizationMemberships
            .Where(m => m.PersonUserId == userId && m.Role == OrganizationRole.Admin)
            .Join(db.Organizations,
                m => m.OrganizationId, o => o.Id,
                (m, o) => new OrganizationLite { Id = o.Id, Name = o.Name })
            .OrderBy(o => o.Name)
            .ToListAsync();
        _adminOfMultipleOrgs = _adminOrgs.Count > 1;

        _canSubmit = _adminOrgs.Count > 0;
        if (!_canSubmit)
        {
            _isError = true;
            _message = "Only organization administrators can edit training content.";
            _authChecked = true;
            return;
        }

        if (_isNew)
        {
            // NEW mode: auto-fill OrganizationId with the only admin org if
            // the caller Admin's exactly one. Multi-org Admins start at 0
            // and must pick deliberately.
            _model.OrganizationId = _adminOfMultipleOrgs ? 0 : _adminOrgs[0].Id;
            _authChecked = true;
            return;
        }

        // EDIT mode: load the existing row + verify the caller is Admin of
        // its org. The locked-org UX means no "switch ownership" affordance;
        // a non-admin viewer gets the "not authorized" path.
        var id = Id!.Value;
        var existing = await db.TrainingContents
            .Include(c => c.Organization)
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == id);
        if (existing is null)
        {
            _isError = true;
            _message = "Training content not found.";
            _canSubmit = false;
            _authChecked = true;
            return;
        }
        var isAdminOfOwning = await OrgAuth.IsOrgAdminAsync(userId, existing.OrganizationId);
        if (!isAdminOfOwning)
        {
            _isError = true;
            _message = "You don't have administrator rights for this training's organization.";
            _canSubmit = false;
            _authChecked = true;
            return;
        }
        _existingOrg = new OrganizationLite { Id = existing.OrganizationId, Name = existing.Organization.Name };
        _model = new ContentModel
        {
            Id = existing.Id,
            OrganizationId = existing.OrganizationId,
            Title = existing.Title,
            Description = existing.Description,
            Format = existing.Format,
            FilePathOrUrl = existing.FilePathOrUrl,
            DurationMinutes = existing.EstimatedDuration.HasValue ? (int?)existing.EstimatedDuration.Value.TotalMinutes : null,
        };
        _authChecked = true;
    }


    private async Task HandleUpload(InputFileChangeEventArgs e)
    {
        _uploading = true;
        try
        {
            var file = e.File;
            var safeName = $"{Guid.NewGuid():N}{Path.GetExtension(file.Name)}";
            var path = Uploads.GetTrainingUploadPath(safeName);
            await using var fs = File.Create(path);
            await file.OpenReadStream(50 * 1024 * 1024).CopyToAsync(fs);

            // PDF "view every page" verification needs to know how many
            // pages the file has. Count them now (the file is fully
            // written) so the Take page can compare its viewed-pages set
            // against TotalPageCount. Non-PDF uploads leave it null —
            // the eligibility rule then falls back to duration / dwell.
            if (string.Equals(file.ContentType, "application/pdf", StringComparison.OrdinalIgnoreCase)
                || safeName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                try
                {
                    _detectedPageCount = PdfPageCounter.Count(path);
                }
                catch
                {
                    _detectedPageCount = null;
                }
            }

            _uploadedPath = $"/uploads/training/{safeName}";
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task Save()
    {
        if (!_canSubmit)
        {
            _isError = true;
            _message = "You don't have permission to do that.";
            return;
        }

        // Extra defense-in-depth: re-validate the form-side dropdown
        // choice before insert. An admin of MORE than one org could pick
        // an org they don't Admin (auto-fills + dropdown-disables should
        // prevent this, but a malicious POST body might still let it slip
        // through). The OrgAuth double-check is the trust boundary.
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _isError = true;
            _message = "You don't have permission to do that.";
            return;
        }
        if (await OrgAuth.IsOrgAdminAsync(userId, _model.OrganizationId) is false)
        {
            _isError = true;
            _message = "You don't have administrator rights for the chosen organization.";
            return;
        }
        if (_model.OrganizationId <= 0)
        {
            _isError = true;
            _message = "Pick the owning organization.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        if (_isNew)
        {
            db.TrainingContents.Add(new TrainingContent
            {
                OrganizationId = _model.OrganizationId,
                Title = _model.Title,
                Description = _model.Description,
                Format = _model.Format,
                FilePathOrUrl = _model.FilePathOrUrl,
                EstimatedDuration = _model.DurationMinutes.HasValue
                    ? TimeSpan.FromMinutes(_model.DurationMinutes.Value)
                    : null,
                TotalPageCount = _detectedPageCount,
            });
            await db.SaveChangesAsync();
            Nav.NavigateTo(LinkBuilder.TrainingManageHref());
            return;
        }
        var existing = await db.TrainingContents.FindAsync(Id!.Value);
        if (existing is null)
        {
            _isError = true;
            _message = "Training content not found.";
            return;
        }
        // Trust boundary: a non-Admin of the existing org can't mutate this
        // row even if they bypass the page gate. Belt-and-suspenders.
        if (existing.OrganizationId != _model.OrganizationId
            || !await OrgAuth.IsOrgAdminAsync(userId, existing.OrganizationId))
        {
            _isError = true;
            _message = "You don't have administrator rights for this training's organization.";
            return;
        }
        existing.Title = _model.Title;
        existing.Description = _model.Description;
        existing.Format = _model.Format;
        existing.FilePathOrUrl = _model.FilePathOrUrl;
        existing.EstimatedDuration = _model.DurationMinutes.HasValue
            ? TimeSpan.FromMinutes(_model.DurationMinutes.Value) : null;
        // Refresh TotalPageCount from the latest PDF if the admin
        // uploaded a new one. Version bump below resets any in-flight
        // activity for this content — that's the contract with
        // TrainingActivityRow.PK being versioned.
        existing.TotalPageCount = _detectedPageCount ?? existing.TotalPageCount;
        existing.Version += 1;
        existing.VersionDateUtc = DateTime.UtcNow;
        await db.SaveChangesAsync();
        Nav.NavigateTo(LinkBuilder.TrainingManageHref());
    }

    private sealed class ContentModel
    {
        public int Id { get; set; }
        [Required, StringLength(200)] public string Title { get; set; } = "";
        [StringLength(2000)] public string? Description { get; set; }
        public TrainingFormat Format { get; set; }
        [Required, StringLength(600)] public string FilePathOrUrl { get; set; } = "";
        public int? DurationMinutes { get; set; }
        // [Required] isn't enough — 0 is a valid int. Add a Range so the
        // form-side validator rejects "pick an org" (0) before reaching
        // the service; the service-side check still re-validates.
        [Required, Range(1, int.MaxValue, ErrorMessage = "Pick the owning organization.")]
        public int OrganizationId { get; set; }
    }

    private sealed class OrganizationLite
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
}
