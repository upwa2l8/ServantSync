@page "/Training/Manage"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Manage training</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-3 flex-wrap" Spacing="2">
    <div>
        <MudText Typo="Typo.h4" Class="mb-0 gradient-text">Training catalog</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Training content you administer. Since round N, training belongs to a single
            organization — this page shows the union of every catalog you Admin. Volunteers
            only ever see
            <em>their</em> outstanding requirements + history on the
            <MudLink Href="Training">/Training</MudLink> page; this is the org-admin edit surface.
        </MudText>
        @if (_managedOrgNames.Count > 0)
        {
            <MudStack Row="true" Spacing="1" Class="mt-1 flex-wrap">
                <strong class="mud-text-secondary">Admin of:</strong>
                @foreach (var name in _managedOrgNames)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@name</MudChip>
                }
            </MudStack>
        }
    </div>
    <MudButton Href="@LinkBuilder.TrainingNewHref()"
               Color="Color.Primary"
               Variant="Variant.Filled">+ New training</MudButton>
</MudStack>

@* Round-FR-2 navbar surfacing addition: the in-person training
   sessions surface exists at /Organizations/{OrgId}/Training/Sessions,
   hidden one level deep inside each Organization's "Org training"
   tab. Round-FR-2 ships the 4 sessions pages but they had no
   discoverable entry from /Training/Manage. This card gives the
   coordinator a one-click drill-in to the per-org sessions list
   for every org they manage. Per-org links (not a single
   umbrella list) because each session belongs to exactly one org
   and the cross-org aggregate view has no meaningful lifecycle. *@
@if (_managedOrgsFull.Count > 0 && _denyReason is null && _contents is not null)
{
    <MudCard Outlined="true" Class="glass-card mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Outlined.CalendarMonth" Class="me-1" />
                        In-person training sessions
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@_managedOrgsFull.Count org@(_managedOrgsFull.Count == 1 ? "" : "s")</MudChip>
                </MudStack>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">
                Schedule in-person training events for each organization you administer. Volunteers can sign up via the per-org sessions page or from their My Schedule page (after Frank-FR-2 came online earlier this was the only path that worked for managers, but it still lives here for full CRUD over each session).
            </MudText>
            <MudGrid Spacing="2">
                @foreach (var orgRow in _managedOrgsFull)
                {
                    <MudItem xs="12" md="4">
                        <MudButton Href="@LinkBuilder.OrganizationSessionsHref(orgRow.Id)"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   FullWidth="true"
                                   title="@($"Browse the upcoming + past in-person training sessions for {orgRow.Name}.")">
                            @orgRow.Name — sessions →
                        </MudButton>
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>
    </MudCard>
}

@if (_denyReason is not null)
{
    <MudAlert Severity="Severity.Warning">
        @_denyReason <MudLink Href="Training">Back to my training</MudLink>.
    </MudAlert>
}
else if (_contents is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_contents.Any())
{
    <MudAlert Severity="Severity.Info">
        You don't administer any catalog yet — start by creating training in one of the
        organizations you manage, or ask another admin to grant you Admin rights on their org.
    </MudAlert>
}
else
{
    <MudPaper Outlined="true" Class="glass-card">
        <MudTable T="ContentRow" Items="_contents" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Organization</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Format</MudTh>
                <MudTh>Version</MudTh>
                <MudTh>Required by</MudTh>
                <MudTh Class="text-end"></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudLink Href="@LinkBuilder.OrganizationHref(context.OrganizationId)">@context.OrganizationName</MudLink>
                </MudTd>
                <MudTd>
                    <MudLink Href="@LinkBuilder.TrainingHref(context.Id)">@context.Title</MudLink>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Description</MudText>
                </MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Format</MudChip></MudTd>
                <MudTd>v@context.Version</MudTd>
                <MudTd>
                    @foreach (var r in context.Requirements)
                    {
                        <div>
                            @if (r.OrganizationId.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">Org</MudChip>
                                <MudLink Href="@LinkBuilder.OrganizationHref(r.OrganizationId.Value)">@r.OrganizationName</MudLink>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Slot</MudChip>
                                @r.SlotPath
                            }
                        </div>
                    }
                </MudTd>
                <MudTd Class="text-end">
                    <MudButton Href="@LinkBuilder.TrainingEditHref(context.Id)"
                               Color="Color.Default"
                               Variant="Variant.Outlined"
                               Size="Size.Small"
                               Class="me-1">Edit</MudButton>
                    <MudButton Href="@LinkBuilder.TrainingHref(context.Id)"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Size="Size.Small">Take</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@inject ITrainingService TrainingService
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@code {
    private List<ContentRow>? _contents;
    // Per-org admin badges in the header. Computed once per load so the
    // markup is cheap; mirrors exactly the union-of-managed-orgs the
    // catalog itself is sourced from.
    private List<string> _managedOrgNames = new();
    // Round-FR-2 discoverability: per-org (id + name) tuples to feed the
    // "In-person training sessions" card's per-org links. Distinct from
    // _managedOrgNames above — that one is a string list for the header
    // badges (no link target needed) while this one is a full shape for
    // the per-org link generation. Both share the same source list
    // (TrainingService.ListManageableTrainingAsync's Organization nav).
    private List<ManagedOrg> _managedOrgsFull = new();
    private bool _authorized;
    private string? _denyReason;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Static for this page — no dynamic route
    // params, no loaded data that affects the trail.
    private List<BreadcrumbItem> BreadcrumbItems = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("Training catalog", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        // No broad try/catch on purpose: if the OrgAuth lookup or the
        // TrainingContent query throws, Blazor's default error UI is
        // louder and more diagnostic than a generic yellow alert. The
        // user-input branches that warrant a polite message
        // (unauthenticated, not an org admin) are handled inline below
        // by setting _denyReason — those are the only failure modes
        // the markup should ever pre-empt.
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _denyReason = "You must be signed in to manage training.";
            return;
        }
        _authorized = await OrgAuth.IsAnyOrgAdminAsync(userId);
        if (!_authorized)
        {
            _denyReason = "Only organization admins can manage the training catalog.";
            return;
        }

        // The service does the org-Auth gate inside the SQL itself —
        // joins through OrganizationMemberships with Role=Admin — so the
        // page handler doesn't need to enumerate "admin of which orgs"
        // and pass them in. One round-trip; the page receives only the
        // catalogs the caller actually owns.
        var raw = await TrainingService.ListManageableTrainingAsync(userId);
        _managedOrgNames = raw
            .Select(c => c.Organization?.Name ?? "(unknown)")
            .Distinct()
            .OrderBy(n => n)
            .ToList();
        // Distinct (Id, Name) tuples so the per-org sessions card drives
        // its buttons off the same source list. The .Distinct() comes
        // first because ListManageableTrainingAsync returns one row per
        // catalog and an admin managing 3 TrainingContents in the same
        // org would otherwise triple-count.
        _managedOrgsFull = raw
            .Where(c => c.Organization is not null)
            .GroupBy(c => c.OrganizationId)
            .Select(g => new ManagedOrg { Id = g.Key, Name = g.First().Organization!.Name })
            .OrderBy(o => o.Name)
            .ToList();

        // Fold the per-row requirements join into a thin shape to keep
        // the table render cheap. The managed-orgs join still happens
        // server-side via EF fix-up.
        await using var db = await DbFactory.CreateDbContextAsync();
        _contents = raw.Select(c => new ContentRow
        {
            Id = c.Id,
            OrganizationId = c.OrganizationId,
            OrganizationName = c.Organization?.Name ?? "(unknown)",
            Title = c.Title,
            Format = c.Format,
            Version = c.Version,
            Description = c.Description,
        }).ToList();

        // Bulk-load the requirements so the "Required by" column renders
        // without an N+1. Single query keyed on the visible content ids.
        var ids = _contents.Select(c => c.Id).ToHashSet();
        var reqs = await db.TrainingRequirements
            .Where(r => ids.Contains(r.TrainingContentId))
            .Select(r => new ReqRow
            {
                TrainingContentId = r.TrainingContentId,
                OrganizationId = r.OrganizationId,
                OrganizationName = r.Organization!.Name,
                ServiceSlotId = r.ServiceSlotId,
                SlotPath = r.ServiceSlot!.Ministry.Organization.Name + " › "
                    + r.ServiceSlot.Ministry.Name + " › " + r.ServiceSlot.Name,
            })
            .ToListAsync();
        foreach (var row in _contents)
        {
            row.Requirements = reqs.Where(r => r.TrainingContentId == row.Id).ToList();
        }
    }

    private class ContentRow
    {
        public int Id { get; set; }
        public int OrganizationId { get; set; }
        public string OrganizationName { get; set; } = "";
        public string Title { get; set; } = "";
        public TrainingFormat Format { get; set; }
        public int Version { get; set; }
        public string? Description { get; set; }
        public List<ReqRow> Requirements { get; set; } = new();
    }

    private class ReqRow
    {
        public int TrainingContentId { get; set; }
        public int? OrganizationId { get; set; }
        public string OrganizationName { get; set; } = "";
        public int? ServiceSlotId { get; set; }
        public string SlotPath { get; set; } = "";
    }

    private class ManagedOrg
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
    }
}
