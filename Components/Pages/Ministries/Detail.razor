@page "/Organizations/{OrgId:int}/Ministries/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_ministry?.Name ?? "Ministry")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (!_hasLoaded)
{
    <MudText><em>Loading...</em></MudText>
}
else if (_ministry is null)
{
    <MudAlert Severity="Severity.Warning" Class="mt-3">
        <MudText Typo="Typo.h5">Ministry not found</MudText>
        <MudText>
            No ministry matches id <code>@Id</code> in organization <code>@OrgId</code>. Try the
            <MudLink Href="Organizations">organization list</MudLink>.
        </MudText>
    </MudAlert>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <div>
            <MudText Typo="Typo.h4">@_ministry.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@_ministry.Description</MudText>
        </div>
        <MudStack Row="true" Spacing="2">
            @* Personal-preference toggle. Anyone who is a member of the
               parent org sees this; out-of-org visitors are redirected to
               the Not Found panel above before reaching this markup.
               Directors do NOT auto-follow a ministry they manage;
               explicit opt-in is the contract (mirrors the service gate). *@
            @if (_isInOrg)
            {
                @if (_isInterested)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="LeaveThisMinistryAsync"
                               Disabled="@_busyToggle"
                               title="Stop showing this ministry's open shifts on your Browse page">
                        @(_busyToggle ? "Leaving..." : "Leave this ministry")
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="JoinThisMinistryAsync"
                               Disabled="@_busyToggle"
                               title="Show this ministry's open shifts on your Browse page">
                        @(_busyToggle ? "Joining..." : "Join this ministry")
                    </MudButton>
                }
            }
            @* Admin-only "Edit ministry" affordance. Server gate on
               Ministries/Edit.razor enforces the same check; hiding here
               avoids 403-on-submit UX. *@
            @if (_canManageOrg)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           Href="@LinkBuilder.MinistryEditHref(OrgId, Id)">
                    Edit ministry
                </MudButton>
            }
            @* Round-AW: ministry coordinator (Admin/Coordinator of the
               owning org OR the ministry's own CoordinatorPersonUserId
               OR a parent-ministry coordinator) gets the Signups link
               so they can see who has marked the ministry as followed.
               _canManageMinistry already covers Admin/Coordinator of
               the parent org via CanManageMinistryAsync; SystemAdmin is
               added by the Signups page's own gate (read-side widening
               is fine even though navigation visibility here stays
               per-org scoped). *@
            @if (_canManageMinistry)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Href="@LinkBuilder.MinistrySignupsHref(OrgId, Id)">
                    View signups
                </MudButton>
            }
        </MudStack>
    </MudStack>

    @* Coordinator card is intentionally always-rendered (per the user
       requirement that "each coordinator email can be visible"). The name
       falls back to "-" when no CoordinatorPersonUserId is set; the email
       / phone come from the ministry's own columns and are visible to any
       authenticated page visitor. *@
    <MudCard Class="mb-4">
        <MudCardHeader>Director</MudCardHeader>
        <MudCardContent>
            <MudText><strong>@(_ministry.CoordinatorPerson?.DisplayName ?? "-")</strong></MudText>
            <MudText>@_ministry.CoordinatorEmail &nbsp; <span class="mud-text-secondary">@_ministry.CoordinatorPhone</span></MudText>
        </MudCardContent>
    </MudCard>

    @if (_lastMessage is not null)
    {
        <MudAlert Severity="@(_lastIsError ? Severity.Error : Severity.Success)" Dense="true" Class="mb-3">
            @_lastMessage
        </MudAlert>
    }

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
        <MudText Typo="Typo.h5">Service slots (volunteer opportunities)</MudText>
        @* Round-BA: gate widened from `_canManageOrg` (org-Admin only) to
           `_canManageMinistry` (CanManageMinistryAsync). Both target pages
           — ServiceSlots/Edit.razor create path and Leagues/Teams/New.razor —
           already use CanManageMinistryAsync as their server-side gate, so
           the button visibility now matches the action-allowed state.
           Previously a ministry coordinator could Schedule shifts in slots
           they manage but got 403'd on CREATING a slot (Create was gated
           on OrgAuth alone). *@
        @if (_canManageMinistry)
        {
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Href="@LinkBuilder.SlotNewHref(OrgId, Id)">
                    + Add slot
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           Href="@LinkBuilder.TeamNewHref(Id)">
                    + Add team
                </MudButton>
            </MudStack>
        }
    </MudStack>
    @* League-CTA explainer: a ministry becomes a League (i.e. shows up
       under the Leagues nav / gets standings & games surfaces) the
       moment it owns at least one <c>Team</c>. Until then the ministry is
       reachable via this page only, which made the conversion invisible
       to admins. The explainer turns the implicit state into an explicit
       one and points the admin at the right button above. *@
    @if (_canManageMinistry && !_ministry.Teams.Any())
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mud-text-secondary mb-2" Style="font-size: 0.875rem;">
            <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" />
            <span>A ministry becomes a <strong>league</strong> (visible on the Leagues page
            with standings + games + team rosters) the moment it has at least one team.
            Use <em>+ Add team</em> above to convert it.</span>
        </MudStack>
    }
    @if (!_ministry.ServiceSlots.Any())
    {
        <MudAlert Severity="Severity.Info">No service slots yet.</MudAlert>
    }
    else
    {
        <MudList T="ServiceSlot">
            @foreach (var s in _ministry.ServiceSlots.OrderBy(s => s.Name))
            {
                <MudListItem>
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudLink Href="@LinkBuilder.SlotHref(OrgId, Id, s.Id)">@s.Name</MudLink>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@s.Assignments.Count scheduled</MudChip>
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(s.Description))
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@s.Description</MudText>
                    }
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   Href="@ScheduleHref(s.Id)">Schedule</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   Href="@LinkBuilder.SlotEditHref(OrgId, Id, s.Id)">Edit</MudButton>
                        @* Round-FR-7: per-slot Subscribe toggle. The
                           pill flips between "Subscribe" and
                           "Subscribed ✓" so the volunteer can pin
                           the slot to their "My slots" filter on /Open
                           without leaving the ministry page. In-org
                           members only; out-of-org visitors are
                           redirected to the Not Found panel above. *@
                        @if (_isInOrg)
                        {
                            @if (_subscribedSlotIds.Contains(s.Id))
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                           Disabled="@(_busySlotId == s.Id)"
                                           OnClick="() => ToggleSlotSubscriptionAsync(s.Id, s.Name)"
                                           Title="Stop including this slot's shifts in the My slots filter on /Open">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="me-1" />
                                    @(_busySlotId == s.Id ? "Updating…" : "Subscribed")
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                           Disabled="@(_busySlotId == s.Id)"
                                           OnClick="() => ToggleSlotSubscriptionAsync(s.Id, s.Name)"
                                           Title="Add this slot's shifts to the My slots filter on /Open">
                                    @(_busySlotId == s.Id ? "Updating…" : "Subscribe")
                                </MudButton>
                            }
                        }
                    </MudStack>
                </MudListItem>
            }
        </MudList>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject IMinistryInterestService MinistryInterest
@inject ISlotInterestService Slots
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int Id { get; set; }
    private Ministry? _ministry;
    // Admin-of-this-org gate, drives Edit + Add-slot affordances. Single
    // source of truth = OrgAuthService.IsOrgAdminAsync; the same gate is
    // re-checked server-side by Ministries/Edit.razor and
    // ServiceSlots/Edit.razor. Default false (deny) until OnInitialized
    // resolves the user id.
    private bool _canManageOrg;
    // Coordinator-or-admin gate for this ministry. Wider than
    // _canManageOrg (Admin only) so Coordinators can also drive the
    // Schedule action on the slot list. Same gate is re-checked
    // server-side by ServiceSlots/Schedule.razor via
    // CanManageSlotAsync. Default false (deny) until OnInitialized
    // resolves the user id.
    private bool _canManageMinistry;
    // True iff the signed-in user is a member of the parent org. Drives
    // the Join/Leave button visibility AND gates the page itself (a
    // signed-in user not in the org gets the Not Found panel rather than
    // this ministry's data — strict per-org sandbox).
    private bool _isInOrg;
    // True iff the signed-in user has marked this ministry as
    // "interested" via MinistryInterestService.JoinAsync. Drives the
    // button label (Join vs Leave).
    private bool _isInterested;
    // Round-FR-7: per-slot subscription cache. Built once in
    // OnInitializedAsync via ISlotInterestService.ListSubscribedAsync.
    // Drives the Subscribe/Subscribed pill per slot row. Optimistic
    // local mutation in ToggleSlotSubscriptionAsync; Reload re-fetches.
    private HashSet<int> _subscribedSlotIds = new();
    private int _busySlotId;
    // True after OnInitializedAsync has completed so the renderer can
    // distinguish "still loading" from "loaded but no match" / "loaded
    // but cross-org access refused" without an indefinite spinner.
    private bool _hasLoaded;
    private string _userId = "";
    // Inline alert for the Join/Leave result. Cleared on action entry,
    // re-set on action exit. Shared with other handlers
    // (UpdateRole-style pattern) so consistent messaging appears at the
    // same place on the page.
    private string? _lastMessage;
    private bool _lastIsError;
    private bool _busyToggle;

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from route params so it stays in
    // sync if the user navigates between ministries.
    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("Organizations", href: "Organizations"),
        new BreadcrumbItem($"Org #{OrgId}", href: LinkBuilder.OrganizationHref(OrgId)),
        new BreadcrumbItem(_ministry?.Name ?? $"Ministry #{Id}", href: null, disabled: true)
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        await using var db = await DbFactory.CreateDbContextAsync();

        // Server-side cross-org gate: search by (Id, OrganizationId) so
        // an out-of-org visitor can't even see the ministry's description
        // by guessing the Id. _ministry stays null and the Not Found
        // branch in the markup renders.
        _ministry = await db.Ministries
            .Include(m => m.CoordinatorPerson)
            .Include(m => m.ServiceSlots).ThenInclude(s => s.Assignments)
            .FirstOrDefaultAsync(m => m.Id == Id && m.OrganizationId == OrgId);

        // Cached membership check (used by the Join/Leave button) and
        // admin gate (Edit + Add-slot) default to false until we resolve
        // them. Both run only if _userId is non-empty.
        if (!string.IsNullOrEmpty(_userId))
        {
            _canManageOrg = await OrgAuth.IsOrgAdminAsync(_userId, OrgId);
            _canManageMinistry = await OrgAuth.CanManageMinistryAsync(_userId, Id);
            _isInOrg = await db.OrganizationMemberships
                .AnyAsync(m => m.OrganizationId == OrgId && m.PersonUserId == _userId);
            _isInterested = _isInOrg && await db.MinistryInterests
                .AnyAsync(i => i.PersonUserId == _userId && i.MinistryId == Id);

            // Round-FR-7: precompute the slot-level subscription set so
            // each row in the list can render its Subscribe/Subscribed
            // pill without an N+1 chase.
            if (_isInOrg)
            {
                var subs = await Slots.ListSubscribedAsync(_userId);
                _subscribedSlotIds = subs.Where(s => s.ServiceSlot.MinistryId == Id)
                                          .Select(s => s.ServiceSlotId)
                                          .ToHashSet();
            }
        }

        _hasLoaded = true;
    }

    private async Task JoinThisMinistryAsync()
    {
        _busyToggle = true;
        _lastMessage = null;
        try
        {
            var result = await MinistryInterest.JoinAsync(_userId, _userId, Id);
            switch (result)
            {
                case MinistryInterestJoinResult.Joined:
                case MinistryInterestJoinResult.AlreadyJoined:
                    _isInterested = true;
                    _lastIsError = false;
                    _lastMessage = result == MinistryInterestJoinResult.Joined
                        ? $"You're now following {_ministry?.Name}. Its open shifts will show up on your Browse page."
                        : "You were already following this ministry.";
                    break;
                case MinistryInterestJoinResult.PermissionDenied:
                    _lastIsError = true;
                    _lastMessage = "You can only follow ministries in organizations you belong to.";
                    break;
                case MinistryInterestJoinResult.MinistryNotFound:
                    _lastIsError = true;
                    _lastMessage = "This ministry no longer exists.";
                    break;
            }
        }
        finally
        {
            _busyToggle = false;
        }
    }

    // Schedule-button href: managers (Admin or Coordinator) go to the
    // scheduling editor so they can create assignments / open shifts;
    // everyone else (volunteer, in-org member, out-of-org visitor)
    // follows the slot name to the read-only published schedule view
    // (ServiceSlots/Detail.razor) — the "actual published schedule"
    // the slot-list affordance is meant to surface for non-managers.
    private string ScheduleHref(int slotId) => _canManageMinistry
        ? LinkBuilder.SlotScheduleHref(OrgId, Id, slotId)
        : LinkBuilder.SlotHref(OrgId, Id, slotId);

    private async Task LeaveThisMinistryAsync()
    {
        _busyToggle = true;
        _lastMessage = null;
        try
        {
            var result = await MinistryInterest.LeaveAsync(_userId, _userId, Id);
            switch (result)
            {
                case MinistryInterestLeaveResult.Left:
                case MinistryInterestLeaveResult.NotInterested:
                    _isInterested = false;
                    _lastIsError = false;
                    _lastMessage = result == MinistryInterestLeaveResult.Left
                        ? $"You stopped following {_ministry?.Name}. Its open shifts will no longer appear on your Browse page."
                        : "You weren't following this ministry.";
                    break;
                case MinistryInterestLeaveResult.PermissionDenied:
                    _lastIsError = true;
                    _lastMessage = "You can only stop following ministries in organizations you belong to.";
                    break;
                case MinistryInterestLeaveResult.MinistryNotFound:
                    _lastIsError = true;
                    _lastMessage = "This ministry no longer exists.";
                    break;
            }
        }
        finally
        {
            _busyToggle = false;
        }
    }

    /// <summary>
    /// Per-slot Subscribe / Unsubscribe toggle (Round-FR-7). Optimistically
    /// flips the local _subscribedSlotIds cache so the pill updates
    /// instantly; the ISlotInterestService call below reconciles with the DB.
    /// On a server refusal (PermissionDenied / SlotNotFound) we revert the
    /// optimistic flip so the UI stays in sync with persisted state.
    /// </summary>
    private async Task ToggleSlotSubscriptionAsync(int slotId, string slotNameForError)
    {
        if (string.IsNullOrEmpty(_userId)) return;

        var wasSubscribed = _subscribedSlotIds.Contains(slotId);
        _busySlotId = slotId;
        _lastMessage = null;
        try
        {
            if (wasSubscribed)
            {
                _subscribedSlotIds.Remove(slotId);
                var result = await Slots.UnsubscribeAsync(_userId, _userId, slotId);
                if (result == SlotInterestLeaveResult.PermissionDenied)
                {
                    _subscribedSlotIds.Add(slotId);  // revert
                    _lastIsError = true;
                    _lastMessage = "You can only stop subscribing to slots in organizations you belong to.";
                }
                else if (result == SlotInterestLeaveResult.SlotNotFound)
                {
                    _subscribedSlotIds.Add(slotId);  // revert
                    _lastIsError = true;
                    _lastMessage = "This slot no longer exists.";
                }
            }
            else
            {
                _subscribedSlotIds.Add(slotId);
                var result = await Slots.SubscribeAsync(_userId, _userId, slotId, SlotInterestSource.Explicit);
                if (result == SlotInterestJoinResult.PermissionDenied)
                {
                    _subscribedSlotIds.Remove(slotId);  // revert
                    _lastIsError = true;
                    _lastMessage = "You can only subscribe to slots in organizations you belong to.";
                }
                else if (result == SlotInterestJoinResult.SlotNotFound)
                {
                    _subscribedSlotIds.Remove(slotId);  // revert
                    _lastIsError = true;
                    _lastMessage = "This slot no longer exists.";
                }
            }
        }
        finally
        {
            _busySlotId = 0;
        }
    }
}
