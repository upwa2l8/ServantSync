@page "/Organizations/{OrgId:int}/Ministries/{Id:int}/Edit"
@page "/Organizations/{OrgId:int}/Ministries/New"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_isNew ? "New ministry" : "Edit ministry")</PageTitle>

<MudBreadcrumbs Items="BreadcrumbItems" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-2 gradient-text">@(_isNew ? "New ministry" : "Edit ministry")</MudText>
<StatusMessage Message="@_message" IsError="@_isError" />

<EditForm Model="_model" OnValidSubmit="Save" FormName="min">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <MudTextField T="string"
                  Label="Name"
                  @bind-Value="_model.Name"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-3"
                  Required="true"
                  RequiredError="Name is required" />
    <MudTextField T="string"
                  Label="Description"
                  @bind-Value="_model.Description"
                  Lines="3"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-3" />

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-3">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Icon:</MudText>
        <MudIcon Icon="@(_model.Icon ?? MinistryIcons.Default)" Size="Size.Medium" Color="Color.Primary" />
        <MudSelect T="string"
                   @bind-Value="_model.Icon"
                   Label="Ministry icon"
                   Variant="Variant.Outlined"
                   Margin="Margin.Dense"
                   Dense="true"
                   Style="max-width: 320px;">
            <MudSelectItem T="string" Value="@((string?)null)">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@MinistryIcons.Default" Size="Size.Small" />
                    <span>Default (Church)</span>
                </MudStack>
            </MudSelectItem>
            @foreach (var opt in MinistryIcons.All)
            {
                <MudSelectItem T="string" Value="@opt.Value">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@opt.Value" Size="Size.Small" />
                        <span>@opt.Label</span>
                    </MudStack>
                </MudSelectItem>
            }
        </MudSelect>
    </MudStack>

    <MudGrid Spacing="2" Class="mb-2">
        <MudItem xs="12" md="6">
            <MudSelect T="string"
                       @bind-Value="_model.CoordinatorPersonUserId"
                       Label="Director"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense">
                <MudSelectItem T="string" Value="@("")">— none —</MudSelectItem>
                @foreach (var p in _members)
                {
                    <MudSelectItem T="string" Value="@p.UserId">@p.DisplayName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudTextField T="string"
                          Label="Director email"
                          InputType="InputType.Email"
                          @bind-Value="_model.CoordinatorEmail"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
        </MudItem>
    </MudGrid>
    <MudTextField T="string"
                  Label="Director phone"
                  @bind-Value="_model.CoordinatorPhone"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Class="mb-3" />

    <MudStack Row="true" Spacing="2">
        <MudButton ButtonType="ButtonType.Submit"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!_canSubmit)">Save</MudButton>
        <MudButton Href="@CancelHref"
                   Color="Color.Default"
                   Variant="Variant.Outlined">Cancel</MudButton>
    </MudStack>
</EditForm>

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject IOrganizationMinistryService MinistryUpsert
@code {
    [Parameter] public int OrgId { get; set; }
    [Parameter] public int? Id { get; set; }
    private bool _isNew => Id is null;
    // EditForm requires the bound model to be a PROPERTY marked with
    // [SupplyParameterFromForm] — without it the form data is submitted
    // but never deserialized into the model, so Save gets an empty _model
    // and DataAnnotationsValidator flags Name as required. A private field
    // is silently ignored by the form-binding pipeline. (See
    // Components/Account/Pages/Login.razor for the same comment.)
    [SupplyParameterFromForm] private MinModel _model { get; set; } = new();
    private List<Person> _members = new();
    private string? _message;
    private bool _isError;
    private bool _canSubmit;
    // The signed-in user's id cached at OnInitializedAsync so Save() can
    // forward it to OrganizationMinistryService.UpsertAsync without a
    // fresh Auth call. Empty string (never null) keeps the gate from
    // misclassifying an anonymous request as "admin".
    private string _userId = "";

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the route params + isNew flag
    // so it stays in sync whether the user is creating or editing a ministry.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new BreadcrumbItem("Home", href: ""),
                new BreadcrumbItem("Organizations", href: "Organizations"),
                new BreadcrumbItem($"Org #{OrgId}", href: $"Organizations/{OrgId}"),
            };
            if (!_isNew)
            {
                items.Add(new BreadcrumbItem($"Ministry #{Id}", href: $"Organizations/{OrgId}/Ministries/{Id}"));
            }
            items.Add(new BreadcrumbItem(_isNew ? "New ministry" : "Edit", href: null, disabled: true));
            return items;
        }
    }

    private string CancelHref => _isNew ? $"Organizations/{OrgId}" : $"Organizations/{OrgId}/Ministries/{Id}";

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        // Tightened from CanManageOrgAsync (Admin OR Coordinator) to
        // IsOrgAdminAsync (Admin only). Ministry management is now an
        // Admin-only action; Coordinators can still view ministries
        // (via the org Detail page) but can't create/edit them.
        _canSubmit = !string.IsNullOrEmpty(_userId)
            && await OrgAuth.IsOrgAdminAsync(_userId, OrgId);
        if (!_canSubmit)
        {
            _isError = true;
            _message = "You don't have permission to manage ministries in this organization.";
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();
        _members = await db.OrganizationMemberships
            .Where(m => m.OrganizationId == OrgId)
            .Select(m => m.Person)
            .OrderBy(p => p.LastName)
            .ToListAsync();

        if (_isNew) return;
        var min = await db.Ministries
            .FirstOrDefaultAsync(m => m.Id == Id!.Value && m.OrganizationId == OrgId);
        if (min is null)
        {
            _isError = true;
            _message = "Ministry not found.";
            return;
        }
        _model = new MinModel
        {
            Name = min.Name,
            Description = min.Description,
            CoordinatorPersonUserId = min.CoordinatorPersonUserId,
            CoordinatorEmail = min.CoordinatorEmail,
            CoordinatorPhone = min.CoordinatorPhone,
            Icon = min.Icon,
        };
    }


    private async Task Save()
    {
        if (!_canSubmit)
        {
            _isError = true;
            _message = "You don't have permission to do that.";
            return;
        }

        // Route through the service so the Admin-only gate lives in one
        // place. The page still does its own IsOrgAdminAsync gate (defense
        // in depth: hide the form), but Save re-validates against the
        // service so a stale page render can't sneak a write through.
        var result = await MinistryUpsert.UpsertAsync(
            callerUserId: _userId,
            organizationId: OrgId,
            ministryId: Id,
            name: _model.Name,
            description: _model.Description,
            coordinatorPersonUserId: _model.CoordinatorPersonUserId,
            coordinatorEmail: _model.CoordinatorEmail,
            coordinatorPhone: _model.CoordinatorPhone,
            icon: _model.Icon);

        switch (result)
        {
            case MinistryUpsertResult.Saved:
                Nav.NavigateTo(_isNew ? $"Organizations/{OrgId}" : $"Organizations/{OrgId}/Ministries/{Id}");
                return;
            case MinistryUpsertResult.NotFound:
                _isError = true;
                _message = "Ministry not found.";
                return;
            case MinistryUpsertResult.PermissionDenied:
                _isError = true;
                _message = "You don't have permission to manage ministries in this organization.";
                return;
        }
    }

    private class MinModel
    {
        [Required, StringLength(160)] public string Name { get; set; } = "";
        [StringLength(2000)] public string? Description { get; set; }
        public string? CoordinatorPersonUserId { get; set; }
        [StringLength(120), EmailAddress] public string? CoordinatorEmail { get; set; }
        [StringLength(40)] public string? CoordinatorPhone { get; set; }
        [StringLength(80)] public string? Icon { get; set; }
    }
}
