@page "/Games/{GameId:int}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_game is null ? "Game" : $"{_game.HomeTeam.Name} vs {_game.AwayTeam.Name}")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (_game is null)
{
    <MudText><em>Loading…</em></MudText>
}
else
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap gap-2">
        <div>
            <MudText Typo="Typo.h4">@_game.HomeTeam.Name vs @_game.AwayTeam.Name</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                <MudLink Href="@LinkBuilder.LeagueHref(_game.MinistryId)">@_game.Ministry?.Name</MudLink>
                · @_game.Arena.Name
            </MudText>
        </div>
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="@LinkBuilder.LeagueScheduleHref(_game.MinistryId)">Back to schedule</MudButton>
            @if (_canManage)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@LinkBuilder.GameEditHref(GameId)">Edit</MudButton>
            }
        </MudStack>
    </MudStack>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="7">
            <MudCard>
                <MudCardContent>
                    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
                        <MudItem xs="5">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudLink Href="@LinkBuilder.TeamHref(_game.HomeTeamId)" Typo="Typo.h5">@_game.HomeTeam.Name</MudLink>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">home</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="2">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudChip T="string" Size="Size.Large" Color="@AssignmentStatusUi.MudColorFor(_game.Status)">
                                    @(_game.HomeScore?.ToString() ?? "—") : @(_game.AwayScore?.ToString() ?? "—")
                                </MudChip>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@_game.Status</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="5">
                            <MudStack AlignItems="AlignItems.Center" Spacing="0">
                                <MudLink Href="@LinkBuilder.TeamHref(_game.AwayTeamId)" Typo="Typo.h5">@_game.AwayTeam.Name</MudLink>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">away</MudText>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>

            <MudCard Class="mt-3">
                <MudCardHeader>When & where</MudCardHeader>
                <MudCardContent>
                    <div><strong>Start:</strong> <LocalTime Utc="@_game.StartUtc" Format="ddd, MMM d yyyy h:mm tt" /></div>
                    <div><strong>End:</strong> <LocalTime Utc="@_game.EndUtc" Format="h:mm tt" /></div>
                    <div><strong>Arena:</strong> @_game.Arena.Name @(_game.Arena.SurfaceType is null ? "" : $"({_game.Arena.SurfaceType})")</div>
                    @if (!string.IsNullOrEmpty(_game.Arena.Address))
                    {
                        <div><strong>Address:</strong> @_game.Arena.Address</div>
                    }
                    @if (!string.IsNullOrEmpty(_game.Notes))
                    {
                        <div class="mt-2"><strong>Notes:</strong> @_game.Notes</div>
                    }
                </MudCardContent>
            </MudCard>

            @if (_canManage)
            {
                <MudCard Class="mt-3">
                    <MudCardHeader>Record final score</MudCardHeader>
                    <MudCardContent>
                        @* No FormName="…" on purpose: this EditForm is
                           mounted inside an @if(_canManage) branch of
                           an @rendermode InteractiveServer page. Blazor's
                           enhanced-form handling treats any
                           <EditForm FormName="X"> as static-form-SSR-capable;
                           mounting such a form mid-render into an
                           already-interactive circuit triggers the
                           SignalR-drop regression captured in
                           STATUS.md → Known quirks. Keep this comment if
                           you ever add a FormName back. *@
                        <EditForm Model="_scoreModel" OnValidSubmit="SaveScore">
                            <MudGrid Spacing="2" AlignItems="AlignItems.End">
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="int" @bind-Value="_scoreModel.HomeScore" Label="@($"{_game.HomeTeam.Name} (home)")" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudNumericField T="int" @bind-Value="_scoreModel.AwayScore" Label="@($"{_game.AwayTeam.Name} (away)")" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="12" md="4">
                                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success" FullWidth="true">Save final score</MudButton>
                                </MudItem>
                            </MudGrid>
                        </EditForm>
                        <StatusMessage Message="@_scoreMessage" IsError="@_scoreError" />
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>

        <MudItem xs="12" md="5">
            <MudCard>
                <MudCardHeader>Game-day volunteers</MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Volunteer shifts scheduled for this game's day. Each shift is a regular <c>Assignment</c> on a game-day slot (e.g. "Game-Day Referee").</MudText>
                    @if (!_shifts.Any())
                    {
                        <MudText Typo="Typo.body2" Class="mud-text-secondary">None scheduled.</MudText>
                    }
                    else
                    {
                        <MudList T="ShiftRow" Dense="true">
                            @foreach (var s in _shifts)
                            {
                                <MudListItem>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <span><MudLink Href="@LinkBuilder.PersonHref(s.PersonUserId)">@s.PersonName</MudLink> · @s.SlotName</span>
                                        <MudChip T="string" Size="Size.Small" Color="@AssignmentStatusUi.MudColorFor(s.Status)">@s.Status</MudChip>
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IGameService GameService
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    [Parameter] public int GameId { get; set; }
    private Game? _game;
    private bool _canManage;
    // [SupplyParameterFromForm] — see Organizations/Edit.razor for rationale.
    [SupplyParameterFromForm] private ScoreModel _scoreModel { get; set; } = new();
    private string? _scoreMessage;
    private bool _scoreError;
    private List<ShiftRow> _shifts = new();

    // Breadcrumb items for MudBreadcrumbs. The last item is the current
    // page (no href, disabled). Built from the game data so it stays
    // in sync with whatever game the volunteer is viewing.
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new("Home", href: LinkBuilder.HomeHref()),
                new("Leagues", href: LinkBuilder.LeaguesHref()),
            };
            if (_game is not null)
            {
                items.Add(new BreadcrumbItem(_game.Ministry?.Name ?? "League", href: LinkBuilder.LeagueHref(_game.MinistryId)));
                items.Add(new BreadcrumbItem($"{_game.HomeTeam.Name} vs {_game.AwayTeam.Name}", href: null, disabled: true));
            }
            else
            {
                items.Add(new BreadcrumbItem($"Game #{GameId}", href: null, disabled: true));
            }
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        _game = await GameService.GetGameAsync(GameId);
        if (_game is null) return;

        if (!string.IsNullOrEmpty(userId))
        {
            _canManage = await OrgAuth.CanManageMinistryAsync(userId, _game.MinistryId);
        }

        // Default the score form to the current values (or 0-0) for convenience.
        _scoreModel = new ScoreModel
        {
            HomeScore = _game.HomeScore ?? 0,
            AwayScore = _game.AwayScore ?? 0,
        };

        // Game-day volunteer shifts: assignments on game-day slots in the
        // game's ministry whose time window overlaps the game.
        await using var db = await DbFactory.CreateDbContextAsync();
        _shifts = await db.Assignments
            .Where(a => a.ServiceSlot.MinistryId == _game.MinistryId
                && a.StartUtc < _game.EndUtc
                && a.EndUtc > _game.StartUtc
                && a.Status != AssignmentStatus.Cancelled)
            .OrderBy(a => a.StartUtc)
            .Select(a => new ShiftRow
            {
                Id = a.Id,
                PersonUserId = a.PersonUserId,
                PersonName = a.Person.DisplayName,
                SlotName = a.ServiceSlot.Name,
                Status = a.Status,
            })
            .AsNoTracking()
            .ToListAsync();
    }

    private async Task SaveScore()
    {
        if (_game is null || !_canManage) return;
        try
        {
            await GameService.SetScoreAsync(GameId, _scoreModel.HomeScore, _scoreModel.AwayScore);
            _game = await GameService.GetGameAsync(GameId);
            _scoreMessage = "Score saved.";
            _scoreError = false;
        }
        catch (Exception ex)
        {
            _scoreError = true;
            _scoreMessage = "Save failed: " + ex.Message;
        }
    }

    private class ScoreModel
    {
        public int HomeScore { get; set; }
        public int AwayScore { get; set; }
    }

    private class ShiftRow
    {
        public int Id { get; set; }
        public string PersonUserId { get; set; } = "";
        public string PersonName { get; set; } = "";
        public string SlotName { get; set; } = "";
        public AssignmentStatus Status { get; set; }
    }
}
