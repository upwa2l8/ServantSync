@page "/People"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Volunteers</PageTitle>

<h1>Volunteers</h1>

@* Privacy model: the global /People listing visibility is tier-scoped
   (single source of truth via OrgAuthService). Round-AW wires SystemAdmin
   to the global-acccess tier:

     - SystemAdmin: sees every Person across every org. Strictly
       visibility-only — they cannot edit other orgs' rosters without
       being OrganizationRole.Admin of those orgs.
     - OrgAdmin (any-org): sees only Person rows who have at least one
       OrganizationMembership in an org they Admin (the existing
       gate; below this comment).
     - Everyone else: "no access" panel.

   The filtered query below mirrors the user's requirement that
   volunteers shouldn't see other volunteers' information
   cross-org. The org-scoped Members tab on /Organizations/{Id} is the
   org-intra list; /People is the global directory for managers +
   sysadmins only. *@

@if (_loaded == false)
{
    <p><em>Loading…</em></p>
}
else if (!_isAdmin)
{
    <div class="alert alert-secondary">
        <h6 class="mb-2">No access</h6>
        <p class="mb-0 small">
            The global volunteer list is only visible to organization administrators.
            You can find your co-volunteers on the
            <a href="Organizations">Organizations</a> page &mdash; open any
            organization you're a member of, then the <strong>Members</strong> tab.
        </p>
    </div>
}
else
{
    <input class="form-control mb-3" placeholder="Search by name…" @bind="_filter" @bind:event="oninput" />

    @if (_people is null)
    {
        <p><em>Loading…</em></p>
    }
    else if (!_people.Any())
    {
        <div class="alert alert-info">No volunteers registered.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var p in Filtered)
            {
                <a class="list-group-item list-group-item-action" href="@($"People/{p.UserId}")">
                    <div class="d-flex justify-content-between">
                        <div>
                            <strong>@p.DisplayName</strong>
                            <div class="text-muted small">@p.Email</div>
                        </div>
                        <span class="badge bg-secondary">@p.MembershipCount memberships</span>
                    </div>
                </a>
            }
        </div>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    private List<PersonRow>? _people;
    private string _filter = "";
    // Round-AW tier flags: _isAdmin still gates the "no access" panel
    // shape but _isSystemAdmin gets its own OR-branch in the visibility
    // condition. The two are tracked separately so the markup's
    // descriptions can be tier-appropriate (SystemAdmin sees the global
    // directory; OrgAdmin sees the org-scoped directory; non-managers
    // see the no-access panel).
    private bool _isAdmin;
    private bool _isSystemAdmin;
    private bool? _loaded;

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _loaded = true;
            return;
        }
        // Round-AW: SystemAdmin gets the global pass; OrgAdmin stays
        // bounded by the existing IsAnyOrgAdminAsync gate. The two are
        // OR'd on the gate but the QUERY branches so SystemAdmin sees
        // every Person and an OrgAdmin sees the scoped set.
        var isSysAdmin = await OrgAuth.IsSystemAdminAsync(userId);
        _isAdmin = await OrgAuth.IsAnyOrgAdminAsync(userId);
        _isSystemAdmin = isSysAdmin;

        // Only fetch the listing when the gate passes; otherwise leave _people
        // null so the "no access" panel renders without an unneeded DB call.
        if (_isAdmin || _isSystemAdmin)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var query = db.People.AsNoTracking();
            if (!_isSystemAdmin)
            {
                // OrgAdmin path: only Persons who hold a current membership
                // in an org they Admin. The Memberships.Any() filter is
                // SQL-side so EF translates to one IN-clause over a sub-
                // query; no per-row round-trip.
                var myOrgIds = await db.OrganizationMemberships
                    .Where(m => m.PersonUserId == userId && m.Role == OrganizationRole.Admin)
                    .Select(m => m.OrganizationId).ToListAsync();
                query = query.Where(p => p.Memberships.Any(m => myOrgIds.Contains(m.OrganizationId)));
            }
            _people = await query
                .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                .Select(p => new PersonRow
                {
                    UserId = p.UserId,
                    DisplayName = p.DisplayName,
                    Email = p.User.Email ?? "",
                    MembershipCount = p.Memberships.Count,
                })
                .ToListAsync();
        }
        _loaded = true;
    }

    private IEnumerable<PersonRow> Filtered =>
        _people?
            .Where(p => string.IsNullOrEmpty(_filter)
                || p.DisplayName.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                || p.Email.Contains(_filter, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<PersonRow>();

    private class PersonRow
    {
        public string UserId { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public int MembershipCount { get; set; }
    }
}
