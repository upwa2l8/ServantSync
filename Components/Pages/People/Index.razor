@page "/People"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Volunteers</PageTitle>

<MudBreadcrumbs Items="_crumbs" Class="mb-2 px-0" />

<MudText Typo="Typo.h4" Class="mb-2">Volunteers</MudText>

@* Privacy model: the global /People listing visibility is tier-scoped
   (single source of truth via OrgAuthService). Round-AW wires SystemAdmin
   to the global-access tier:
     - SystemAdmin: sees every Person across every org. Strictly
       visibility-only — they cannot edit other orgs' rosters without
       being OrganizationRole.Admin of those orgs.
     - OrgAdmin (any-org): sees only Person rows who have at least one
       OrganizationMembership in an org they Admin (the existing
       gate; below this comment).
     - Everyone else: "no access" panel.
   The filtered query below mirrors the user's requirement that
   volunteers shouldn't see other volunteers' information
   cross-org. *@

@if (_loaded == false)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!_isAdmin)
{
    <MudPaper Outlined="true" Class="pa-4">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">No access</MudText>
            <MudText Typo="Typo.body2">
                The global volunteer list is only visible to organization administrators.
                You can find your co-volunteers on the
                <MudLink Href="Organizations">Organizations</MudLink> page &mdash; open any
                organization you're a member of, then the <strong>Members</strong> tab.
            </MudText>
        </MudStack>
    </MudPaper>
}
else
{
    <MudTextField T="string"
                  Value="_filter"
                  ValueChanged="v => _filter = v ?? string.Empty"
                  Immediate="true"
                  Placeholder="Search by name…"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Outlined.Search"
                  Class="mb-3"
                  Style="max-width:480px" />

    @if (_people is null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (!_people.Any())
    {
        <MudAlert Severity="Severity.Info">No volunteers registered.</MudAlert>
    }
    else
    {
        <MudPaper Outlined="true">
            <MudList T="PersonRow" Dense="true">
                @foreach (var p in Filtered)
                {
                    <MudListItem T="PersonRow" Href="@LinkBuilder.PersonHref(p.UserId)" Icon="@Icons.Material.Outlined.Person">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <strong>@p.DisplayName</strong>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@p.Email</MudText>
                            </div>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                @p.MembershipCount memberships
                            </MudChip>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    private List<PersonRow>? _people;
    private string _filter = "";
    // Round-AW tier flags: _isAdmin still gates the "no access" panel
    // shape but _isSystemAdmin gets its own OR-branch in the visibility
    // condition.
    private bool _isAdmin;
    private bool _isSystemAdmin;
    private bool? _loaded;
    private List<BreadcrumbItem> _crumbs = new()
    {
        new BreadcrumbItem("Home", href: ""),
        new BreadcrumbItem("Volunteers", href: null, disabled: true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            _loaded = true;
            return;
        }
        var isSysAdmin = await OrgAuth.IsSystemAdminAsync(userId);
        _isAdmin = await OrgAuth.IsAnyOrgAdminAsync(userId);
        _isSystemAdmin = isSysAdmin;

        if (_isAdmin || _isSystemAdmin)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var query = db.People.AsNoTracking();
            if (!_isSystemAdmin)
            {
                var myOrgIds = await db.OrganizationMemberships
                    .Where(m => m.PersonUserId == userId && m.Role == OrganizationRole.Admin)
                    .Select(m => m.OrganizationId).ToListAsync();
                query = query.Where(p => p.Memberships.Any(m => myOrgIds.Contains(m.OrganizationId)));
            }
            _people = await query
                .OrderBy(p => p.LastName).ThenBy(p => p.FirstName)
                .Select(p => new PersonRow
                {
                    UserId = p.UserId,
                    DisplayName = p.DisplayName,
                    Email = p.User.Email ?? "",
                    MembershipCount = p.Memberships.Count,
                })
                .ToListAsync();
        }
        _loaded = true;
    }

    private IEnumerable<PersonRow> Filtered =>
        _people?
            .Where(p => string.IsNullOrEmpty(_filter)
                || p.DisplayName.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                || p.Email.Contains(_filter, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<PersonRow>();

    private class PersonRow
    {
        public string UserId { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string Email { get; set; } = "";
        public int MembershipCount { get; set; }
    }
}
