@page "/People/{UserId}"
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>@(_person?.DisplayName ?? "Volunteer")</PageTitle>

<MudBreadcrumbs Items="@BreadcrumbItems" Class="mb-2" />

@if (!_hasLoaded)
{
    <MudText><em>Loading…</em></MudText>
}
else if (!_canView)
{
    <MudAlert Severity="Severity.Warning" Class="mt-3">
        <MudText Typo="Typo.h5">Not authorized</MudText>
        <MudText>You don't have access to view this volunteer's information.</MudText>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">
            The global People directory is available to organization administrators.
            Co-volunteers in your orgs can be found on the
            <MudLink Href="Organizations">Organizations</MudLink> page &mdash;
            open any org you're a member of, then the <strong>Members</strong> tab.
        </MudText>
    </MudAlert>
}
else if (_person is null)
{
    <MudText><em>Volunteer not found.</em></MudText>
}
else
{
    <MudText Typo="Typo.h4">@_person.DisplayName</MudText>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">@_person.User.Email</MudText>

    @* Tab strip as MudButton row styled as tabs. Preserves the string
       Tab property in @code (no ActivePanelIndex mapping needed). *@
    <MudStack Row="true" Spacing="0" Class="mb-0">
        <MudButton Variant="@(Tab == "orgs" ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick='() => Tab = "orgs"'>Organizations</MudButton>
        <MudButton Variant="@(Tab == "training" ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick='() => Tab = "training"'>Training</MudButton>
        <MudButton Variant="@(Tab == "schedule" ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick='() => Tab = "schedule"'>Schedule</MudButton>
    </MudStack>

    @if (Tab == "orgs")
    {
        <MudSimpleTable Hover="true" Bordered="false" Dense="true" Class="mt-3">
            <thead>
                <tr>
                    <th>Organization</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _person.Memberships)
                {
                    <tr>
                        <td><MudLink Href="@LinkBuilder.OrganizationHref(m.OrganizationId)">@m.Organization.Name</MudLink></td>
                        <td>@m.Role</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
    else if (Tab == "training")
    {
        if (!_person.TrainingCompletions.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">No training recorded yet.</MudAlert>
        }
        else
        {
            <MudSimpleTable Hover="true" Bordered="false" Dense="true" Class="mt-3">
                <thead>
                    <tr>
                        <th>Training</th>
                        <th>Completed</th>
                        <th>Expires</th>
                        <th>Valid?</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _person.TrainingCompletions)
                    {
                        var valid = c.IsValid(DateTime.UtcNow);
                        <tr>
                            <td><MudLink Href="@LinkBuilder.TrainingHref(c.TrainingContentId)">@c.TrainingContent.Title</MudLink> v@c.TrainingContentVersion</td>
                            <td>@c.CompletionUtc.ToString("u")</td>
                            <td>@(c.ExpiresUtc?.ToString("u") ?? "—")</td>
                            <td>@(valid ? "✅" : "❌")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    }
    else
    {
        @if (!_upcoming.Any())
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">No upcoming assignments.</MudAlert>
        }
        else
        {
            <MudSimpleTable Hover="true" Bordered="false" Dense="true" Class="mt-3">
                <thead>
                    <tr>
                        <th>When</th>
                        <th>Slot</th>
                        <th>Ministry</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _upcoming)
                    {
                        <tr>
                            <td><LocalTime Utc="@a.StartUtc" /> – <LocalTime Utc="@a.EndUtc" /></td>
                            <td>@a.ServiceSlot.Name</td>
                            <td>@a.ServiceSlot.Ministry.Name</td>
                            <td>@a.Status</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    }
}

@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@code {
    [Parameter] public string UserId { get; set; } = "";
    private Person? _person;
    private List<Assignment> _upcoming = new();
    private string Tab { get; set; } = "orgs";
    // True after OnInitializedAsync has finished so the renderer can show the
    // "Loading…" placeholder vs. a "Volunteer not found" / "Not authorized"
    // outcome. Without this, navigating to /People/{bogusId} would show
    // "Loading…" forever on the gate-denied path.
    private bool _hasLoaded;
    // Access-gate result. Default false (deny); set true only when one of
    // the three allowed rules fires (self / admin-of-shared-org / coach-of-
    // team-parent). The Person fetch is short-circuited when false so we
    // don't leak the volunteer's existence to a denied caller beyond the
    // gate panel.
    private bool _canView;
    private string _userId = "";

    // Breadcrumb items for MudBreadcrumbs. Conditional on the access-gate
    // result so a denied viewer sees only "Home" + "Volunteer" (no PII
    // leak), while an authorized viewer sees the full "Home / Volunteers /
    // {Name}" trail. Last item is always the current page (disabled).
    private List<BreadcrumbItem> BreadcrumbItems
    {
        get
        {
            var items = new List<BreadcrumbItem>
            {
                new("Home", href: LinkBuilder.HomeHref()),
            };
            if (_canView && _person is not null)
            {
                items.Add(new BreadcrumbItem("Volunteers", href: "People"));
                items.Add(new BreadcrumbItem(_person.DisplayName, href: null, disabled: true));
            }
            else
            {
                items.Add(new BreadcrumbItem("Volunteer", href: null, disabled: true));
            }
            return items;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        _userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

        // Self access. Identity owns their own profile — they're entitled to
        // see it regardless of any other organization membership.
        if (_userId == UserId)
        {
            _canView = true;
        }
        else if (!string.IsNullOrEmpty(_userId))
        {
            // Round-AW: SystemAdmin gets a third access path. They'd
            // previously have been denied under the older gate unless they
            // ALSO happened to be OrgAdmin of a shared org — now they can
            // view any volunteer's profile. Strictly visibility-only: they
            // cannot mutate the target's data; only Admin-of-shared-org
            // can do that (the page's existing edit affordances live in
            // Members tab on /Organizations/{Id} and remain per-org gated).
            // Short-circuit: SystemAdmin skips the shared-org EF round-trip
            // entirely.
            var isSysAdmin = await OrgAuth.IsSystemAdminAsync(_userId);
            await using var db = await DbFactory.CreateDbContextAsync();
            _canView = isSysAdmin
                || await db.OrganizationMemberships
                    .Where(my =>
                        my.PersonUserId == _userId
                        && my.Role == OrganizationRole.Admin
                        && db.OrganizationMemberships.Any(target =>
                            target.PersonUserId == UserId
                            && target.OrganizationId == my.OrganizationId))
                    .AnyAsync();
        }

        if (!_canView) { _hasLoaded = true; return; }

        await using var db2 = await DbFactory.CreateDbContextAsync();
        _person = await db2.People
            .Include(p => p.User)
            .Include(p => p.Memberships).ThenInclude(m => m.Organization)
            .Include(p => p.TrainingCompletions).ThenInclude(c => c.TrainingContent)
            .FirstOrDefaultAsync(p => p.UserId == UserId);

        if (_person is null) { _hasLoaded = true; return; }

        var fromUtc = DateTime.UtcNow;
        _upcoming = await db2.Assignments
            .Include(a => a.ServiceSlot).ThenInclude(s => s.Ministry)
            .Where(a => a.PersonUserId == UserId && a.StartUtc >= fromUtc
                && a.Status != AssignmentStatus.Cancelled)
            .OrderBy(a => a.StartUtc)
            .AsNoTracking()
            .ToListAsync();

        _hasLoaded = true;
    }
}
