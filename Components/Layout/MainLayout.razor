@* New MainLayout: replaces the dark-gradient sidebar / topbar shell with a
   MudAppBar + collapsible MudDrawer shell, all bound to the brand theme
   (ServantSyncTheme.Build inside MudProviders). Layout itself stays a
   LayoutComponentBase WITHOUT @rendermode, per the .NET 9 Blazor
   Body-is-a-RenderFragment-can't-cross-rendermode-boundary constraint
   documented in Components/Routes.razor. The providers component below
   (<MudProviders />) holds the InteractiveServer boundary.

   Phase 5 — Bootstrap removal: the prior class="d-flex align-items-center
   text-decoration-none" Bootstrap flex utilities are replaced with the
   MudBlazor-compatible d-flex + align-center utilities (align-items-center
   is the Bootstrap name; MudBlazor / Material use align-center). The
   class="ml-2" Bootstrap-specific margin utility is replaced with the
   spacing token ms-2 (margin-inline-start: 0.5rem) which works in
   both MudBlazor and standard CSS. The pa-6 utility on the main
   container is a MudBlazor spacing token. *@
@inherits LayoutComponentBase

<MudProviders />

<MudLayout>
    <MudAppBar Elevation="0"
               Color="Color.Dark"
               Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="Toggle navigation drawer" />
        <a href="" aria-label="ServantSync home" class="d-flex align-center text-decoration-none">
            <img src="@Assets["img/servantsync-mark.svg"]"
                 alt="ServantSync"
                 width="32" height="32"
                 style="border-radius:6px;background:rgba(255,255,255,0.06);padding:2px;" />
            <span class="ms-2"
                  style="color:#ffffff;font-weight:700;letter-spacing:-0.3px;font-size:1.05rem;">
                ServantSync
            </span>
        </a>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Outlined.AccountCircle"
                       Color="Color.Inherit"
                       Href="Account/Manage"
                       aria-label="Account" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Anchor="Anchor.Start"
               Elevation="1"
               Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true"
               ClipMode="DrawerClipMode.Always">
        <NavMenu OnDrawerLinkClicked="CloseDrawer" />
    </MudDrawer>

    <MudMainContent>
        <div class="ss-main-container pa-6">
            <TimeZoneInitializer />
            @Body
        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void CloseDrawer() => _drawerOpen = false;
}
