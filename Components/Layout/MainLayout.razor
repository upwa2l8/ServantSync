@* MainLayout — "Cyber Chapel" dark shell.
   MudAppBar + custom CSS drawer.  No @rendermode here (Body can't
   cross the render-mode boundary — see Routes.razor).

   Drawer setup:
   • Custom <aside> drawer controlled by CSS class .ss-drawer-open on
     the body element.  Toggle is pure JS (no Blazor interop needed),
     so it works in static SSR before the SignalR circuit warms up.
   • Desktop (>= 600px): drawer visible by default, hamburger toggles.
   • Mobile (< 600px): drawer hidden by default, hamburger toggles.
   • Resize watcher (livedrawer.js) auto-syncs the CSS class when the
     viewport crosses the 600px breakpoint.
   • Navigation closes the drawer on mobile via LocationChanged. *@
@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<MudProviders />

<MudLayout>
    <MudAppBar Elevation="0"
               Color="Color.Dark"
               Dense="false">
        @* Raw <button> — works in static SSR, no Razor OnClick needed.
           livedrawer.js handles the toggle via CSS class on <body>. *@
        <button class="mud-icon-button mud-icon-button-edge-start mud-icon-button-color-inherit"
                onclick="ssToggleDrawer()"
                type="button"
                aria-label="Toggle navigation drawer">
            <span class="mud-icon-root mud-icon mud-svg-icon mud-icon-size-medium">
                <svg focusable="false" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"></path>
                </svg>
            </span>
        </button>
        <a href="" aria-label="ServantSync home" class="d-flex align-center text-decoration-none">
            <img src="@Assets["img/servantsync-mark.svg"]"
                 alt="ServantSync"
                 width="32" height="32"
                 style="border-radius:8px;background:rgba(167,139,250,0.12);padding:3px;" />
            <span class="ms-2"
                  style="color:#c4b5fd;font-weight:800;letter-spacing:-0.4px;font-size:1.1rem;">
                ServantSync
            </span>
        </a>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Outlined.AccountCircle"
                       Color="Color.Inherit"
                       Href="Account/Manage"
                       aria-label="Account" />
    </MudAppBar>

    @* Custom drawer — pure HTML/CSS, no MudDrawer state machine.
       Toggle via .ss-drawer-open class on <body>. *@
    <aside class="ss-drawer" aria-label="Navigation">
        <NavMenu />
    </aside>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="ss-main-content pa-4">
            <TimeZoneInitializer />
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _disposed;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, EventArgs e)
    {
        if (_disposed) return;
        // Close the drawer on every route change so mobile visitors
        // don't land on a new page with the drawer still open.
        try
        {
            _ = JS.InvokeVoidAsync("ssCloseDrawer");
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }
    }

    public void Dispose()
    {
        _disposed = true;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
