@using Microsoft.AspNetCore.Components.Authorization
@using ServantSync.Services

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        @* The navbar brand. Uses the mark SVG (square 512×512, scales
           cleanly) at a fixed navbar height; CSS caps the rendered size
           so the SVG doesn't burst up to its native dimensions. The
           visible "ServantSync" wordmark is preserved as accessible
           text for screen readers (aria-label), and as a no-CSS fallback
           if the SVG fails to load (the `<img>` alt text). The home
           link is unchanged so the existing "/" navigation still works.
           See BRANDING.md for the design tokens behind the choice. *@
        <a class="navbar-brand d-flex align-items-center gap-2" href="" aria-label="ServantSync home">
            <img src="@Assets["img/servantsync-mark.svg"]"
                 alt="ServantSync"
                 width="36" height="36"
                 class="navbar-brand-mark" />
            <span class="navbar-brand-wordmark">ServantSync</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                @* Round-FR-5: link visibility is driven by three role-aware
                   flags (each one a pre-computed bit in @code), per the
                   spec table in PLAN.md → Round-FR-5. The links break
                   down into three tiers:

                     • _isAdmin            → Organizations / Volunteers / Leagues
                                              (the "manage the whole org" surfaces)
                     • _isTrainingManager  → In-person training catalog
                                              (admin + ministry directors only;
                                              slot coordinators don't manage training)
                     • _isTrainingManager
                       || _isSlotCoordinator → Dashboard
                       (all visible management tiers + slot coordinators see
                        only their dashboard, never the org-wide nav)

                   _isSystemAdmin widens ALL flags so a fresh sysadmin with
                   no per-org Admin/Coordinator role still sees the same nav
                   as a per-org admin — they go through every page in
                   visibility-only mode anyway. *@
                @if (_isAdmin)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Organizations">
                            <span class="bi bi-building-nav-menu" aria-hidden="true"></span> Organizations
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="People">
                            <span class="bi bi-people-nav-menu" aria-hidden="true"></span> Volunteers
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Leagues">
                            <span class="bi bi-trophy-nav-menu" aria-hidden="true"></span> Leagues
                        </NavLink>
                    </div>
                }
                @if (_isTrainingManager || _isSlotCoordinator)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Dashboard">
                            <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Dashboard
                        </NavLink>
                    </div>
                }
                @if (_isTrainingManager)
                {
                    @* In-person training discoverability. Slot Coordinators
                       deliberately do NOT see this link — they manage slots,
                       not the training catalog (per the spec's IsAnyTrainingManagerAsync). *@
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="Training/Manage">
                            <span class="bi bi-mortarboard-nav-menu" aria-hidden="true"></span> In-person training
                        </NavLink>
                    </div>
                }
                @* Always-visible links for any signed-in user, regardless of
                   org role. Training / My schedule / Browse open slots are
                   the volunteer-primary surfaces; volunteers without any
                   manage role still need them. *@
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Training">
                        <span class="bi bi-mortarboard-nav-menu" aria-hidden="true"></span> Training
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="MySchedule">
                        <span class="bi bi-calendar-nav-menu" aria-hidden="true"></span> My schedule
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Open">
                        <span class="bi bi-search-nav-menu" aria-hidden="true"></span> Browse open slots
                    </NavLink>
                </div>

                <div class="nav-item px-3 mt-3 border-top border-secondary pt-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-circle-nav-menu" aria-hidden="true"></span> Account
                    </NavLink>
                </div>
                @* SystemAdmin-only nav link — only renders when the round-BC
                   IsSystemAdminAsync lookup succeeds. Stays invisible for
                   non-SysAdmin signed-in users; OrgAdmins/Coordinators do
                   not see this link. *@
                @if (_isSystemAdmin)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="SystemAdmin">
                            <span class="bi bi-shield-lock-nav-menu" aria-hidden="true"></span> System admin
                        </NavLink>
                    </div>
                }
                <div class="nav-item px-3">
                    <form method="post" action="Account/Logout">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link btn btn-link text-start w-100">
                            <span class="bi bi-box-arrow-right-nav-menu" aria-hidden="true"></span> Sign out
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3 mt-3 border-top border-secondary pt-3">
                    <NavLink class="nav-link" href="Account/Login">Sign in</NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">Register</NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject ILoggerFactory LoggerFactory
@implements IDisposable
@code {
    // Round-FR-5: three role-aware flags driven by the spec table.
    //
    //   _isAdmin            → Admin of any org OR SystemAdmin.
    //                         Drives Organizations / Volunteers / Leagues
    //                         nav links.
    //   _isTrainingManager  → Admin || MinistryDirector || SystemAdmin.
    //                         Drives the In-person training catalog link
    //                         (slot coordinators are explicitly NOT training
    //                         managers — they manage slots, not training).
    //   _isSlotCoordinator  → IsAnySlotCoordinatorAsync. The membership-role
    //                         label (not entity-level delegation) drives
    //                         Dashboard visibility for slot coordinators.
    //                         Specific slot management goes through
    //                         ServiceSlot.CoordinatorPersonUserId per the
    //                         spec's "key design principle".
    //   _isSystemAdmin      → ASP.NET Core Identity "SystemAdmin" role.
    //                         Stays orthogonal to the other three flags so
    //                         the SystemAdmin nav link can render even for a
    //                         SysAdmin who isn't a per-org Admin/Coordinator.
    //
    // All four default false until OnInitializedAsync finishes — that way
    // the unauthorized user never sees a flicker of manage-only links while
    // the auth-state await runs.
    private bool _isAdmin;
    private bool _isTrainingManager;
    private bool _isSlotCoordinator;
    private bool _isSystemAdmin;
    // Toolbar logger: created in OnInitialized so we don't allocate on
    // every auth-state tick. Logging takes the place of a silent catch so
    // a logic bug in RefreshManagerFlagAsync is visible in production
    // logs rather than hiding behind a swallowed exception.
    private ILogger _log = null!;

    protected override async Task OnInitializedAsync()
    {
        _log = LoggerFactory.CreateLogger("ServantSync.Components.NavMenu");
        Auth.AuthenticationStateChanged += OnAuthStateChanged;
        await RefreshManagerFlagAsync();
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            await RefreshManagerFlagAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _log.LogWarning(ex, "NavMenu: ignored error refreshing manager flags; will retry on next state change.");
        }
    }

    private async Task RefreshManagerFlagAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            _isAdmin = _isTrainingManager = _isSlotCoordinator = _isSystemAdmin = false;
            return;
        }
        _isSystemAdmin = await OrgAuth.IsSystemAdminAsync(userId);
        // _isAdmin widens to OR SystemAdmin: a fresh SysAdmin with no
        // per-org Admin role still sees Organizations / Volunteers /
        // Leagues so they can navigate to the pages the SystemAdmin
        // visibility-only contract grants them.
        _isAdmin = await OrgAuth.IsAnyOrgAdminAsync(userId) || _isSystemAdmin;
        // _isTrainingManager: Admin or MinistryDirector of any org,
        // OR SystemAdmin. Slot Coordinators deliberately do NOT count
        // (per IsAnyTrainingManagerAsync).
        _isTrainingManager = await OrgAuth.IsAnyTrainingManagerAsync(userId) || _isSystemAdmin;
        // _isSlotCoordinator: membership-role label only (per spec key
        // design principle — actual slot-level management goes via
        // ServiceSlot.CoordinatorPersonUserId, not this OrgRole label).
        _isSlotCoordinator = await OrgAuth.IsAnySlotCoordinatorAsync(userId);
    }

    public void Dispose()
    {
        Auth.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
