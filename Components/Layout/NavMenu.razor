@* New NavMenu. Grouped by audience (the user-feedback request): the
   volunteer sees "Browse" prominently; the manager sees "Manage" tucked
   below; the sysadmin sees "System" at the bottom. Sections are
   collapsible MudNavGroups with role-driven visibility, preserving the
   Round-FR-5 RBAC contract from the original NavMenu (the comment
   block below preserves the exact four flag semantics):
     • _isAdmin            → Admin || SystemAdmin
     • _isTrainingManager  → Admin || MinistryDirector || SystemAdmin
                                         (slot coordinators do NOT count)
     • _isSlotCoordinator  → any SlotCoordinator membership
     • _isSystemAdmin      → ASP.NET Core Identity "SystemAdmin" role
   The flag pass-through is the same OrgAuthService surface that the
   prior sidebar called, so a future rebalance only edits the four
   OrgAuth predicates, not this file. *@
@using Microsoft.AspNetCore.Components.Authorization
@using ServantSync.Services

<MudNavMenu>
    @* ----- Home (everyone) ----- *@
    <MudNavLink Href=""
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Outlined.Home">
        Home
    </MudNavLink>

    <AuthorizeView>
        <Authorized>
            @* ----- For me -----
               Always visible to any signed-in user. Volunteers without
               any manage role still need these. *@
            <MudNavGroup Title="For me"
                         Icon="@Icons.Material.Outlined.PersonOutline"
                         Expanded="true">
                <MudNavLink Href="MySchedule"
                            Icon="@Icons.Material.Outlined.CalendarMonth">My schedule</MudNavLink>
                <MudNavLink Href="Training"
                            Icon="@Icons.Material.Outlined.School">My training</MudNavLink>
                <MudNavLink Href="Open"
                            Icon="@Icons.Material.Outlined.Search">Browse open slots</MudNavLink>
            </MudNavGroup>

            @* ----- Browse ---
               Volunteers need to easily browse ministries and slots
               (user feedback; the slot-level browse mission was why
               "Browse open slots" was promoted into "For me" above). *@
            <MudNavGroup Title="Browse"
                         Icon="@Icons.Material.Outlined.Explore"
                         Expanded="true">
                <MudNavLink Href="Organizations"
                            Icon="@Icons.Material.Outlined.Business">Organizations</MudNavLink>
            </MudNavGroup>

            @* ----- Manage (admin/coord) ----- *@
            @if (_isAdmin || _isTrainingManager || _isSlotCoordinator)
            {
                <MudNavGroup Title="Manage"
                             Icon="@Icons.Material.Outlined.AdminPanelSettings"
                             Expanded="@_manageExpanded"
                             ExpandedChanged="v => _manageExpanded = v">
                    @if (_isTrainingManager || _isSlotCoordinator)
                    {
                        <MudNavLink Href="Dashboard"
                                    Icon="@Icons.Material.Outlined.Speed">Dashboard</MudNavLink>
                    }
                    @if (_isAdmin)
                    {
                        <MudNavLink Href="People"
                                    Icon="@Icons.Material.Outlined.People">Volunteers</MudNavLink>
                        <MudNavLink Href="Leagues"
                                    Icon="@Icons.Material.Outlined.EmojiEvents">Leagues</MudNavLink>
                    }
                    @if (_isTrainingManager)
                    {
                        <MudNavLink Href="Training/Manage"
                                    Icon="@Icons.Material.Outlined.Class">
                            In-person training
                        </MudNavLink>
                    }
                </MudNavGroup>
            }

            @* ----- System (sysadmin) ----- *@
            @if (_isSystemAdmin)
            {
                <MudNavGroup Title="System"
                             Icon="@Icons.Material.Outlined.Shield"
                             Expanded="false">
                    <MudNavLink Href="SystemAdmin"
                                Icon="@Icons.Material.Outlined.AdminPanelSettings">
                        System admin
                    </MudNavLink>
                </MudNavGroup>
            }

            @* ----- Account (sign out lives at the very bottom under the
               identity surface; clicking it posts a real form to
               /Account/Logout, which signs the cookie out, then
               redirects to "/" — same Minimal-API endpoint as before). ----- *@
            <MudNavGroup Title="Account"
                         Icon="@Icons.Material.Outlined.AccountCircle"
                         Expanded="false">
                <MudNavLink Href="Account/Manage"
                            Icon="@Icons.Material.Outlined.ManageAccounts">
                    Account settings
                </MudNavLink>
                <form method="post" action="Account/Logout" class="mud-nav-logout-form">
                    <AntiforgeryToken />
                    <button type="submit"
                            class="mud-nav-logout-btn">
                        <MudIcon Icon="@Icons.Material.Outlined.Logout"
                                 Class="mud-nav-logout-icon" />
                        <span>Sign out</span>
                    </button>
                </form>
            </MudNavGroup>
        </Authorized>
        <NotAuthorized>
            <MudNavGroup Title="Account"
                         Icon="@Icons.Material.Outlined.AccountCircle"
                         Expanded="true">
                <MudNavLink Href="Account/Login"
                            Icon="@Icons.Material.Outlined.Login">Sign in</MudNavLink>
                <MudNavLink Href="Account/Register"
                            Icon="@Icons.Material.Outlined.PersonAdd">Register</MudNavLink>
            </MudNavGroup>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@inject AuthenticationStateProvider Auth
@inject IOrgAuthService OrgAuth
@inject ILoggerFactory LoggerFactory
@implements IDisposable
@code {
    // RBAC flag set — see the comment block at the top of this file for
    // the exact field semantics; they're identical to the prior NavMenu's
    // so the OrgAuthService contract is unchanged.
    private bool _isAdmin;
    private bool _isTrainingManager;
    private bool _isSlotCoordinator;
    private bool _isSystemAdmin;
    private bool _manageExpanded = true;
    private ILogger _log = null!;

    protected override async Task OnInitializedAsync()
    {
        _log = LoggerFactory.CreateLogger("ServantSync.Components.NavMenu");
        Auth.AuthenticationStateChanged += OnAuthStateChanged;
        await RefreshManagerFlagAsync();
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            await RefreshManagerFlagAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _log.LogWarning(ex, "NavMenu: ignored error refreshing manager flags; will retry on next state change.");
        }
    }

    private async Task RefreshManagerFlagAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        var userId = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(userId))
        {
            _isAdmin = _isTrainingManager = _isSlotCoordinator = _isSystemAdmin = false;
            return;
        }
        _isSystemAdmin = await OrgAuth.IsSystemAdminAsync(userId);
        _isAdmin = await OrgAuth.IsAnyOrgAdminAsync(userId) || _isSystemAdmin;
        _isTrainingManager = await OrgAuth.IsAnyTrainingManagerAsync(userId) || _isSystemAdmin;
        _isSlotCoordinator = await OrgAuth.IsAnySlotCoordinatorAsync(userId);
    }

    public void Dispose()
    {
        Auth.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
